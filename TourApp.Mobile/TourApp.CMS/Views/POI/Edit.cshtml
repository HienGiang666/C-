@model TourApp.CMS.Models.POI
@{
    ViewData["Title"] = "Cập nhật địa điểm";
    var isAdmin = ViewBag.IsAdminPoiEdit as bool? == true;
    var translations = ViewBag.Translations as List<TourApp.CMS.Models.POITranslation> ?? new List<TourApp.CMS.Models.POITranslation>();
    var languages = new[] {
        ("en", "🇬🇧 English"), ("zh", "🇨🇳 中文"), ("ja", "🇯🇵 日本語")
    };
    var allCategories = ViewBag.AllCategories as List<TourApp.CMS.Models.Category> ?? new List<TourApp.CMS.Models.Category>();
    var poiCategoryIds = ViewBag.PoiCategoryIds as List<int> ?? new List<int>();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen me-2 text-primary"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />

                    @if (isAdmin)
                    {
                        <div class="alert alert-info small">
                            <strong>Quản trị viên:</strong> chỉ được khóa/mở (hoạt động), và chỉnh bán kính quét, độ ưu tiên, đánh giá.
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Tên địa điểm</label>
                            <input class="form-control" value="@Model.Name" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Địa chỉ</label>
                            <input class="form-control" value="@Model.Address" readonly />
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Vĩ độ</label>
                                <input class="form-control" value="@Model.Latitude" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Kinh độ</label>
                                <input class="form-control" value="@Model.Longitude" readonly />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Giờ mở cửa</label>
                            <input class="form-control" value="@Model.OpenTime" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Mô tả</label>
                            <textarea class="form-control" rows="3" readonly>@Model.Description</textarea>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">Ảnh hiện tại</label>
                                <div><img src="@Model.ImageUrl" alt="" class="img-thumbnail" style="max-height: 100px" /></div>
                            </div>
                        }
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Radius" class="form-label fw-medium">Bán kính quét (m) <span class="text-danger">*</span></label>
                                <input asp-for="Radius" class="form-control" type="number" min="1" step="1" required />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Priority" class="form-label fw-medium">Độ ưu tiên <span class="text-danger">*</span></label>
                                <input asp-for="Priority" class="form-control" type="number" min="1" step="1" required />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Rating" class="form-label fw-medium">Đánh giá <span class="text-danger">*</span></label>
                                <input asp-for="Rating" class="form-control" type="number" step="any" min="0.01" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                <label class="form-check-label" asp-for="IsActive">Đang hoạt động trên App</label>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium">Tên địa điểm <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-medium">Địa chỉ <span class="text-danger">*</span></label>
                            <input asp-for="Address" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Chọn vị trí trên bản đồ <span class="text-danger">*</span></label>
                            <div class="input-group mb-2">
                                <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                                <input type="text" id="mapSearch" class="form-control" placeholder="Tìm địa điểm..." />
                                <button type="button" class="btn btn-outline-primary" onclick="searchPlace()">Tìm</button>
                            </div>
                            <div id="goongMap" style="height:350px;border-radius:8px;border:1px solid #dee2e6;"></div>
                            <small class="text-muted"><i class="fa-solid fa-hand-pointer me-1"></i>Click trên bản đồ để chọn vị trí</small>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Latitude" class="form-label fw-medium">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                                <input asp-for="Latitude" id="Latitude" class="form-control bg-light" type="number" step="any" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Longitude" class="form-label fw-medium">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                                <input asp-for="Longitude" id="Longitude" class="form-control bg-light" type="number" step="any" required />
                            </div>
                        </div>
                        <input type="hidden" asp-for="Radius" value="20" />
                        <input type="hidden" asp-for="Priority" value="1" />
                        <p class="small text-muted">Bán kính <strong>20 m</strong> và độ ưu tiên <strong>1</strong> do hệ thống cố định cho chủ quán.</p>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Rating" class="form-label fw-medium">Đánh giá <span class="text-danger">*</span></label>
                                <input asp-for="Rating" class="form-control" type="number" step="any" min="0.01" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="OpenTime" class="form-label fw-medium">Giờ mở cửa <span class="text-danger">*</span></label>
                                <input asp-for="OpenTime" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Ảnh đại diện</label>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ImageUrl" alt="Current Image" class="img-thumbnail" style="max-height: 100px" />
                                </div>
                            }
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                            <small class="text-muted">Bỏ trống nếu muốn giữ nguyên ảnh hiện tại.</small>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                <label class="form-check-label" asp-for="IsActive">Đang hoạt động trên App</label>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-medium">Mô tả chi tiết (Tiếng Việt) <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
                        </div>
                    }

                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===== CATEGORY SECTION ===== -->
        <div class="card border-0 mt-4">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-tags me-2 text-warning"></i> Danh mục</h5>
            </div>
            <div class="card-body p-4">
                <form method="post" asp-action="SaveCategories" asp-route-id="@Model.Id">
                    <p class="text-muted small mb-3">Chọn một hoặc nhiều danh mục cho địa điểm này.</p>
                    <div class="row g-3">
                        @foreach (var cat in allCategories)
                        {
                            var isChecked = poiCategoryIds.Contains(cat.Id);
                            <div class="col-md-3 col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="categoryIds" value="@cat.Id" id="cat_@cat.Id" @(isChecked ? "checked" : "")>
                                    <label class="form-check-label" for="cat_@cat.Id">
                                        <span class="badge rounded-pill" style="background-color:@(cat.Color ?? "#6c757d")">@cat.Name</span>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-save me-1"></i> Lưu danh mục</button>
                    </div>
                </form>
            </div>
        </div>
        <!-- ===== END CATEGORY SECTION ===== -->

        <!-- ===== TRANSLATION SECTION ===== -->
        <div class="card border-0 mt-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-language me-2 text-success"></i> Bản dịch đa ngôn ngữ</h5>
                <button type="button" class="btn btn-success btn-sm" onclick="autoTranslateAll()">
                    <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Tự động dịch tất cả
                </button>
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-3">Nhập bản dịch mô tả cho từng ngôn ngữ. Bấm <strong>"Tự động dịch tất cả"</strong> để hệ thống tự dịch từ mô tả tiếng Việt. Sau đó bấm <strong>"Lưu tất cả"</strong>.</p>

                <div id="translationStatus" class="alert alert-info small d-none mb-3">
                    <i class="fa-solid fa-spinner fa-spin me-1"></i> <span id="translationStatusText">Đang dịch...</span>
                </div>

                <form method="post" asp-action="SaveAllTranslations" asp-route-id="@Model.Id">
                    <div class="row g-3">
                        @for (var i = 0; i < languages.Length; i++)
                        {
                            var (code, label) = languages[i];
                            var existing = translations.FirstOrDefault(t => t.Language == code);
                            <div class="col-md-6">
                                <div class="card h-100 border">
                                    <div class="card-header py-2 bg-light d-flex justify-content-between align-items-center">
                                        <span class="fw-semibold small">@label</span>
                                        @if (existing != null && !string.IsNullOrWhiteSpace(existing.Description))
                                        {
                                            <span class="badge bg-success">✓ Đã dịch</span>
                                        }
                                    </div>
                                    <div class="card-body p-2">
                                        <input type="hidden" name="langs[]" value="@code" />
                                        <input type="text" name="names[]" id="name-@code" class="form-control form-control-sm mb-2"
                                               value="@(existing?.Name ?? "")" placeholder="Tên quán dịch..." />
                                        <textarea name="descs[]" id="desc-@code" class="form-control form-control-sm" rows="3"
                                                  placeholder="Mô tả dịch...">@(existing?.Description ?? "")</textarea>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-save me-1"></i> Lưu tất cả bản dịch
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <!-- ===== END TRANSLATION SECTION ===== -->

    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.js"></script>
    <script>
        // ===== GOONG MAP PICKER =====
        document.addEventListener('DOMContentLoaded', function () {
            var mapEl = document.getElementById('goongMap');
            if (!mapEl) return; // Admin view has no map

            var GOONG_MAPTILE_KEY = '2Dnp8yaRq6ivkjX5c7D7RFcx5tDSi5g512jA5dG9';
            var GOONG_REST_KEY = 'FEx6pcCh7bba5bfwJC4M7truNtLS7rEAwkZQZZ8g';
            goongjs.accessToken = GOONG_MAPTILE_KEY;

            var existingLat = parseFloat(document.getElementById('Latitude')?.value) || 10.762;
            var existingLng = parseFloat(document.getElementById('Longitude')?.value) || 106.702;

            var map = new goongjs.Map({
                container: 'goongMap',
                style: 'https://tiles.goong.io/assets/goong_map_web.json?api_key=' + GOONG_MAPTILE_KEY,
                center: [existingLng, existingLat],
                zoom: 15
            });

            var marker = null;

            function setMarker(lat, lng, address) {
                if (marker) marker.remove();
                marker = new goongjs.Marker({ color: '#e74c3c' })
                    .setLngLat([lng, lat])
                    .addTo(map);
                document.getElementById('Latitude').value = lat.toFixed(6);
                document.getElementById('Longitude').value = lng.toFixed(6);
                if (address) {
                    document.getElementById('Address').value = address;
                }
            }

            // Reverse geocode khi click bản đồ
            function reverseGeocode(lat, lng) {
                var url = 'https://rsapi.goong.io/Geocode?latlng=' + lat + ',' + lng + '&api_key=' + GOONG_REST_KEY;
                fetch(url).then(r => r.json()).then(data => {
                    if (data.results && data.results.length > 0) {
                        document.getElementById('Address').value = data.results[0].formatted_address;
                    }
                }).catch(() => {});
            }

            // Show existing marker if POI already has coordinates
            if (existingLat > 0 && existingLng > 0) {
                setMarker(existingLat, existingLng);
            }

            map.on('click', function (e) {
                setMarker(e.lngLat.lat, e.lngLat.lng);
                reverseGeocode(e.lngLat.lat, e.lngLat.lng);
            });

            // Tìm kiếm bằng Goong Place AutoComplete + Detail
            window.searchPlace = function () {
                var query = document.getElementById('mapSearch').value.trim();
                if (!query) return;
                var center = map.getCenter();
                var url = 'https://rsapi.goong.io/Place/AutoComplete?api_key=' + GOONG_REST_KEY
                    + '&input=' + encodeURIComponent(query)
                    + '&location=' + center.lat + ',' + center.lng;
                fetch(url).then(r => r.json()).then(data => {
                    if (data.predictions && data.predictions.length > 0) {
                        var placeId = data.predictions[0].place_id;
                        var desc = data.predictions[0].description;
                        var detailUrl = 'https://rsapi.goong.io/Place/Detail?api_key=' + GOONG_REST_KEY + '&place_id=' + placeId;
                        fetch(detailUrl).then(r => r.json()).then(detail => {
                            if (detail.result && detail.result.geometry) {
                                var loc = detail.result.geometry.location;
                                map.flyTo({ center: [loc.lng, loc.lat], zoom: 17 });
                                setMarker(loc.lat, loc.lng, detail.result.formatted_address || desc);
                            }
                        });
                    } else {
                        alert('Không tìm thấy địa điểm. Thử nhập cụ thể hơn.');
                    }
                }).catch(() => alert('Lỗi tìm kiếm. Vui lòng thử lại.'));
            };

            document.getElementById('mapSearch').addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); searchPlace(); }
            });
        });
    </script>

    <!-- Translation script -->
    <script>
        const poiDescription = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Description ?? ""));
        const poiName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name ?? ""));
        const langCodes = [@Html.Raw(string.Join(",", languages.Select(l => $"\"{l.Item1}\"")))];

        async function translateText(text, targetLang) {
            try {
                const url = `/api/Translate?text=${encodeURIComponent(text)}&target=${targetLang}&source=vi`;
                const response = await fetch(url);
                if (!response.ok) return text;
                const data = await response.json();
                if (data && data[0] && data[0].length > 0) {
                    return data[0].map(x => x[0]).join('');
                }
                return text;
            } catch {
                return text;
            }
        }

        async function autoTranslateAll() {
            if (!poiDescription && !poiName) {
                alert('Vui lòng nhập mô tả tiếng Việt trước khi dịch.');
                return;
            }

            const statusDiv = document.getElementById('translationStatus');
            const statusText = document.getElementById('translationStatusText');
            statusDiv.classList.remove('d-none');

            for (let i = 0; i < langCodes.length; i++) {
                const code = langCodes[i];
                statusText.textContent = `Đang dịch ${code}... (${i + 1}/${langCodes.length})`;

                try {
                    if (poiName) {
                        const nameBox = document.getElementById(`name-${code}`);
                        if (nameBox && !nameBox.value.trim()) {
                            nameBox.value = await translateText(poiName, code);
                        }
                    }
                    if (poiDescription) {
                        const descBox = document.getElementById(`desc-${code}`);
                        if (descBox && !descBox.value.trim()) {
                            descBox.value = await translateText(poiDescription, code);
                        }
                    }
                } catch (err) {
                    console.warn(`Dịch ${code} thất bại:`, err);
                }
            }

            statusText.textContent = '✅ Dịch xong! Kiểm tra và bấm "Lưu tất cả bản dịch" để lưu.';
            setTimeout(() => statusDiv.classList.add('d-none'), 5000);
        }
    </script>
}
