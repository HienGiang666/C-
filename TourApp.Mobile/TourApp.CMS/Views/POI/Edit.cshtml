@model TourApp.CMS.Models.POI

@{
    ViewData["Title"] = "Chỉnh sửa Địa điểm";
}

<div class="page-breadcrumb">
    <i class="fas fa-map-marker-alt"></i> Quản lý / Địa điểm / <span class="text-primary">Chỉnh sửa</span>
</div>

<div class="page-title">✏️ Chỉnh sửa Địa điểm</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Thông tin Địa điểm</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Tên Địa điểm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Chợ Bến Thành" required />
                        <small class="form-text text-muted">Nhập tên đầy đủ của địa điểm du lịch</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="6" placeholder="Nhập bài giới thiệu chi tiết về địa điểm..." required></textarea>
                        <small class="form-text text-muted">Mô tả chi tiết sẽ được hiển thị cho khách</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Latitude" class="form-label fw-bold">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" type="number" step="0.000001" class="form-control" placeholder="Ví dụ: 10.7725" required />
                            <small class="form-text text-muted">Tọa độ vĩ độ (thành phố HCM: 10.7725)</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Longitude" class="form-label fw-bold">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" type="number" step="0.000001" class="form-control" placeholder="Ví dụ: 106.6980" required />
                            <small class="form-text text-muted">Tọa độ kinh độ (thành phố HCM: 106.6980)</small>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i> Lưu Thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">ℹ️ Thông tin</h5>
            </div>
            <div class="card-body">
                <p><strong>ID:</strong> <span class="badge bg-secondary">@Model.Id</span></p>
                <hr>
                <p><strong>Cách nhập tọa độ:</strong></p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-map-pin text-primary"></i> Vĩ độ: Từ -90 đến +90</li>
                    <li><i class="fas fa-map-pin text-primary"></i> Kinh độ: Từ -180 đến +180</li>
                </ul>
            </div>
        </div>
    </div>
</div>