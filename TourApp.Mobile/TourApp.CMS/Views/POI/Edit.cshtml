@model TourApp.CMS.Models.POI
@{
    ViewData["Title"] = "Cập nhật địa điểm";
    var isAdmin = ViewBag.IsAdminPoiEdit as bool? == true;
    var translations = ViewBag.Translations as List<TourApp.CMS.Models.POITranslation> ?? new List<TourApp.CMS.Models.POITranslation>();
    var languages = new[] {
        ("en", "🇬🇧 English"), ("zh", "🇨🇳 中文"), ("ja", "🇯🇵 日本語")
    };
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen me-2 text-primary"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />

                    @if (isAdmin)
                    {
                        <div class="alert alert-info small">
                            <strong>Quản trị viên:</strong> chỉ được khóa/mở (hoạt động), và chỉnh bán kính quét, độ ưu tiên, đánh giá.
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Tên địa điểm</label>
                            <input class="form-control" value="@Model.Name" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Địa chỉ</label>
                            <input class="form-control" value="@Model.Address" readonly />
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Vĩ độ</label>
                                <input class="form-control" value="@Model.Latitude" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Kinh độ</label>
                                <input class="form-control" value="@Model.Longitude" readonly />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Giờ mở cửa</label>
                            <input class="form-control" value="@Model.OpenTime" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Mô tả</label>
                            <textarea class="form-control" rows="3" readonly>@Model.Description</textarea>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">Ảnh hiện tại</label>
                                <div><img src="@Model.ImageUrl" alt="" class="img-thumbnail" style="max-height: 100px" /></div>
                            </div>
                        }
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Radius" class="form-label fw-medium">Bán kính quét (m) <span class="text-danger">*</span></label>
                                <input asp-for="Radius" class="form-control" type="number" min="1" step="1" required />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Priority" class="form-label fw-medium">Độ ưu tiên <span class="text-danger">*</span></label>
                                <input asp-for="Priority" class="form-control" type="number" min="1" step="1" required />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Rating" class="form-label fw-medium">Đánh giá <span class="text-danger">*</span></label>
                                <input asp-for="Rating" class="form-control" type="number" step="any" min="0.01" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                <label class="form-check-label" asp-for="IsActive">Đang hoạt động trên App</label>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium">Tên địa điểm <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-medium">Địa chỉ <span class="text-danger">*</span></label>
                            <input asp-for="Address" class="form-control" required />
                        </div>
                        <!-- Map Picker Section -->
                        <div class="mb-3">
                            <label class="form-label fw-medium">Vị trí trên bản đồ <span class="text-danger">*</span></label>
                            <div class="mb-2">
                                <button type="button" class="btn btn-outline-secondary" id="btnCurrentLocation">
                                    <i class="fa-solid fa-crosshairs me-2"></i>Lấy vị trí hiện tại
                                </button>
                            </div>
                            <div id="mapPicker" style="height: 300px; width: 100%; border-radius: 8px; border: 1px solid #dee2e6;"></div>
                            <small class="text-muted mt-1 d-block">
                                <i class="fa-solid fa-info-circle me-1"></i>Click trên bản đồ để chọn vị trí chính xác.
                            </small>
                            <div id="selectedLocationInfo" class="alert alert-info mt-2 @(Model.Latitude != 0 && Model.Longitude != 0 ? "" : "d-none") small">
                                <i class="fa-solid fa-check-circle me-2 text-success"></i>
                                <span>Đã chọn: <strong id="locationText">@(Model.Latitude != 0 && Model.Longitude != 0 ? $"{Model.Latitude}, {Model.Longitude}" : "Chưa chọn")</strong></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Latitude" class="form-label fw-medium">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                                <input asp-for="Latitude" id="Latitude" class="form-control" type="number" step="any" min="0.000001" required readonly />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Longitude" class="form-label fw-medium">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                                <input asp-for="Longitude" id="Longitude" class="form-control" type="number" step="any" min="0.000001" required readonly />
                            </div>
                        </div>
                        <input type="hidden" asp-for="Radius" value="20" />
                        <input type="hidden" asp-for="Priority" value="1" />
                        <p class="small text-muted">Bán kính <strong>20 m</strong> và độ ưu tiên <strong>1</strong> do hệ thống cố định cho chủ quán.</p>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Rating" class="form-label fw-medium">Đánh giá <span class="text-danger">*</span></label>
                                <input asp-for="Rating" class="form-control" type="number" step="any" min="0.01" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="OpenTime" class="form-label fw-medium">Giờ mở cửa <span class="text-danger">*</span></label>
                                <input asp-for="OpenTime" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Ảnh đại diện</label>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ImageUrl" alt="Current Image" class="img-thumbnail" style="max-height: 100px" />
                                </div>
                            }
                            <input type="file" name="uploadImage" class="form-control mb-2" accept="image/*" />
                            <input type="url" name="imageUrl" class="form-control" value="@Model.ImageUrl" placeholder="Hoặc dán URL ảnh ở đây" />
                            <small class="text-muted">Bỏ trống nếu muốn giữ nguyên ảnh hiện tại. Có thể tải file lên hoặc nhập link ảnh.</small>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                <label class="form-check-label" asp-for="IsActive">Đang hoạt động trên App</label>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-medium">Mô tả chi tiết (Tiếng Việt) <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
                        </div>
                    }

                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===== TRANSLATION SECTION ===== -->
        <div class="card border-0 mt-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-language me-2 text-success"></i> Bản dịch đa ngôn ngữ</h5>
                <button type="button" class="btn btn-success btn-sm" onclick="autoTranslateAll()">
                    <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Tự động dịch tất cả
                </button>
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-3">Nhập bản dịch mô tả cho từng ngôn ngữ. Bấm <strong>"Tự động dịch tất cả"</strong> để hệ thống tự dịch từ mô tả tiếng Việt. Sau đó bấm <strong>"Lưu tất cả"</strong>.</p>

                <div id="translationStatus" class="alert alert-info small d-none mb-3">
                    <i class="fa-solid fa-spinner fa-spin me-1"></i> <span id="translationStatusText">Đang dịch...</span>
                </div>

                <form method="post" asp-action="SaveAllTranslations" asp-route-id="@Model.Id">
                    <div class="row g-3">
                        @for (var i = 0; i < languages.Length; i++)
                        {
                            var (code, label) = languages[i];
                            var existing = translations.FirstOrDefault(t => t.Language == code);
                            <div class="col-md-6">
                                <div class="card h-100 border">
                                    <div class="card-header py-2 bg-light d-flex justify-content-between align-items-center">
                                        <span class="fw-semibold small">@label</span>
                                        @if (existing != null && !string.IsNullOrWhiteSpace(existing.Description))
                                        {
                                            <span class="badge bg-success">✓ Đã dịch</span>
                                        }
                                    </div>
                                    <div class="card-body p-2">
                                        <input type="hidden" name="langs[]" value="@code" />
                                        <input type="text" name="names[]" id="name-@code" class="form-control form-control-sm mb-2"
                                               value="@(existing?.Name ?? "")" placeholder="Tên quán dịch..." />
                                        <textarea name="descs[]" id="desc-@code" class="form-control form-control-sm" rows="3"
                                                  placeholder="Mô tả dịch...">@(existing?.Description ?? "")</textarea>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-save me-1"></i> Lưu tất cả bản dịch
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <!-- ===== END TRANSLATION SECTION ===== -->

    </div>
</div>

<script>
const poiDescription = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Description ?? ""));
const poiName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name ?? ""));
const langCodes = [@Html.Raw(string.Join(",", languages.Select(l => $"\"{l.Item1}\"")))];

async function translateText(text, targetLang) {
    try {
        const url = `/api/Translate?text=${encodeURIComponent(text)}&target=${targetLang}&source=vi`;
        const response = await fetch(url);
        if (!response.ok) return text;
        const data = await response.json();
        if (data && data[0] && data[0].length > 0) {
            return data[0].map(x => x[0]).join('');
        }
        return text;
    } catch {
        return text;
    }
}

async function autoTranslateAll() {
    if (!poiDescription && !poiName) {
        alert('Vui lòng nhập mô tả tiếng Việt trước khi dịch.');
        return;
    }

    const statusDiv = document.getElementById('translationStatus');
    const statusText = document.getElementById('translationStatusText');
    statusDiv.classList.remove('d-none');

    for (let i = 0; i < langCodes.length; i++) {
        const code = langCodes[i];
        statusText.textContent = `Đang dịch ${code}... (${i + 1}/${langCodes.length})`;

        try {
            if (poiName) {
                const nameBox = document.getElementById(`name-${code}`);
                if (nameBox && !nameBox.value.trim()) {
                    nameBox.value = await translateText(poiName, code);
                }
            }
            if (poiDescription) {
                const descBox = document.getElementById(`desc-${code}`);
                if (descBox && !descBox.value.trim()) {
                    descBox.value = await translateText(poiDescription, code);
                }
            }
        } catch (err) {
            console.warn(`Dịch ${code} thất bại:`, err);
        }
    }

    statusText.textContent = '✅ Dịch xong! Kiểm tra và bấm "Lưu tất cả bản dịch" để lưu.';
    setTimeout(() => statusDiv.classList.add('d-none'), 5000);
}
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
    var existingLat = @(Model.Latitude != 0 ? Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
    var existingLng = @(Model.Longitude != 0 ? Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
    let map = null;
    let marker = null;
    let selectedLat = existingLat;
    let selectedLng = existingLng;

    // Initialize map on page load
    document.addEventListener('DOMContentLoaded', function() {
        // Use existing coordinates or default to Ho Chi Minh City center
        var initialLat = existingLat || 10.7769;
        var initialLng = existingLng || 106.7009;
        var zoomLevel = existingLat && existingLng ? 16 : 13;
        
        map = L.map('mapPicker').setView([initialLat, initialLng], zoomLevel);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
            maxZoom: 19
        }).addTo(map);

        // Add existing marker if coordinates exist
        if (existingLat && existingLng) {
            marker = L.marker([existingLat, existingLng]).addTo(map);
        }

        // Handle map click
        map.on('click', function(e) {
            selectedLat = e.latlng.lat.toFixed(6);
            selectedLng = e.latlng.lng.toFixed(6);
            
            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng).addTo(map);
            }
            
            // Update form values immediately
            document.getElementById('Latitude').value = selectedLat;
            document.getElementById('Longitude').value = selectedLng;
            document.getElementById('locationText').textContent = selectedLat + ', ' + selectedLng;
            document.getElementById('selectedLocationInfo').classList.remove('d-none');
        });
    });

    // Get current location
    document.getElementById('btnCurrentLocation').addEventListener('click', function() {
        if (navigator.geolocation) {
            this.disabled = true;
            this.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Đang lấy vị trí...';
            
            navigator.geolocation.getCurrentPosition(
                function(position) {
                    var lat = position.coords.latitude.toFixed(6);
                    var lng = position.coords.longitude.toFixed(6);
                    
                    document.getElementById('Latitude').value = lat;
                    document.getElementById('Longitude').value = lng;
                    document.getElementById('locationText').textContent = lat + ', ' + lng + ' (Vị trí hiện tại)';
                    document.getElementById('selectedLocationInfo').classList.remove('d-none');
                    
                    var btn = document.getElementById('btnCurrentLocation');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-crosshairs me-2"></i>Lấy vị trí hiện tại';

                    // Move map to current location and add marker
                    if (map) {
                        map.setView([lat, lng], 16);
                        if (marker) {
                            marker.setLatLng([lat, lng]);
                        } else {
                            marker = L.marker([lat, lng]).addTo(map);
                        }
                    }
                    selectedLat = lat;
                    selectedLng = lng;
                },
                function(error) {
                    alert('Không thể lấy vị trí hiện tại: ' + error.message);
                    var btn = document.getElementById('btnCurrentLocation');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-crosshairs me-2"></i>Lấy vị trí hiện tại';
                },
                { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
            );
        } else {
            alert('Trình duyệt không hỗ trợ Geolocation');
        }
    });
</script>
