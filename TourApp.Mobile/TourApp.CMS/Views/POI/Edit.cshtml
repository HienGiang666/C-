@model TourApp.CMS.Models.POI

@{
    ViewData["Title"] = "Cập nhật Điểm Tham Quan";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen me-2 text-primary"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium">Tên địa điểm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-medium">Địa chỉ góc</label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Latitude" class="form-label fw-medium">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" class="form-control" type="number" step="any" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Longitude" class="form-label fw-medium">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" class="form-control" type="number" step="any" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Radius" class="form-label fw-medium">Bán kính quét (m)</label>
                            <input asp-for="Radius" class="form-control" type="number" required />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Priority" class="form-label fw-medium">Độ ưu tiên</label>
                            <input asp-for="Priority" class="form-control" type="number" required />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Rating" class="form-label fw-medium">Đánh giá (1-5)</label>
                            <input asp-for="Rating" class="form-control" type="number" step="0.1" required />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="OpenTime" class="form-label fw-medium">Giờ mở cửa</label>
                            <input asp-for="OpenTime" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Ảnh đại diện</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.ImageUrl" alt="Current Image" class="img-thumbnail" style="max-height: 100px" />
                            </div>
                        }
                        <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                        <small class="text-muted">Bỏ trống nếu muốn giữ nguyên ảnh hiện tại.</small>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive">
                            <label class="form-check-label" asp-for="IsActive">Đang hoạt động trên App</label>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-medium">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>