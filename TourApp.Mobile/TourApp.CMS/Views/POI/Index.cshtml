@model IEnumerable<TourApp.CMS.Models.POI>

@{
    ViewData["Title"] = "Quản lý Điểm Tham Quan (POI)";
    int stt = 0;
}

<!-- QR Modal -->
<div class="modal fade" id="qrModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-qrcode me-2 text-primary"></i> Mã QR - <span id="qrPoiName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div id="qrcode" class="d-inline-block p-3 bg-white border rounded-3 shadow-sm mb-3"></div>
                <p class="text-muted small mb-1">Dán poster tại địa điểm. Khách quét QR → nghe thuyết minh ngay.</p>
                <p class="text-primary small fw-semibold" id="qrUrl"></p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary" onclick="downloadQR()">
                    <i class="fa-solid fa-download me-1"></i> Tải ảnh QR
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-map-location-dot me-2 text-primary"></i> Danh sách Địa điểm</h5>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center">
            <i class="fa-solid fa-plus me-2"></i> Thêm mới
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:48px" class="text-center text-muted">STT</th>
                        <th>Ảnh</th>
                        <th>Tên địa điểm</th>
                        <th>Mô tả</th>
                        <th>Tọa độ &amp; Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            stt++;
                            <tr>
                                <td class="text-center text-muted align-middle">
                                    <span class="badge bg-secondary">#@stt</span>
                                </td>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/50" : item.ImageUrl)"
                                         class="img-thumbnail rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                                </td>
                                <td class="fw-bold text-primary">@item.Name</td>
                                <td class="text-truncate" style="max-width: 200px;" title="@item.Description">
                                    <small>@item.Description</small>
                                </td>
                                <td>
                                    <div class="mb-1"><small class="text-muted"><i class="fa-solid fa-location-crosshairs me-1 text-danger"></i> @item.Latitude</small></div>
                                    <div class="mb-1"><small class="text-muted"><i class="fa-solid fa-location-crosshairs me-1 text-primary"></i> @item.Longitude</small></div>
                                    @if(item.IsActive) { <span class="badge bg-success" style="font-size: 0.65em;">Hoạt động</span> } else { <span class="badge bg-warning" style="font-size: 0.65em;">Đang ẩn</span> }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Audio" asp-action="Index" asp-route-poiId="@item.Id" class="btn btn-sm btn-outline-info me-1" title="Quản lý Audio">
                                        <i class="fa-solid fa-headphones"></i> Audios
                                    </a>
                                    <!-- QR Button -->
                                    <button class="btn btn-sm btn-outline-success me-1" title="Tạo QR Code"
                                            onclick="showQR(@item.Id, '@Html.Raw(item.Name.Replace("'", "\\'"))')">
                                        <i class="fa-solid fa-qrcode"></i>
                                    </button>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa địa điểm này?');">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="fa-solid fa-box-open fs-2 mb-2"></i><br />
                                Không có dữ liệu
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<!-- QRCode.js library (no build step needed) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
let currentQrPoiId = null;

function showQR(poiId, poiName) {
    currentQrPoiId = poiId;
    document.getElementById('qrPoiName').textContent = poiName;

    // URL mà app mobile sẽ decode — dạng deep link
    const qrContent = `tourapp://poi/${poiId}`;
    document.getElementById('qrUrl').textContent = qrContent;

    // Clear old QR
    const container = document.getElementById('qrcode');
    container.innerHTML = '';

    // Generate QR
    new QRCode(container, {
        text: qrContent,
        width: 220,
        height: 220,
        colorDark: '#1e293b',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H
    });

    // Show modal
    const modal = new bootstrap.Modal(document.getElementById('qrModal'));
    modal.show();
}

function downloadQR() {
    const canvas = document.querySelector('#qrcode canvas');
    if (!canvas) { alert('QR chưa sẵn sàng!'); return; }
    const link = document.createElement('a');
    link.download = `QR_POI_${currentQrPoiId}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
}
</script>
}