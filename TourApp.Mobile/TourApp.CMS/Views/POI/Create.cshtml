@model TourApp.CMS.Models.POI

@{
    ViewData["Title"] = "Thêm địa điểm";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-plus me-2 text-primary"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium">Tên địa điểm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Bưu điện trung tâm Thành phố" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-medium">Địa chỉ <span class="text-danger">*</span></label>
                        <input asp-for="Address" class="form-control" placeholder="VD: 02 Công xã Paris, Bến Nghé, Quận 1" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Chọn vị trí trên bản đồ <span class="text-danger">*</span></label>
                        <div class="input-group mb-2">
                            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                            <input type="text" id="mapSearch" class="form-control" placeholder="Tìm địa điểm... (VD: Bưu điện trung tâm)" />
                            <button type="button" class="btn btn-outline-primary" onclick="searchPlace()">Tìm</button>
                        </div>
                        <div id="goongMap" style="height:350px;border-radius:8px;border:1px solid #dee2e6;"></div>
                        <small class="text-muted"><i class="fa-solid fa-hand-pointer me-1"></i>Click trên bản đồ để chọn vị trí</small>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Latitude" class="form-label fw-medium">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" id="Latitude" class="form-control bg-light" type="number" step="any" placeholder="10.7769" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Longitude" class="form-label fw-medium">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" id="Longitude" class="form-control bg-light" type="number" step="any" placeholder="106.7009" required />
                        </div>
                    </div>
                    <input type="hidden" asp-for="Radius" value="20" />
                    <input type="hidden" asp-for="Priority" value="1" />
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Rating" class="form-label fw-medium">Đánh giá ( &gt; 0, VD 1–5) <span class="text-danger">*</span></label>
                            <input asp-for="Rating" class="form-control" type="number" step="any" min="0.01" value="4.5" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OpenTime" class="form-label fw-medium">Giờ mở cửa <span class="text-danger">*</span></label>
                            <input asp-for="OpenTime" class="form-control" placeholder="08:00 - 17:00" required />
                        </div>
                    </div>
                    <p class="small text-muted mb-3">Bán kính quét mặc định <strong>20 m</strong>, độ ưu tiên <strong>1</strong> (hệ thống áp dụng tự động).</p>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Ảnh đại diện <span class="text-danger">*</span></label>
                        <input type="file" name="uploadImage" class="form-control" accept="image/*" required />
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                            <label class="form-check-label" asp-for="IsActive">Đang hoạt động trên App (sau khi Admin phê duyệt)</label>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-medium">Mô tả chi tiết <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập giới thiệu về địa điểm..." required></textarea>
                    </div>
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var GOONG_MAPTILE_KEY = '2Dnp8yaRq6ivkjX5c7D7RFcx5tDSi5g512jA5dG9';
            var GOONG_REST_KEY = 'FEx6pcCh7bba5bfwJC4M7truNtLS7rEAwkZQZZ8g';
            goongjs.accessToken = GOONG_MAPTILE_KEY;

            var initLat = 10.762, initLng = 106.702;
            var map = new goongjs.Map({
                container: 'goongMap',
                style: 'https://tiles.goong.io/assets/goong_map_web.json?api_key=' + GOONG_MAPTILE_KEY,
                center: [initLng, initLat],
                zoom: 15
            });

            var marker = null;

            function setMarker(lat, lng, address) {
                if (marker) marker.remove();
                marker = new goongjs.Marker({ color: '#e74c3c' })
                    .setLngLat([lng, lat])
                    .addTo(map);
                document.getElementById('Latitude').value = lat.toFixed(6);
                document.getElementById('Longitude').value = lng.toFixed(6);
                if (address) {
                    document.getElementById('Address').value = address;
                }
            }

            // Reverse geocode khi click bản đồ
            function reverseGeocode(lat, lng) {
                var url = 'https://rsapi.goong.io/Geocode?latlng=' + lat + ',' + lng + '&api_key=' + GOONG_REST_KEY;
                fetch(url).then(r => r.json()).then(data => {
                    if (data.results && data.results.length > 0) {
                        document.getElementById('Address').value = data.results[0].formatted_address;
                    }
                }).catch(() => {});
            }

            map.on('click', function (e) {
                setMarker(e.lngLat.lat, e.lngLat.lng);
                reverseGeocode(e.lngLat.lat, e.lngLat.lng);
            });

            // Tìm kiếm bằng Goong Place AutoComplete + Detail
            window.searchPlace = function () {
                var query = document.getElementById('mapSearch').value.trim();
                if (!query) return;
                var center = map.getCenter();
                var url = 'https://rsapi.goong.io/Place/AutoComplete?api_key=' + GOONG_REST_KEY
                    + '&input=' + encodeURIComponent(query)
                    + '&location=' + center.lat + ',' + center.lng;
                fetch(url).then(r => r.json()).then(data => {
                    if (data.predictions && data.predictions.length > 0) {
                        var placeId = data.predictions[0].place_id;
                        var desc = data.predictions[0].description;
                        var detailUrl = 'https://rsapi.goong.io/Place/Detail?api_key=' + GOONG_REST_KEY + '&place_id=' + placeId;
                        fetch(detailUrl).then(r => r.json()).then(detail => {
                            if (detail.result && detail.result.geometry) {
                                var loc = detail.result.geometry.location;
                                map.flyTo({ center: [loc.lng, loc.lat], zoom: 17 });
                                setMarker(loc.lat, loc.lng, detail.result.formatted_address || desc);
                            }
                        });
                    } else {
                        alert('Không tìm thấy địa điểm. Thử nhập cụ thể hơn.');
                    }
                }).catch(() => alert('Lỗi tìm kiếm. Vui lòng thử lại.'));
            };

            document.getElementById('mapSearch').addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); searchPlace(); }
            });
        });
    </script>
}
