@model TourApp.CMS.Models.POI

@{
    ViewData["Title"] = "Thêm Địa điểm";
}

<div class="page-breadcrumb">
    <i class="fas fa-map-marker-alt"></i> Quản lý / Địa điểm / <span class="text-primary">Thêm mới</span>
</div>

<div class="page-title">➕ Thêm Địa điểm mới</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Thông tin Địa điểm</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Tên Địa điểm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Chợ Bến Thành" required />
                        <small class="form-text text-muted">Nhập tên đầy đủ của địa điểm du lịch</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="6" placeholder="Nhập bài giới thiệu chi tiết về địa điểm..." required></textarea>
                        <small class="form-text text-muted">Mô tả chi tiết sẽ được hiển thị cho khách</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold">Hình ảnh</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <small class="form-text text-muted">Định dạng: JPG, PNG, GIF, WebP (Tối đa 5MB)</small>
                        <img id="imagePreview" class="mt-3" style="max-width: 200px; display: none;" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Latitude" class="form-label fw-bold">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" type="number" step="0.000001" class="form-control" placeholder="Ví dụ: 10.7725" required />
                            <small class="form-text text-muted">Tọa độ vĩ độ (thành phố HCM: 10.7725)</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Longitude" class="form-label fw-bold">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" type="number" step="0.000001" class="form-control" placeholder="Ví dụ: 106.6980" required />
                            <small class="form-text text-muted">Tọa độ kinh độ (thành phố HCM: 106.6980)</small>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i> Lưu Địa điểm
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">💡 Hướng dẫn</h5>
            </div>
            <div class="card-body">
                <p><strong>Cách nhập tọa độ:</strong></p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-map-pin text-primary"></i> Vĩ độ: Từ -90 đến +90</li>
                    <li><i class="fas fa-map-pin text-primary"></i> Kinh độ: Từ -180 đến +180</li>
                </ul>
                <hr>
                <p><strong>Ví dụ Việt Nam:</strong></p>
                <ul class="list-unstyled small">
                    <li>🏛️ Hà Nội: 21.0285, 105.8542</li>
                    <li>🏙️ HCM: 10.7725, 106.6980</li>
                    <li>🏖️ Nha Trang: 12.2384, 109.1967</li>
                </ul>
                <hr>
                <p><strong>Yêu cầu ảnh:</strong></p>
                <ul class="list-unstyled small">
                    <li><i class="fas fa-check text-success"></i> JPG, PNG, GIF, WebP</li>
                    <li><i class="fas fa-check text-success"></i> Tối đa 5MB</li>
                    <li><i class="fas fa-check text-success"></i> Tỷ lệ 16:9 hoặc 4:3</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const fileInput = document.querySelector('input[type="file"]');
        const imagePreview = document.getElementById('imagePreview');

        fileInput?.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    imagePreview.src = e.target.result;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}