@model TourApp.CMS.Models.POI

@{
    ViewData["Title"] = "Thêm Điểm Tham Quan";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-plus me-2 text-primary"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium">Tên địa điểm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Bưu điện trung tâm Thành phố" required />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Latitude" class="form-label fw-medium">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" class="form-control" type="number" step="any" placeholder="10.7769" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Longitude" class="form-label fw-medium">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" class="form-control" type="number" step="any" placeholder="106.7009" required />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-medium">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập giới thiệu về địa điểm..."></textarea>
                    </div>
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>