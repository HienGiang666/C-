@model IEnumerable<TourApp.CMS.Models.Booking>

@{
    ViewData["Title"] = "Quản lý Booking";
}

<div class="page-breadcrumb">
    <i class="fas fa-calendar-check"></i> Quản lý / Booking
</div>

<div class="page-title">📅 Quản lý Booking</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header bg-white">
        <h5 class="mb-0">Danh sách Booking</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Tour ID</th>
                        <th>User ID</th>
                        <th>Số Khách</th>
                        <th>Ngày Booking</th>
                        <th>Ngày Tour</th>
                        <th>Tổng Giá</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@booking.Id</span></td>
                                <td>@booking.TourId</td>
                                <td>@booking.UserId</td>
                                <td>@booking.NumberOfParticipants</td>
                                <td>@booking.BookingDate.ToString("dd/MM/yyyy")</td>
                                <td>@booking.TourDate.ToString("dd/MM/yyyy")</td>
                                <td><strong class="text-success">@booking.TotalPrice.ToString("C")</strong></td>
                                <td>
                                    @if (booking.Status == "Confirmed")
                                    {
                                        <span class="badge bg-success">Xác nhận</span>
                                    }
                                    else if (booking.Status == "Pending")
                                    {
                                        <span class="badge bg-warning">Chờ xác nhận</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hủy</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-sm btn-info" title="Chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@booking.Id" class="btn btn-sm btn-danger" 
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa?');" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2"></i>
                                <p>Không có dữ liệu nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
