@model IEnumerable<TourApp.CMS.Models.Booking>
@using TourApp.CMS.Helpers

@{
    ViewData["Title"] = "Quản lý Đặt vé (Booking)";
    var userMap = ViewBag.UserDisplayByUserId as Dictionary<int, int> ?? new Dictionary<int, int>();
    var tourCat = ViewBag.TourCatalogByTourId as Dictionary<int, int> ?? new Dictionary<int, int>();
    int UserDisp(int uid) => userMap.TryGetValue(uid, out var n) ? n : uid;
    int TourDisp(int tourId) => tourCat.TryGetValue(tourId, out var n) ? n : tourId;
}

<div class="card border-0 mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-ticket me-2 text-primary"></i> Danh sách Đặt vé</h5>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center">
            <i class="fa-solid fa-plus me-2"></i> Tạo Booking
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:48px">#</th>
                        <th>Mã đặt vé</th>
                        <th>Mã thành viên</th>
                        <th>Mã Tour</th>
                        <th>Ngày khởi hành</th>
                        <th>Số lượng khách</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        var stt = 0;
                        foreach (var booking in Model)
                        {
                            stt++;
                            <tr>
                                <td class="text-center text-muted">@stt</td>
                                <td><span class="badge bg-secondary">@DisplayIdHelper.BookingRef(DisplayIdHelper.BookingCatalogNumber(booking))</span><br/><small class="text-muted">@booking.BookingDate.ToString("dd/MM/yyyy")</small></td>
                                <td>
                                    <a asp-controller="User" asp-action="Details" asp-route-id="@booking.UserId" class="text-decoration-none">
                                        <span class="badge bg-secondary">@DisplayIdHelper.UserBadgeFromNumber(UserDisp(booking.UserId))</span>
                                    </a>
                                </td>
                                <td>
                                    <a asp-controller="Tour" asp-action="Edit" asp-route-id="@booking.TourId" class="fw-medium text-decoration-none text-info">@DisplayIdHelper.TourRef(TourDisp(booking.TourId))</a>
                                </td>
                                <td><i class="fa-regular fa-calendar text-primary me-1"></i> @booking.TourDate.ToString("dd/MM/yyyy")</td>
                                <td><i class="fa-solid fa-users text-secondary me-1"></i> @booking.NumberOfParticipants</td>
                                <td class="text-danger fw-bold">@booking.TotalPrice.ToString("N0") VNĐ</td>
                                <td>
                                    @if(booking.Status == "Confirmed") {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success"><i class="fa-solid fa-check me-1"></i> Đã xác nhận</span>
                                    } else if(booking.Status == "Cancelled") {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="fa-solid fa-xmark me-1"></i> Đã hủy</span>
                                    } else {
                                        <span class="badge bg-warning border border-warning text-dark"><i class="fa-solid fa-clock me-1"></i> Chờ duyệt</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-sm btn-outline-secondary" title="Chi tiết & Duyệt">
                                        <i class="fa-solid fa-gear"></i> Duyệt
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@booking.Id" class="btn btn-sm btn-outline-danger ms-1" title="Xóa" onclick="return confirm('Xóa vé này khỏi hệ thống?');">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-ticket fs-1 mb-3 bg-light p-4 rounded-circle"></i>
                                <h5>Chưa có dữ liệu đặt vé</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
