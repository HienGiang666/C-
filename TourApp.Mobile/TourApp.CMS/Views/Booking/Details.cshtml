@model TourApp.CMS.Models.Booking
@using TourApp.CMS.Helpers

@{
    ViewData["Title"] = "Chi tiết Vé & Duyệt đơn";
    var userBadge = ViewBag.UserBadge as string ?? $"#U{Model.UserId}";
    var tourCode = ViewBag.TourCode as string ?? $"TR-{Model.TourId}";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i> Đơn Đặt Vé @Model.DisplayCode</h5>
                @if(Model.Status == "Confirmed") {
                    <span class="badge bg-success bg-opacity-10 text-success px-3 border border-success">Đã Xác Nhận</span>
                } else if(Model.Status == "Paid") {
                    <span class="badge bg-info bg-opacity-10 text-info px-3 border border-info">Đã Thanh Toán</span>
                } else if(Model.Status == "Cancelled") {
                    <span class="badge bg-danger bg-opacity-10 text-danger px-3 border border-danger">Đã Hủy</span>
                } else {
                    <span class="badge bg-warning text-dark px-3 border border-warning">Chờ Duyệt</span>
                }
            </div>
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-md-6 border-end">
                        <h6 class="text-uppercase text-muted fw-bold mb-3">Thông tin Khách</h6>
                        <p class="mb-1"><i class="fa-solid fa-id-card text-muted me-2 width-20"></i> <span class="fw-medium">Mã thành viên:</span> <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="text-decoration-none">@userBadge</a></p>
                        <p class="mb-1"><i class="fa-regular fa-clock text-muted me-2 width-20"></i> <span class="fw-medium">Giờ đặt vé:</span> @Model.BookingDate.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="col-md-6 ps-md-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3">Thông tin Tour</h6>
                        <p class="mb-1"><i class="fa-solid fa-suitcase-rolling text-muted me-2 width-20"></i> <span class="fw-medium">Mã Tour:</span> <a asp-controller="Tour" asp-action="Edit" asp-route-id="@Model.TourId" class="text-decoration-none">@tourCode</a></p>
                        <p class="mb-1"><i class="fa-solid fa-calendar-day text-muted me-2 width-20"></i> <span class="fw-medium">Ngày đi:</span> @Model.TourDate.ToString("dd/MM/yyyy")</p>
                        <p class="mb-1"><i class="fa-solid fa-users text-muted me-2 width-20"></i> <span class="fw-medium">SL Khách:</span> @Model.NumberOfParticipants khách</p>
                    </div>
                </div>

                <div class="bg-light rounded p-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                        <span class="fw-medium">Ghi chú từ khách hàng:</span>
                    </div>
                    <p class="text-muted fst-italic mb-0">@(string.IsNullOrEmpty(Model.Notes) ? "Không có ghi chú" : Model.Notes)</p>
                </div>

                <div class="d-flex justify-content-between align-items-center p-3 bg-dark text-white rounded shadow-sm mb-4">
                    <span class="fs-5 fw-medium">TỔNG THANH TOÁN:</span>
                    <span class="fs-4 fw-bold text-warning">@Model.TotalPrice.ToString("N0") VNĐ</span>
                </div>

                <h6 class="fw-bold mb-3 border-bottom pb-2">Xử lý đơn</h6>
                <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <select name="status" class="form-select w-auto">
                        @if(Model.Status == "Pending") { <option value="Pending" selected>Chờ duyệt</option> } else { <option value="Pending">Chờ duyệt</option> }
                        @if(Model.Status == "Confirmed") { <option value="Confirmed" selected>Xác nhận vé</option> } else { <option value="Confirmed">Xác nhận vé</option> }
                        @if(Model.Status == "Cancelled") { <option value="Cancelled" selected>Hủy vé</option> } else { <option value="Cancelled">Hủy vé</option> }
                    </select>

                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk me-1"></i> Lưu trạng thái</button>
                    <a asp-action="Index" class="btn btn-light border ms-auto">Quay lại</a>
                </form>

            </div>
        </div>
    </div>
</div>
