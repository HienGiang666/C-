@{
    ViewData["Title"] = "Quản lý hoạt động";
}

<!-- Stats Cards Row -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-mobile-screen-button text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Tổng thiết bị</div>
                    <div class="fw-bold fs-4" id="totalDevices">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-qrcode text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Lượt quét QR</div>
                    <div class="fw-bold fs-4" id="qrScanCount">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-signal text-info fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Đang online</div>
                    <div class="fw-bold fs-4" id="onlineNow">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-clock-rotate-left text-warning fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Hoạt động 24h</div>
                    <div class="fw-bold fs-4" id="active24h">0</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User Activity Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-users text-primary me-2"></i>Lịch sử hoạt động người dùng (24h)</h5>
        <div class="d-flex gap-2">
            <span id="lastUpdate" class="text-muted small align-self-center"></span>
            <button class="btn btn-sm btn-outline-primary" onclick="loadData()">
                <i class="fa-solid fa-rotate me-1"></i>Làm mới
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px">#</th>
                        <th>Thiết bị</th>
                        <th>Trạng thái</th>
                        <th>Ngôn ngữ</th>
                        <th>Bắt đầu online</th>
                        <th>Lần cuối hoạt động</th>
                        <th>Lượt nghe</th>
                        <th>QR</th>
                        <th>Điểm vị trí</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    <tr>
                        <td colspan="9" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <div class="text-muted mt-2">Đang tải dữ liệu...</div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white d-flex align-items-center justify-content-between">
        <small id="connectionStatus" class="text-muted"><i class="fa-solid fa-plug me-1"></i>Đang kết nối real-time...</small>
        <small class="text-muted">Tự động cập nhật mỗi 3 giây</small>
    </div>
</div>

@section Styles {
    <style>
        .status-dot {
            width: 10px; height: 10px; border-radius: 50%; display: inline-block;
        }
        .status-online { background: #28a745; box-shadow: 0 0 6px rgba(40,167,69,0.6); animation: pulse 1.5s infinite; }
        .status-offline { background: #6c757d; }
        @@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
        .lang-badge { font-size: 0.72rem; padding: 2px 7px; border-radius: 10px; }
        .user-row { transition: background-color 0.3s; }
        .user-row.highlight { background-color: #fff3cd !important; }
    </style>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var apiBaseUrl = '@(ViewBag.ApiBaseUrl)';
        var pollingTimer = null;
        var prevDeviceIds = new Set();

        function updateConnectionStatus(msg, cls) {
            var el = document.getElementById('connectionStatus');
            if (el) el.innerHTML = '<span class="' + cls + '"><i class="fa-solid fa-circle me-1" style="font-size:8px"></i>' + msg + '</span>';
        }

        function langBadge(lang) {
            var colors = { vi: 'bg-danger', en: 'bg-primary', ja: 'bg-warning text-dark', ko: 'bg-info', zh: 'bg-success', fr: 'bg-secondary' };
            var labels = { vi: '🇻🇳 VI', en: '🇬🇧 EN', ja: '🇯🇵 JA', ko: '🇰🇷 KO', zh: '🇨🇳 ZH', fr: '🇫🇷 FR' };
            return '<span class="lang-badge ' + (colors[lang] || 'bg-secondary') + ' text-white">' + (labels[lang] || lang) + '</span>';
        }

        function timeAgo(dt) {
            var diff = (Date.now() - new Date(dt).getTime()) / 1000;
            if (diff < 60) return Math.floor(diff) + 's trước';
            if (diff < 3600) return Math.floor(diff / 60) + ' phút trước';
            if (diff < 86400) return Math.floor(diff / 3600) + ' giờ trước';
            return new Date(dt).toLocaleString('vi-VN');
        }

        function formatTime(dt) {
            return new Date(dt).toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', second: '2-digit', day: '2-digit', month: '2-digit' });
        }

        function renderTable(data) {
            var users = data.users || [];
            var narr = data.narrationByDevice || {};
            var tbody = document.getElementById('userTableBody');
            var newDeviceIds = new Set(users.map(u => u.deviceId));

            if (users.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center py-5 text-muted"><i class="fa-solid fa-users-slash fs-1 mb-2 d-block"></i>Chưa có người dùng hoạt động trong 24h qua</td></tr>';
                return;
            }

            tbody.innerHTML = users.map(function (u, i) {
                var n = narr[u.deviceId] || { playCount: 0, languages: [], qrCount: 0 };
                var isNew = !prevDeviceIds.has(u.deviceId);
                var statusCls = u.isOnline ? 'status-online' : 'status-offline';
                var statusText = u.isOnline ? '<span class="text-success fw-semibold">Online</span>' : '<span class="text-muted">Offline</span>';
                var langs = n.languages.length > 0 ? n.languages.map(langBadge).join(' ') : '<span class="text-muted small">-</span>';
                var deviceShort = u.deviceId.length > 16 ? u.deviceId.substring(0, 16) + '...' : u.deviceId;
                var typeBadge = u.isAnonymous ? '<span class="badge bg-secondary ms-1">Khách</span>' : '<span class="badge bg-success ms-1">User</span>';

                return '<tr class="user-row' + (isNew ? ' highlight' : '') + '">' +
                    '<td class="text-muted small">' + (i + 1) + '</td>' +
                    '<td><div class="d-flex align-items-center"><span class="status-dot ' + statusCls + ' me-2"></span><span class="fw-medium small" title="' + u.deviceId + '">' + deviceShort + '</span>' + typeBadge + '</div></td>' +
                    '<td>' + statusText + '</td>' +
                    '<td>' + langs + '</td>' +
                    '<td class="small">' + formatTime(u.firstSeen) + '</td>' +
                    '<td class="small">' + timeAgo(u.lastSeen) + '</td>' +
                    '<td class="text-center"><span class="badge bg-primary bg-opacity-75">' + n.playCount + '</span></td>' +
                    '<td class="text-center"><span class="badge bg-warning text-dark">' + n.qrCount + '</span></td>' +
                    '<td class="text-center text-muted small">' + u.locationCount + '</td>' +
                    '</tr>';
            }).join('');

            prevDeviceIds = newDeviceIds;

            // Remove highlight after 2s
            setTimeout(function () {
                document.querySelectorAll('.user-row.highlight').forEach(function (el) { el.classList.remove('highlight'); });
            }, 2000);
        }

        function loadData() {
            fetch(apiBaseUrl + '/api/userlocation/management-stats')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('totalDevices').textContent = data.totalDevices || 0;
                    document.getElementById('qrScanCount').textContent = data.qrScanCount || 0;
                    document.getElementById('onlineNow').textContent = data.onlineNow || 0;
                    document.getElementById('active24h').textContent = data.active24h || 0;
                    document.getElementById('lastUpdate').textContent = 'Cập nhật: ' + new Date().toLocaleTimeString('vi-VN');
                    renderTable(data);
                })
                .catch(err => {
                    console.error('[Management] Error:', err);
                    document.getElementById('userTableBody').innerHTML =
                        '<tr><td colspan="9" class="text-center py-5 text-danger"><i class="fa-solid fa-triangle-exclamation fs-1 mb-2 d-block"></i>Không thể kết nối API</td></tr>';
                });
        }
        window.loadData = loadData;

        function startPolling() {
            if (pollingTimer) clearInterval(pollingTimer);
            pollingTimer = setInterval(loadData, 3000);
        }

        // SignalR for instant updates
        var connection = new signalR.HubConnectionBuilder()
            .withUrl(apiBaseUrl + '/hubs/userlocation')
            .withAutomaticReconnect([0, 1000, 2000, 5000])
            .build();

        connection.on('UserOnline', function () { loadData(); });
        connection.on('UserOffline', function () { loadData(); });
        connection.on('LocationUpdated', function () { loadData(); });

        connection.start().then(function () {
            updateConnectionStatus('Real-time kết nối thành công', 'text-success');
            loadData();
            startPolling();
        }).catch(function () {
            updateConnectionStatus('Dùng polling (3s)', 'text-warning');
            loadData();
            startPolling();
        });

        connection.onreconnecting(function () { updateConnectionStatus('Đang kết nối lại...', 'text-warning'); });
        connection.onreconnected(function () { updateConnectionStatus('Real-time kết nối thành công', 'text-success'); });
    });
    </script>
}
