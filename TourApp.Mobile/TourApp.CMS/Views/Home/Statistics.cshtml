@{
    ViewData["Title"] = "Thống kê";
    var cmsRole = Context.Session.GetString("Role") ?? "";
    var isAdmin = cmsRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
}

@if (isAdmin)
{
<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-signal text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Đang online</div>
                    <div class="fw-bold fs-4" id="onlineCount">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-clock-rotate-left text-info fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Hoạt động 24h</div>
                    <div class="fw-bold fs-4" id="active24hCount">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                    <i class="fa-solid fa-map-pin text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Điểm vị trí (24h)</div>
                    <div class="fw-bold fs-4" id="locationPoints">0</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Map Full Width -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-map-location-dot text-primary me-2"></i>Bản đồ người dùng</h5>
        <div class="d-flex align-items-center gap-2">
            <small id="connectionStatus" class="text-muted"><i class="fa-solid fa-plug me-1"></i>Đang kết nối...</small>
            <button id="refreshMap" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-rotate"></i></button>
        </div>
    </div>
    <div class="card-body p-0 position-relative">
        <div id="goongMap" style="height: 550px;"></div>

        <!-- Layer Toggles -->
        <div class="position-absolute" style="top: 10px; right: 10px; z-index: 10;">
            <div class="d-flex flex-column gap-2 p-2 rounded-3" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(8px); box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                <small class="text-muted text-center fw-semibold">Hiển thị</small>
                <button class="btn btn-success btn-sm active" id="btnLive" onclick="toggleLayer('live')">
                    <i class="fa-solid fa-circle-check me-1"></i>Live Monitoring
                </button>
                <button class="btn btn-danger btn-sm active" id="btnHeatmap" onclick="toggleLayer('heatmap')">
                    <i class="fa-solid fa-circle-check me-1"></i>Heatmap
                </button>
                <button class="btn btn-primary btn-sm active" id="btnPaths" onclick="toggleLayer('paths')">
                    <i class="fa-solid fa-circle-check me-1"></i>Tuyến di chuyển phổ biến
                </button>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white">
        <div class="d-flex flex-wrap gap-3 justify-content-center small">
            <span><i class="fa-solid fa-circle text-success me-1"></i>Đang online</span>
            <span><i class="fa-solid fa-fire text-danger me-1"></i>Heatmap (mật độ)</span>
            <span><i class="fa-solid fa-route text-primary me-1"></i>Tuyến di chuyển phổ biến</span>
        </div>
    </div>
</div>
}
else
{
    <div class="alert alert-warning">
        <i class="fa-solid fa-lock me-2"></i> Bạn không có quyền xem trang này.
    </div>
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var apiBaseUrl = '@(ViewBag.ApiBaseUrl ?? "https://localhost:7244")';
        var GOONG_MAPTILE_KEY = '2Dnp8yaRq6ivkjX5c7D7RFcx5tDSi5g512jA5dG9';
        goongjs.accessToken = GOONG_MAPTILE_KEY;

        var map = new goongjs.Map({
            container: 'goongMap',
            style: 'https://tiles.goong.io/assets/goong_map_web.json?api_key=' + GOONG_MAPTILE_KEY,
            center: [106.702, 10.762],
            zoom: 14
        });

        var liveMarkers = {};
        var heatmapCanvas = null;
        var pathLines = [];
        var pathMarkers = [];
        var layerStates = { live: true, heatmap: true, paths: true };
        var heatmapData = [];

        function updateConnectionStatus(msg, cls) {
            var el = document.getElementById('connectionStatus');
            if (el) el.innerHTML = '<span class="' + cls + '"><i class="fa-solid fa-circle me-1" style="font-size:8px"></i>' + msg + '</span>';
        }

        // ===== LIVE MARKERS =====
        function clearLiveMarkers() {
            Object.values(liveMarkers).forEach(m => m.remove());
            liveMarkers = {};
        }

        function showLiveMarkers() {
            Object.values(liveMarkers).forEach(m => m.addTo(map));
        }

        function syncLive(data) {
            if (!data.onlineLocations) return;
            var activeIds = new Set();
            data.onlineLocations.forEach(function (loc) {
                var did = loc.deviceId || loc.DeviceId;
                var lat = loc.latitude || loc.Latitude;
                var lng = loc.longitude || loc.Longitude;
                activeIds.add(did);
                if (liveMarkers[did]) liveMarkers[did].remove();

                var el = document.createElement('div');
                el.style.cssText = 'width:16px;height:16px;background:#28a745;border-radius:50%;border:3px solid white;box-shadow:0 0 10px rgba(40,167,69,0.5);';

                var marker = new goongjs.Marker({ element: el })
                    .setLngLat([lng, lat])
                    .setPopup(new goongjs.Popup({ offset: 12 }).setHTML('<b>Device:</b> ' + did + '<br><b>Time:</b> ' + new Date(loc.timestamp || loc.Timestamp).toLocaleTimeString()));
                liveMarkers[did] = marker;
                if (layerStates.live) marker.addTo(map);
            });
            Object.keys(liveMarkers).forEach(function (did) {
                if (!activeIds.has(did)) { liveMarkers[did].remove(); delete liveMarkers[did]; }
            });
            document.getElementById('onlineCount').textContent = Object.keys(liveMarkers).length;
        }

        // ===== HEATMAP (Canvas overlay) =====
        function drawHeatmap() {
            removeHeatmapCanvas();
            if (!layerStates.heatmap || heatmapData.length === 0) return;

            var canvas = document.createElement('canvas');
            canvas.id = 'heatmapOverlay';
            canvas.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:5;opacity:0.6;';
            document.getElementById('goongMap').appendChild(canvas);
            heatmapCanvas = canvas;

            var rect = canvas.parentElement.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = rect.height;
            var ctx = canvas.getContext('2d');

            heatmapData.forEach(function (pt) {
                var projected = map.project([pt[0], pt[1]]); // [lng, lat]
                var x = projected.x;
                var y = projected.y;
                var gradient = ctx.createRadialGradient(x, y, 0, x, y, 30);
                gradient.addColorStop(0, 'rgba(255,0,0,0.4)');
                gradient.addColorStop(0.5, 'rgba(255,165,0,0.2)');
                gradient.addColorStop(1, 'rgba(255,255,0,0)');
                ctx.beginPath();
                ctx.fillStyle = gradient;
                ctx.arc(x, y, 30, 0, Math.PI * 2);
                ctx.fill();
            });
        }

        function removeHeatmapCanvas() {
            var old = document.getElementById('heatmapOverlay');
            if (old) old.remove();
            heatmapCanvas = null;
        }

        map.on('moveend', function () { if (layerStates.heatmap) drawHeatmap(); });
        map.on('zoomend', function () { if (layerStates.heatmap) drawHeatmap(); });

        function loadHeatmap() {
            fetch(apiBaseUrl + '/api/userlocation/heatmap')
                .then(r => r.json())
                .then(data => {
                    heatmapData = (data.points || []).map(p => [p[1], p[0]]); // [lng, lat]
                    if (layerStates.heatmap) drawHeatmap();
                }).catch(err => console.error('[Heatmap]', err));
        }

        // ===== PATHS (Route lines) =====
        function clearPaths() {
            pathLines.forEach(function (id) { if (map.getLayer(id)) map.removeLayer(id); if (map.getSource(id)) map.removeSource(id); });
            pathLines = [];
            pathMarkers.forEach(m => m.remove());
            pathMarkers = [];
        }

        function loadPaths() {
            fetch(apiBaseUrl + '/api/userlocation/paths')
                .then(r => r.json())
                .then(data => {
                    clearPaths();
                    if (!data.routes || !layerStates.paths) return;
                    data.routes.forEach(function (route, i) {
                        var id = 'route-' + i;
                        map.addSource(id, {
                            type: 'geojson',
                            data: { type: 'Feature', geometry: { type: 'LineString', coordinates: route.coordinates } }
                        });
                        var width = 3 + Math.min(route.count || 1, 6);
                        var opacity = Math.min(0.5 + (route.count || 1) * 0.1, 0.85);
                        map.addLayer({
                            id: id,
                            type: 'line',
                            source: id,
                            paint: {
                                'line-color': '#0d6efd',
                                'line-width': width,
                                'line-opacity': opacity
                            }
                        });
                        pathLines.push(id);
                    });
                }).catch(err => console.error('[Paths]', err));
        }

        // ===== TOGGLE =====
        window.toggleLayer = function (layer) {
            layerStates[layer] = !layerStates[layer];
            var btn = document.getElementById('btn' + layer.charAt(0).toUpperCase() + layer.slice(1));
            btn.classList.toggle('active', layerStates[layer]);
            var icon = btn.querySelector('i');
            icon.className = layerStates[layer] ? 'fa-solid fa-circle-check me-1' : 'fa-regular fa-circle me-1';

            if (layer === 'live') { if (layerStates.live) showLiveMarkers(); else clearLiveMarkers(); }
            if (layer === 'heatmap') { if (layerStates.heatmap) drawHeatmap(); else removeHeatmapCanvas(); }
            if (layer === 'paths') { if (layerStates.paths) loadPaths(); else clearPaths(); }
        };

        // ===== SIGNALR =====
        var connection = new signalR.HubConnectionBuilder()
            .withUrl(apiBaseUrl + '/hubs/userlocation')
            .withAutomaticReconnect([0, 1000, 2000, 5000])
            .build();

        connection.on('UserOnline', function (data) {
            var did = data.deviceId || data.DeviceId;
            var lat = data.latitude || data.Latitude || 0;
            var lng = data.longitude || data.Longitude || 0;
            if (lat !== 0 && lng !== 0 && layerStates.live) {
                if (liveMarkers[did]) liveMarkers[did].remove();
                var el = document.createElement('div');
                el.style.cssText = 'width:16px;height:16px;background:#28a745;border-radius:50%;border:3px solid white;box-shadow:0 0 10px rgba(40,167,69,0.5);';
                liveMarkers[did] = new goongjs.Marker({ element: el }).setLngLat([lng, lat]).addTo(map);
                document.getElementById('onlineCount').textContent = Object.keys(liveMarkers).length;
            }
        });

        connection.on('LocationUpdated', function (data) {
            var did = data.deviceId || data.DeviceId;
            var lat = data.latitude || data.Latitude;
            var lng = data.longitude || data.Longitude;
            if (liveMarkers[did]) liveMarkers[did].remove();
            if (layerStates.live) {
                var el = document.createElement('div');
                el.style.cssText = 'width:16px;height:16px;background:#28a745;border-radius:50%;border:3px solid white;box-shadow:0 0 10px rgba(40,167,69,0.5);';
                liveMarkers[did] = new goongjs.Marker({ element: el }).setLngLat([lng, lat]).addTo(map);
            }
        });

        connection.on('UserOffline', function (data) {
            var did = data.deviceId || data.DeviceId;
            if (liveMarkers[did]) { liveMarkers[did].remove(); delete liveMarkers[did]; }
            document.getElementById('onlineCount').textContent = Object.keys(liveMarkers).length;
        });

        // ===== POLLING 3s =====
        function poll() {
            fetch(apiBaseUrl + '/api/userlocation/stats')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('onlineCount').textContent = data.onlineNow || 0;
                    document.getElementById('active24hCount').textContent = data.active24h || 0;
                    var total = (data.onlineLocations || []).length;
                    document.getElementById('locationPoints').textContent = data.active24h || 0;
                    syncLive(data);
                }).catch(err => console.error('[Poll]', err));
        }

        document.getElementById('refreshMap').addEventListener('click', function () {
            poll();
            if (layerStates.heatmap) loadHeatmap();
            if (layerStates.paths) { clearPaths(); loadPaths(); }
        });

        // ===== INIT =====
        map.on('load', function () {
            poll();
            loadHeatmap();
            loadPaths();
        });

        connection.start().then(function () {
            updateConnectionStatus('Real-time kết nối thành công', 'text-success');
            setInterval(poll, 3000);
        }).catch(function () {
            updateConnectionStatus('Dùng polling (3s)', 'text-warning');
            setInterval(poll, 3000);
        });

        connection.onreconnecting(function () { updateConnectionStatus('Đang kết nối lại...', 'text-warning'); });
        connection.onreconnected(function () { updateConnectionStatus('Real-time kết nối thành công', 'text-success'); });
    });
    </script>
}
