@{
    ViewData["Title"] = "Dashboard";
    var cmsRole = Context.Session.GetString("Role") ?? "";
    var isAdmin = cmsRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
}

<!-- Stats Cards Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#6366f1,#818cf8)">
                            <i class="fa-solid fa-map-location-dot text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Địa điểm (POI)</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.POICount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="POI" asp-action="Index" class="text-decoration-none text-primary fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>
    @if (isAdmin)
    {
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#10b981,#34d399)">
                            <i class="fa-solid fa-suitcase-rolling text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Chuyến Tour</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.TourCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Tour" asp-action="Index" class="text-decoration-none text-success fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#f59e0b,#fbbf24)">
                            <i class="fa-solid fa-users text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Thành viên</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.UserCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="User" asp-action="Index" class="text-decoration-none text-warning fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#ef4444,#f87171)">
                            <i class="fa-solid fa-ticket text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Đặt Vé</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.BookingCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Booking" asp-action="Index" class="text-decoration-none text-danger fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>
    }
</div>

@if (isAdmin)
{
<!-- Row 1: Online Users Monitoring -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-users-viewfinder text-success me-2"></i> Người dùng đang hoạt động trên App</h5>
                <span class="badge bg-success rounded-pill animate-pulse" id="onlineCount">
                    @(ViewBag.UserLocationStats?.OnlineNow ?? 0) đang online
                </span>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-6 col-md-6">
                        <div class="d-flex align-items-center p-3 rounded bg-success bg-opacity-10 h-100">
                            <i class="fa-solid fa-mobile-screen-button text-success fs-3 me-3"></i>
                            <div>
                                <div class="text-muted small">Đang online</div>
                                <div class="fw-bold fs-4">@(ViewBag.UserLocationStats?.OnlineNow ?? 0)</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-6">
                        <div class="d-flex align-items-center p-3 rounded bg-info bg-opacity-10 h-100">
                            <i class="fa-solid fa-clock-rotate-left text-info fs-3 me-3"></i>
                            <div>
                                <div class="text-muted small">Hoạt động 24h qua</div>
                                <div class="fw-bold fs-4">@(ViewBag.UserLocationStats?.Active24h ?? 0)</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center mb-2">
                    <small class="text-muted">
                        <i class="fa-solid fa-circle text-success me-1" style="font-size:8px"></i>
                        Cập nhật real-time khi người dùng mở/tắt App
                    </small>
                </div>
                
                <!-- Bản đồ vị trí người dùng đang online - Leaflet -->
                <div id="userLocationMap" style="height: 300px; border-radius: 8px; border: 1px solid #ddd;"></div>
                <div id="connectionStatus" class="mt-2 text-center">
                    <small class="text-muted"><i class="fa-solid fa-plug me-1"></i>Đang kết nối real-time...</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Analytics Stats -->
<div class="row g-4 mb-4">
    <!-- Top địa điểm được nghe nhiều nhất -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-trophy text-warning me-2"></i> Top địa điểm được nghe nhiều nhất</h5>
            </div>
            <div class="card-body p-0">
                @{
                    var narrationStats = ViewBag.NarrationStats as NarrationStatsViewModel;
                    var topPOIs = narrationStats?.TopPOIs ?? new List<TopPOIViewModel>();
                }
                @if (topPOIs.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var (poi, index) in topPOIs.Select((p, i) => (p, i)))
                        {
                            <div class="list-group-item d-flex align-items-center py-3">
                                <span class="badge @(index < 3 ? "bg-warning" : "bg-secondary") rounded-pill me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                    @(index + 1)
                                </span>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@poi.PoiName</div>
                                    <small class="text-muted">POI #@poi.PoiId</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary rounded-pill">@poi.Count lượt nghe</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-headphones-simple fs-1 mb-2"></i>
                        <p class="mb-0">Chưa có dữ liệu lượt nghe</p>
                        <small>Dữ liệu sẽ được cập nhật khi người dùng sử dụng App</small>
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-top-0 text-center">
                <small class="text-muted">Tổng lượt nghe: <strong>@(narrationStats?.TotalPlays ?? 0)</strong></small>
            </div>
        </div>
    </div>

    <!-- Thời gian nghe trung bình tại POI -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-stopwatch text-info me-2"></i> Thời gian nghe trung bình tại POI</h5>
            </div>
            <div class="card-body p-0">
                @{
                    var durationStats = ViewBag.DurationStats as DurationStatsViewModel;
                    var poiDurations = durationStats?.POIDurations ?? new List<POIDurationViewModel>();
                }
                @if (poiDurations.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var poi in poiDurations.Take(5))
                        {
                            <div class="list-group-item d-flex align-items-center py-3">
                                <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                    <i class="fa-solid fa-location-dot text-info"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@poi.PoiName</div>
                                    <small class="text-muted">@poi.TotalListens lượt nghe</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-info rounded-pill">
                                        <i class="fa-regular fa-clock me-1"></i>@poi.AvgDurationFormatted
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-hourglass-half fs-1 mb-2"></i>
                        <p class="mb-0">Chưa có dữ liệu thời gian nghe</p>
                        <small>Thời gian nghe sẽ được ghi lại khi người dùng nghe audio</small>
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-top-0 text-center">
                <small class="text-muted">
                    Thời gian nghe TB toàn hệ thống: 
                    <strong class="text-info">@(durationStats?.GlobalAverageFormatted ?? "00:00")</strong>
                </small>
            </div>
        </div>
    </div>
</div>
}

@section Styles {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
}

@section Scripts {
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ===== LEAFLET MAP SETUP =====
            // Tọa độ mặc định: khu vực Vĩnh Khánh Q4 (trung tâm các POI)
            var map = L.map('userLocationMap').setView([10.762, 106.702], 15);
            
            // Thêm OpenStreetMap tile layer
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                maxZoom: 19
            }).addTo(map);
            
            // Store markers by deviceId
            var markers = {};
            var onlineCount = 0;
            
            // Icon cho user online (chấm xanh)
            var onlineIcon = L.divIcon({
                className: 'custom-div-icon',
                html: "<div style='background-color:#28a745;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 0 10px rgba(40,167,69,0.5);'></div>",
                iconSize: [16, 16],
                iconAnchor: [8, 8]
            });
            
            // ===== SIGNALR SETUP =====
            // API URL - khớp với port API đang chạy (https://localhost:7244)
            var apiBaseUrl = 'https://localhost:7244';
            
            var connection = new signalR.HubConnectionBuilder()
                .withUrl(apiBaseUrl + '/hubs/userlocation')
                .withAutomaticReconnect()
                .build();
            
            // Cập nhật trạng thái kết nối
            function updateConnectionStatus(status, color) {
                var statusEl = document.getElementById('connectionStatus');
                if (statusEl) {
                    statusEl.innerHTML = '<small class="' + color + '"><i class="fa-solid fa-circle me-1" style="font-size:8px"></i>' + status + '</small>';
                }
            }
            
            // Nhận location update từ API
            connection.on('LocationUpdated', function (data) {
                console.log('[SignalR] Location update:', data);
                
                var deviceId = data.deviceId || data.DeviceId;
                var lat = data.latitude || data.Latitude;
                var lng = data.longitude || data.Longitude;
                
                // Remove existing marker for this device
                if (markers[deviceId]) {
                    map.removeLayer(markers[deviceId]);
                }
                
                // Add new marker
                var marker = L.marker([lat, lng], { icon: onlineIcon })
                    .addTo(map)
                    .bindPopup('<b>Device:</b> ' + deviceId + '<br><b>Time:</b> ' + new Date().toLocaleTimeString());
                
                markers[deviceId] = marker;
                
                // Cập nhật số đang online (ước tính)
                if (!onlineCount) onlineCount = Object.keys(markers).length;
                document.getElementById('onlineCount').textContent = onlineCount + ' đang online';
            });
            
            // User offline
            connection.on('UserOffline', function (data) {
                console.log('[SignalR] User offline:', data);
                var deviceId = data.deviceId || data.DeviceId;
                
                if (markers[deviceId]) {
                    map.removeLayer(markers[deviceId]);
                    delete markers[deviceId];
                }
                
                onlineCount = Object.keys(markers).length;
                document.getElementById('onlineCount').textContent = onlineCount + ' đang online';
            });
            
            // User online (initial)
            connection.on('UserOnline', function (data) {
                console.log('[SignalR] User online:', data);
                var deviceId = data.deviceId || data.DeviceId;
                var lat = data.latitude || data.Latitude;
                var lng = data.longitude || data.Longitude;
                
                var marker = L.marker([lat, lng], { icon: onlineIcon })
                    .addTo(map)
                    .bindPopup('<b>Device:</b> ' + deviceId + '<br><b>Time:</b> ' + new Date().toLocaleTimeString());
                
                markers[deviceId] = marker;
                
                onlineCount = Object.keys(markers).length;
                document.getElementById('onlineCount').textContent = onlineCount + ' đang online';
            });
            
            // Start SignalR connection
            connection.start()
                .then(function () {
                    console.log('[SignalR] Connected!');
                    updateConnectionStatus('Kết nối real-time thành công', 'text-success');
                    
                    // Load initial online users từ API
                    fetch(apiBaseUrl + '/api/userlocation/stats')
                        .then(r => r.json())
                        .then(data => {
                            console.log('[API] Initial stats:', data);
                            if (data.onlineLocations) {
                                data.onlineLocations.forEach(function (loc) {
                                    var deviceId = loc.deviceId || loc.DeviceId;
                                    var lat = loc.latitude || loc.Latitude;
                                    var lng = loc.longitude || loc.Longitude;
                                    
                                    var marker = L.marker([lat, lng], { icon: onlineIcon })
                                        .addTo(map)
                                        .bindPopup('<b>Device:</b> ' + deviceId + '<br><b>Last seen:</b> ' + (loc.timestamp || loc.Timestamp));
                                    
                                    markers[deviceId] = marker;
                                });
                                
                                onlineCount = data.onlineNow || data.onlineLocations.length;
                                document.getElementById('onlineCount').textContent = onlineCount + ' đang online';
                            }
                        })
                        .catch(err => console.error('[API] Error loading stats:', err));
                })
                .catch(function (err) {
                    console.error('[SignalR] Connection failed:', err);
                    updateConnectionStatus('Mất kết nối real-time - đang thử lại...', 'text-warning');
                });
            
            // Xử lý reconnect
            connection.onreconnecting(function (err) {
                console.warn('[SignalR] Reconnecting...', err);
                updateConnectionStatus('Mất kết nối - đang kết nối lại...', 'text-warning');
            });
            
            connection.onreconnected(function (connectionId) {
                console.log('[SignalR] Reconnected!');
                updateConnectionStatus('Kết nối real-time thành công', 'text-success');
            });
            
            console.log('Dashboard with Leaflet + SignalR initialized');
        });
    </script>
}
