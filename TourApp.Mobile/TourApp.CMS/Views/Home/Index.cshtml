@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Cards Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#6366f1,#818cf8)">
                            <i class="fa-solid fa-map-location-dot text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Địa điểm (POI)</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.POICount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="POI" asp-action="Index" class="text-decoration-none text-primary fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#10b981,#34d399)">
                            <i class="fa-solid fa-suitcase-rolling text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Chuyến Tour</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.TourCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Tour" asp-action="Index" class="text-decoration-none text-success fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#f59e0b,#fbbf24)">
                            <i class="fa-solid fa-users text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Thành viên</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.UserCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="User" asp-action="Index" class="text-decoration-none text-warning fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#06b6d4,#22d3ee)">
                            <i class="fa-solid fa-headphones text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Lượt Nghe</p>
                        <h3 class="mb-0 fw-bold" id="totalPlays">--</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <span class="text-info fw-medium" style="font-size:0.85rem">
                    <i class="fa-solid fa-chart-line me-1"></i> Từ NarrationLog
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Analytics Charts Row -->
<div class="row g-4 mb-4">
    <!-- Daily Play Chart -->
    <div class="col-lg-8">
        <div class="card border-0 h-100">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-column text-info me-2"></i> Lượt Nghe Thuyết Minh (7 ngày)</h5>
                <span class="badge bg-info-subtle text-info" style="font-size:0.75rem">Auto-refresh mỗi 60s</span>
            </div>
            <div class="card-body">
                <canvas id="dailyChart" height="120"></canvas>
                <div id="noDataMsg" class="text-center text-muted py-4" style="display:none">
                    <i class="fa-solid fa-database fa-2x mb-2 d-block"></i>
                    Chưa có dữ liệu lượt nghe. Hãy mở app mobile thử!
                </div>
            </div>
        </div>
    </div>

    <!-- Trigger Type Pie -->
    <div class="col-lg-4">
        <div class="card border-0 h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-pie text-warning me-2"></i> Loại Kích Hoạt</h5>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <canvas id="triggerChart" width="200" height="200" style="max-width:200px"></canvas>
                <div id="triggerLegend" class="mt-3 w-100"></div>
            </div>
        </div>
    </div>
</div>

<!-- Top POI + Quick Actions -->
<div class="row g-4 mb-4">
    <!-- Top POI -->
    <div class="col-lg-6">
        <div class="card border-0 h-100">
            <div class="card-header bg-white d-flex align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-ranking-star text-danger me-2"></i> Top 5 Địa Điểm Nghe Nhiều Nhất</h5>
            </div>
            <div class="card-body p-0">
                <div id="topPoiList" class="list-group list-group-flush">
                    <div class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm text-info" role="status"></div>
                        <span class="ms-2">Đang tải...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-6">
        <div class="card border-0 h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-bolt text-warning me-2"></i> Thao tác nhanh</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <a asp-controller="POI" asp-action="Create" class="btn btn-outline-primary w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-map-pin text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Thêm Địa Điểm</div>
                                <small class="text-muted">Tạo POI mới</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a asp-controller="Audio" asp-action="Create" class="btn btn-outline-info w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-microphone text-info"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Thêm Audio</div>
                                <small class="text-muted">TTS hoặc MP3</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a asp-controller="Tour" asp-action="Create" class="btn btn-outline-success w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-plus text-success"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Tạo Tour</div>
                                <small class="text-muted">Tour mới</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a asp-controller="Activity" asp-action="Index" class="btn btn-outline-secondary w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-clipboard-list text-secondary"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Activity Log</div>
                                <small class="text-muted">Lịch sử thao tác</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
let dailyChart = null;
let triggerChart = null;

const COLORS = {
    geofence: '#6366f1',
    qr:       '#10b981',
    manual:   '#f59e0b',
    other:    '#94a3b8'
};

async function loadStats() {
    try {
        const r = await fetch('/api/narrationlog/stats', { cache: 'no-store' });
        if (!r.ok) throw new Error('API không phản hồi');
        const data = await r.json();
        renderStats(data);
    } catch(e) {
        console.warn('[Analytics]', e.message);
        renderEmptyState();
    }
}

function renderStats(data) {
    // Total plays badge
    document.getElementById('totalPlays').textContent = data.total ?? 0;

    // === Daily chart ===
    const daily = data.dailyPlays ?? [];
    const hasDaily = daily.length > 0;
    document.getElementById('noDataMsg').style.display = hasDaily ? 'none' : '';

    if (hasDaily) {
        const ctx = document.getElementById('dailyChart').getContext('2d');
        if (dailyChart) dailyChart.destroy();
        dailyChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: daily.map(d => d.date),
                datasets: [{
                    label: 'Lượt nghe',
                    data: daily.map(d => d.count),
                    backgroundColor: 'rgba(99,102,241,0.7)',
                    borderColor: '#6366f1',
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });
    }

    // === Trigger type pie ===
    const triggers = data.triggerStats ?? [];
    if (triggers.length > 0) {
        const ctx2 = document.getElementById('triggerChart').getContext('2d');
        if (triggerChart) triggerChart.destroy();
        triggerChart = new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: triggers.map(t => t.type || 'other'),
                datasets: [{
                    data: triggers.map(t => t.count),
                    backgroundColor: triggers.map(t => COLORS[t.type] ?? COLORS.other),
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                cutout: '65%',
                plugins: { legend: { display: false } }
            }
        });

        // Legend
        const legend = document.getElementById('triggerLegend');
        const iconMap = { geofence:'📡', qr:'📷', manual:'👆', other:'❓' };
        legend.innerHTML = triggers.map(t => `
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span>${iconMap[t.type]??'•'} <span class="text-capitalize">${t.type}</span></span>
                <span class="badge rounded-pill" style="background:${COLORS[t.type]??COLORS.other}">${t.count}</span>
            </div>`).join('');
    }

    // === Top POI list ===
    const topPoi = data.topPoi ?? [];
    const listEl = document.getElementById('topPoiList');
    if (topPoi.length === 0) {
        listEl.innerHTML = `<div class="text-center text-muted py-4">
            <i class="fa-solid fa-headphones fa-2x mb-2 d-block opacity-30"></i>Chưa có lượt nghe nào.</div>`;
    } else {
        const medals = ['🥇','🥈','🥉','4️⃣','5️⃣'];
        listEl.innerHTML = topPoi.map((p, i) => `
            <div class="list-group-item border-0 d-flex align-items-center py-2 px-3">
                <span class="fs-5 me-3">${medals[i]??'•'}</span>
                <div class="flex-grow-1">
                    <div class="fw-semibold text-dark">${p.poiName}</div>
                    <small class="text-muted">ID #${p.poiId}</small>
                </div>
                <span class="badge rounded-pill bg-primary-subtle text-primary fw-bold"
                      style="font-size:.85rem">${p.count} lượt</span>
            </div>`).join('');
    }
}

function renderEmptyState() {
    document.getElementById('totalPlays').textContent = '0';
    document.getElementById('topPoiList').innerHTML = `
        <div class="text-center text-muted py-4">
            <i class="fa-solid fa-plug-circle-xmark fa-2x mb-2 d-block opacity-30"></i>
            Không kết nối được API. Mở app thử và thêm POI!
        </div>`;
}

// Load ngay và auto-refresh mỗi 60s
loadStats();
setInterval(loadStats, 60000);
</script>
}
