@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Cards Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#6366f1,#818cf8)">
                            <i class="fa-solid fa-map-location-dot text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Địa điểm (POI)</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.POICount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="POI" asp-action="Index" class="text-decoration-none text-primary fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#10b981,#34d399)">
                            <i class="fa-solid fa-suitcase-rolling text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Chuyến Tour</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.TourCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Tour" asp-action="Index" class="text-decoration-none text-success fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#f59e0b,#fbbf24)">
                            <i class="fa-solid fa-users text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Thành viên</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.UserCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="User" asp-action="Index" class="text-decoration-none text-warning fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#ef4444,#f87171)">
                            <i class="fa-solid fa-ticket text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Đặt Vé</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.BookingCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Booking" asp-action="Index" class="text-decoration-none text-danger fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Chart Row -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0">
            <div class="card-header bg-white d-flex align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-pie text-primary me-2"></i> Tổng quan Dữ liệu</h5>
            </div>
            <div class="card-body">
                <canvas id="overviewChart" height="100"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card border-0 h-100">
            <div class="card-header bg-white d-flex align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-bolt text-warning me-2"></i> Thao tác nhanh</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <a asp-controller="POI" asp-action="Create" class="btn btn-outline-primary w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-map-pin text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Thêm Địa Điểm</div>
                                <small class="text-muted">Tạo POI mới</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-4">
                        <a asp-controller="Tour" asp-action="Create" class="btn btn-outline-success w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-plus text-success"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Tạo Tour</div>
                                <small class="text-muted">Tạo chuyến mới</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-4">
                        <a asp-controller="User" asp-action="Create" class="btn btn-outline-warning w-100 py-3 text-start d-flex align-items-center">
                            <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;min-width:40px">
                                <i class="fa-solid fa-user-plus text-warning"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Thêm User</div>
                                <small class="text-muted">Tạo tài khoản</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-circle-info text-info me-2"></i> Thông tin hệ thống</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-solid fa-server me-2"></i> Phiên bản</span>
                        <span class="badge bg-primary rounded-pill">v1.0.0</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-solid fa-database me-2"></i> Database</span>
                        <span class="badge bg-success rounded-pill">SQL Server</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-solid fa-code me-2"></i> Framework</span>
                        <span class="badge bg-info rounded-pill">.NET 10</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-regular fa-clock me-2"></i> Ngày</span>
                        <span class="badge bg-secondary rounded-pill">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('overviewChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Địa điểm (POI)', 'Chuyến Tour', 'Thành viên', 'Đặt Vé'],
                    datasets: [{
                        label: 'Số lượng Dữ liệu',
                        data: [@ViewBag.POICount, @ViewBag.TourCount, @ViewBag.UserCount, @ViewBag.BookingCount],
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.7)',
                            'rgba(16, 185, 129, 0.7)',
                            'rgba(245, 158, 11, 0.7)',
                            'rgba(239, 68, 68, 0.7)'
                        ],
                        borderColor: [
                            'rgb(99, 102, 241)',
                            'rgb(16, 185, 129)',
                            'rgb(245, 158, 11)',
                            'rgb(239, 68, 68)'
                        ],
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [5, 5] }, ticks: { stepSize: 1 } },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
}
