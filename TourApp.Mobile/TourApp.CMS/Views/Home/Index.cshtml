@using TourApp.CMS.Models
@{
    ViewData["Title"] = "Dashboard";
    var cmsRole = Context.Session.GetString("Role") ?? "";
    var isAdmin = cmsRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
}

<!-- Stats Cards Row -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#6366f1,#818cf8)">
                            <i class="fa-solid fa-map-location-dot text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Địa điểm (POI)</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.POICount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="POI" asp-action="Index" class="text-decoration-none text-primary fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>
    @if (isAdmin)
    {
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#10b981,#34d399)">
                            <i class="fa-solid fa-suitcase-rolling text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Chuyến Tour</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.TourCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Tour" asp-action="Index" class="text-decoration-none text-success fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#f59e0b,#fbbf24)">
                            <i class="fa-solid fa-users text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Thành viên</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.UserCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="User" asp-action="Index" class="text-decoration-none text-warning fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 overflow-hidden h-100">
            <div class="card-body position-relative">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;background:linear-gradient(135deg,#ef4444,#f87171)">
                            <i class="fa-solid fa-ticket text-white fs-4"></i>
                        </div>
                    </div>
                    <div>
                        <p class="text-muted mb-1 text-uppercase fw-semibold" style="font-size:0.75rem;letter-spacing:0.05em">Đặt Vé</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.BookingCount</h3>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                <a asp-controller="Booking" asp-action="Index" class="text-decoration-none text-danger fw-medium d-flex align-items-center" style="font-size:0.85rem">
                    Xem chi tiết <i class="fa-solid fa-arrow-right ms-auto"></i>
                </a>
            </div>
        </div>
    </div>
    }
</div>

@if (isAdmin)
{
<!-- Row 2: Charts -->
<div class="row g-4 mb-4">
    <!-- Chart: Tổng quan hệ thống -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-column text-primary me-2"></i> Tổng quan hệ thống</h5>
            </div>
            <div class="card-body">
                <canvas id="overviewChart" height="200"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Chart: Top địa điểm được nghe -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-bar text-warning me-2"></i> Lượt nghe theo POI</h5>
            </div>
            <div class="card-body">
                <canvas id="narrationChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Row 3: Analytics Stats -->
<div class="row g-4 mb-4">
    <!-- Top địa điểm được nghe nhiều nhất -->
    <div class="col-lg-12">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-trophy text-warning me-2"></i> Top địa điểm được nghe nhiều nhất</h5>
            </div>
            <div class="card-body p-0">
                @{
                    var narrationStats = ViewBag.NarrationStats as NarrationStatsViewModel;
                    var topPOIs = narrationStats?.TopPOIs ?? new List<TopPOIViewModel>();
                }
                @if (topPOIs.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var (poi, index) in topPOIs.Select((p, i) => (p, i)))
                        {
                            <div class="list-group-item d-flex align-items-center py-3">
                                <span class="badge @(index < 3 ? "bg-warning" : "bg-secondary") rounded-pill me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                    @(index + 1)
                                </span>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@poi.PoiName</div>
                                    <small class="text-muted">POI #@poi.PoiId</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary rounded-pill">@poi.Count lượt nghe</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-headphones-simple fs-1 mb-2"></i>
                        <p class="mb-0">Chưa có dữ liệu lượt nghe</p>
                        <small>Dữ liệu sẽ được cập nhật khi người dùng sử dụng App</small>
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-top-0 text-center">
                <small class="text-muted">Tổng lượt nghe: <strong>@(narrationStats?.TotalPlays ?? 0)</strong></small>
            </div>
        </div>
    </div>

</div>
}

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Dữ liệu từ ViewBag
            var poiCount = @(ViewBag.POICount ?? 0);
            var tourCount = @(ViewBag.TourCount ?? 0);
            var userCount = @(ViewBag.UserCount ?? 0);
            var bookingCount = @(ViewBag.BookingCount ?? 0);
            
            // ===== Chart 1: Tổng quan hệ thống =====
            var ctx1 = document.getElementById('overviewChart').getContext('2d');
            new Chart(ctx1, {
                type: 'bar',
                data: {
                    labels: ['Địa điểm', 'Tour', 'Thành viên', 'Đặt vé'],
                    datasets: [{
                        label: 'Số lượng',
                        data: [poiCount, tourCount, userCount, bookingCount],
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.8)',   // Primary - POI
                            'rgba(16, 185, 129, 0.8)',   // Success - Tour
                            'rgba(245, 158, 11, 0.8)',   // Warning - User
                            'rgba(239, 68, 68, 0.8)'     // Danger - Booking
                        ],
                        borderColor: [
                            'rgba(99, 102, 241, 1)',
                            'rgba(16, 185, 129, 1)',
                            'rgba(245, 158, 11, 1)',
                            'rgba(239, 68, 68, 1)'
                        ],
                        borderWidth: 1,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
            
            // ===== Chart 2: Lượt nghe theo POI =====
            var narrationData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                (ViewBag.NarrationStats as NarrationStatsViewModel)?.TopPOIs?.Take(5)
                    .Select(p => (object)new { poiId = p.PoiId, poiName = p.PoiName, count = p.Count })
                    .ToList() ?? new List<object>(),
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
            ));
            
            if (narrationData && narrationData.length > 0) {
                var ctx2 = document.getElementById('narrationChart').getContext('2d');
                new Chart(ctx2, {
                    type: 'bar',
                    data: {
                        labels: narrationData.map(p => p.poiName?.substring(0, 15) || ('POI #' + p.poiId)),
                        datasets: [{
                            label: 'Lượt nghe',
                            data: narrationData.map(p => p.count),
                            backgroundColor: 'rgba(245, 158, 11, 0.8)',
                            borderColor: 'rgba(245, 158, 11, 1)',
                            borderWidth: 1,
                            borderRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            }
                        }
                    }
                });
            } else {
                document.getElementById('narrationChart').parentElement.innerHTML = 
                    '<div class="text-center py-5 text-muted"><i class="fa-solid fa-chart-simple fs-1 mb-2"></i><p>Chưa có dữ liệu lượt nghe</p></div>';
            }
        });
    </script>
}
