@model IEnumerable<TourApp.CMS.Models.Tour>

@{
    ViewData["Title"] = "Quản lý Tour";
}

<div class="page-breadcrumb">
    <i class="fas fa-suitcase"></i> Quản lý / Tour
</div>

<div class="page-title">🎒 Quản lý Tour</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-times-circle"></i> @TempData["error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Danh sách Tour</h5>
        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="fas fa-plus"></i> Thêm Tour
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Tên Tour</th>
                        <th>Điểm Đến</th>
                        <th>Giá</th>
                        <th>Thời gian</th>
                        <th>Max Khách</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var tour in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@tour.Id</span></td>
                                <td class="fw-bold text-primary">@tour.Name</td>
                                <td>@tour.Destination</td>
                                <td><strong class="text-success">@tour.Price.ToString("C")</strong></td>
                                <td><span class="badge bg-info">@tour.Duration ngày</span></td>
                                <td>@tour.MaxParticipants</td>
                                <td>
                                    @if (tour.IsActive)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Vô hiệu</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@tour.Id" class="btn btn-sm btn-info" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@tour.Id" class="btn btn-sm btn-danger" 
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa?');" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2"></i>
                                <p>Không có dữ liệu nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
