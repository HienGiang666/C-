@using System.Text.Json
@model TourApp.CMS.Models.TourFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa Tour";
    var poisJson = ViewBag.PoisJson as string ?? "[]";
    var initialStops = JsonSerializer.Serialize(Model.StopPoiIds ?? new List<int>());
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-fw fa-pen me-2 text-primary"></i> @ViewData["Title"] (#@Model.Tour.DisplayCode)</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data" id="tourForm">
                    <input type="hidden" asp-for="Tour.Id" />
                    <input type="hidden" asp-for="Tour.CreatedAt" />
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label asp-for="Tour.Name" class="form-label fw-medium">Tên Tour <span class="text-danger">*</span></label>
                            <input asp-for="Tour.Name" class="form-control form-control-lg" required />
                        </div>
                    </div>

                    <div class="border rounded-3 p-3 mb-3 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label asp-for="RestaurantCount" class="form-label fw-medium mb-0">Số quán / điểm dừng trong tour</label>
                            <span class="badge bg-primary rounded-pill" id="poiCountBadge">0 điểm</span>
                        </div>
                        <input asp-for="RestaurantCount" type="number" class="form-control" min="0" max="50" id="restaurantCount" />
                        <div id="poiPickerContainer" class="mt-3"></div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="Tour.Price" class="form-label fw-medium">Giá vé (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Tour.Price" type="number" class="form-control" required min="0.01" step="0.01" />
                                <span class="input-group-text">VNĐ</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Tour.Duration" class="form-label fw-medium">Thời lượng (ngày)</label>
                            <input asp-for="Tour.Duration" type="number" class="form-control" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Tour.MaxParticipants" class="form-label fw-medium">Số khách tối đa</label>
                            <input asp-for="Tour.MaxParticipants" type="number" class="form-control" min="0" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Ảnh cover tour</label>
                        @if (!string.IsNullOrEmpty(Model.Tour.ImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.Tour.ImageUrl" alt="Current" class="img-thumbnail" style="max-height: 150px;" />
                                <small class="text-muted d-block">Ảnh hiện tại</small>
                            </div>
                        }
                        <input type="file" name="coverImage" class="form-control" accept="image/*" />
                        <small class="text-muted">Chọn file ảnh mới để thay thế (JPG, PNG, …) hoặc để trống để giữ ảnh cũ.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium text-muted">Từ khóa tìm kiếm</label>
                        <div class="form-control bg-light text-muted small py-2">Tự động tạo từ <strong>tên tour</strong>, <strong>mô tả</strong> và <strong>tên các điểm dừng</strong> khi lưu.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Tour.Description" class="form-label fw-medium">Ghi chú (Tiếng Việt)</label>
                        <textarea asp-for="Tour.Description" id="tourDesc" class="form-control" rows="5"></textarea>
                        <div class="form-text text-muted small">Rời khỏi ô này để tự động dịch sang các ngôn ngữ khác.</div>
                    </div>

                    <div class="border rounded-3 p-3 mb-4 bg-light">
                        <label class="form-label fw-medium">Mô tả đa ngôn ngữ (dùng cho app mobile)</label>
                        <div id="translate-status" class="small text-muted mb-2" style="display:none;"></div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-muted">English</label>
                                <textarea id="desc-en" name="Translation_en" class="form-control" rows="3">@(Model.Translations?.FirstOrDefault(t => t.Language == "en")?.Description ?? "")</textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-muted">中文 (Chinese)</label>
                                <textarea id="desc-zh" name="Translation_zh" class="form-control" rows="3">@(Model.Translations?.FirstOrDefault(t => t.Language == "zh")?.Description ?? "")</textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-muted">日本語 (Japanese)</label>
                                <textarea id="desc-ja" name="Translation_ja" class="form-control" rows="3">@(Model.Translations?.FirstOrDefault(t => t.Language == "ja")?.Description ?? "")</textarea>
                            </div>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input mt-1" type="checkbox" role="switch" asp-for="Tour.IsActive">
                        <label class="form-check-label ms-2 fw-medium" asp-for="Tour.IsActive">Trạng thái Hoạt động</label>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border px-4">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-1"></i> Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const pois = @Html.Raw(poisJson);
const initialStops = @Html.Raw(initialStops);

function buildPickers() {
    const n = Math.max(0, parseInt(document.getElementById('restaurantCount').value, 10) || 0);
    document.getElementById('poiCountBadge').textContent = `${n} điểm`;
    const box = document.getElementById('poiPickerContainer');
    box.innerHTML = '';
    for (let i = 0; i < n; i++) {
        const wrap = document.createElement('div');
        wrap.className = 'mb-2';
        wrap.innerHTML = `<label class="form-label small text-muted">Điểm dừng thứ ${i + 1}</label>`;
        const sel = document.createElement('select');
        sel.className = 'form-select poi-select';
        sel.name = 'StopPoiIds';
        sel.required = true;
        const o0 = document.createElement('option');
        o0.value = '';
        o0.textContent = '-- Chọn địa điểm --';
        sel.appendChild(o0);
        pois.forEach(p => {
            const o = document.createElement('option');
            o.value = p.id;
            o.textContent = p.name;
            sel.appendChild(o);
        });
        const preset = initialStops[i];
        if (preset) sel.value = String(preset);
        wrap.appendChild(sel);
        box.appendChild(wrap);

        sel.addEventListener('change', function() {
            checkDuplicatePOIs(this);
        });
    }
}

function checkDuplicatePOIs(currentSelect) {
    const allSelects = document.querySelectorAll('.poi-select');
    const currentVal = currentSelect.value;
    if (!currentVal) return;

    let duplicateFound = false;
    allSelects.forEach(s => {
        if (s !== currentSelect && s.value === currentVal) {
            duplicateFound = true;
        }
    });

    if (duplicateFound) {
        alert('Địa điểm này đã được chọn trong tour. Vui lòng chọn địa điểm khác!');
        currentSelect.value = '';
    }
}

document.getElementById('restaurantCount').addEventListener('input', buildPickers);
buildPickers();

    async function translateText(text, targetLang) {
        try {
            const url = `/api/Translate?text=${encodeURIComponent(text)}&target=${targetLang}&source=vi`;
            const response = await fetch(url);
            if (!response.ok) return text;
            const data = await response.json();
            if (Array.isArray(data) && data[0] && Array.isArray(data[0][0]) && data[0][0][0]) {
                return data[0][0][0];
            }
            if (data.translatedText) return data.translatedText;
            return text;
        } catch (err) {
            console.error('Translation error:', err);
            return text;
        }
    }

    let _translateTimer = null;
    const tourDescEl = document.getElementById('tourDesc');
    if (tourDescEl) {
        tourDescEl.addEventListener('input', () => {
            clearTimeout(_translateTimer);
            _translateTimer = setTimeout(autoTranslateAll, 1500);
        });
        tourDescEl.addEventListener('blur', autoTranslateAll);
    }

    async function autoTranslateAll() {
        const tourDesc = tourDescEl?.value?.trim();
        if (!tourDesc) return;
        const status = document.getElementById('translate-status');
        const langMap = { 'en': 'English', 'zh': 'Chinese', 'ja': 'Japanese' };
        const codes = ['en', 'zh', 'ja'];
        const allEmpty = codes.every(c => !document.getElementById(`desc-${c}`)?.value?.trim());
        if (!allEmpty) return;
        status.style.display = 'block';
        for (const code of codes) {
            const box = document.getElementById(`desc-${code}`);
            if (!box || box.value.trim()) continue;
            status.textContent = `Đang dịch sang ${langMap[code]}...`;
            try {
                box.value = await translateText(tourDesc, code);
            } catch (e) { console.error(e); }
        }
        status.textContent = 'Dịch tự động hoàn tất!';
        setTimeout(() => status.style.display = 'none', 3000);
    }
</script>
}
