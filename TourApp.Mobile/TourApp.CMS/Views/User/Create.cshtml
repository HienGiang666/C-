@model TourApp.CMS.Models.User

@{
    ViewData["Title"] = "Thêm Người Dùng Mới";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-user-plus me-2 text-primary"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-medium">Họ và Tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control form-control-lg" placeholder="Nhập họ và tên đầy đủ..." required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label fw-medium">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input asp-for="Username" class="form-control" required autocomplete="username" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="PasswordHash" type="password" class="form-control" required autocomplete="new-password" />
                            <span asp-validation-for="PasswordHash" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-medium">Địa chỉ Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" required placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-medium">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="09xxxxxxxxx" minlength="0" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-medium">Quyền hạn</label>
                            <select asp-for="Role" class="form-select">
                                <option value="Admin">Quản trị viên (admin)</option>
                                <option value="RestaurantOwner">Chủ quán ăn</option>
                            </select>
                            <small class="text-muted">Khách hàng chỉ tạo qua app mobile.</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-medium">Ngày sinh</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-medium">Địa chỉ liên hệ</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Số nhà, Tên đường..."></textarea>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border px-4">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-1"></i> Lưu thông tin</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
