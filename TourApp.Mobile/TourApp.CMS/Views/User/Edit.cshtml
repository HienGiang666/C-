@model TourApp.CMS.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa User";
}

<div class="page-breadcrumb">
    <i class="fas fa-users"></i> Quản lý / User / <span class="text-primary">Chỉnh sửa</span>
</div>

<div class="page-title">✏️ Chỉnh sửa User</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Thông tin User</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-bold">Tên Đầy Đủ <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">Số Điện Thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold">Địa Chỉ</label>
                        <input asp-for="Address" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DateOfBirth" class="form-label fw-bold">Ngày Sinh</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Role" class="form-label fw-bold">Vai Trò</label>
                            <select asp-for="Role" class="form-control">
                                <option value="Customer">Customer</option>
                                <option value="Staff">Staff</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IsActive" class="form-label fw-bold">Trạng thái</label>
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActive" />
                            <label class="form-check-label" for="isActive">
                                Hoạt động
                            </label>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i> Lưu Thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">ℹ️ Thông tin</h5>
            </div>
            <div class="card-body">
                <p><strong>ID:</strong> <span class="badge bg-secondary">@Model.Id</span></p>
                <p><strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
    </div>
</div>
