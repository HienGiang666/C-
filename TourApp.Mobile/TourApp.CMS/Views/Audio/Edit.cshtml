@using System.Text.Json
@model TourApp.CMS.Models.Audio

@{
    ViewData["Title"] = "Sửa thông tin Thuyết minh";
    var languages = ViewBag.Languages as List<TourApp.CMS.Models.LanguageOption> ?? new List<TourApp.CMS.Models.LanguageOption>();
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen me-2 text-info"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AudioPath" />

                    <div class="mb-4">
                        <label class="form-label fw-medium">Thuộc địa điểm (POI)</label>
                        <select asp-for="POIId" class="form-select" asp-items="@ViewBag.PoiList">
                        </select>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Language" class="form-label fw-medium">Ngôn ngữ <span class="text-danger">*</span></label>
                            <select asp-for="Language" class="form-select" required>
                                @foreach (var lang in languages)
                                {
                                    <option value="@lang.Code">@lang.Name (@lang.Code)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Duration" class="form-label fw-medium">Thời lượng (giây)</label>
                            <input asp-for="Duration" type="number" class="form-control" readonly />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ScriptText" class="form-label fw-medium">Nội dung thuyết minh</label>
                        <textarea asp-for="ScriptText" class="form-control" rows="6" id="scriptText"></textarea>
                    </div>

                    <div class="d-flex gap-2 mb-4">
                        <button type="button" class="btn btn-outline-info" onclick="speakText()">🔊 Nghe thử (giọng nữ)</button>
                        <button type="button" class="btn btn-outline-danger" onclick="stopSpeech()">⏹ Dừng</button>
                    </div>
                    <input type="hidden" asp-for="IsActive" value="true" />
                    
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" asp-route-poiId="@Model.POIId" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-info text-white"><i class="fa-solid fa-save me-1"></i> Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/cms-tts.js" asp-append-version="true"></script>
<script>
const synth = window.speechSynthesis;
const languages = @Html.Raw(JsonSerializer.Serialize(languages));
cmsWarmUpSpeechVoices();

function getCurrentLocale() {
    const selected = document.getElementById('Language').value || 'en';
    const found = languages.find(x => x.Code === selected);
    return found?.Locale || 'en-US';
}

function speakText() {
    const text = document.getElementById('scriptText').value.trim();
    if (!text) return;
    const code = document.getElementById('Language').value || 'en';
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = getCurrentLocale();
    utter.pitch = 1.08;
    utter.rate = 0.95;
    utter.voice = cmsPickTtsVoiceForLocale(utter.lang, code);
    stopSpeech();
    synth.speak(utter);
}

function stopSpeech() {
    synth.cancel();
}
</script>
}
