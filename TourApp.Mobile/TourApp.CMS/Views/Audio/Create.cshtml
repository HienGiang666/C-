@using System.Text.Json
@model TourApp.CMS.Models.AudioBulkCreateViewModel
@{
    ViewData["Title"] = "Thêm Thuyết Minh Âm Thanh";
    var languages = ViewBag.Languages as List<TourApp.CMS.Models.LanguageOption> ?? new List<TourApp.CMS.Models.LanguageOption>();
}

<style>
    .translate-box {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        transition: border-color .2s;
    }
    .translate-box:focus-within { border-color: #4f46e5; }
    .translate-box .box-header {
        background: #f8fafc;
        padding: 10px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #e2e8f0;
        flex-wrap: wrap; gap: 6px;
    }
    .translate-box textarea {
        border: none !important;
        box-shadow: none !important;
        resize: none;
        font-size: 1rem;
        padding: 14px 16px;
        min-height: 130px;
        background: transparent;
    }
    .tab-option { cursor: pointer; padding: 6px 12px; border-radius: 8px; font-weight: 600; font-size:.85rem; transition:.2s; }
    .tab-option.active { background:#4f46e5; color:#fff; }
    .tab-option:not(.active):hover { background:#e0e7ff; color:#4f46e5; }
    .lang-badge {
        background:#e0e7ff; color:#4f46e5; padding:3px 10px;
        border-radius:20px; font-size:.78rem; font-weight:700;
    }
    #detectedLang { font-size:.78rem; color:#64748b; }
    .divider-row { display:flex; align-items:center; gap:10px; color:#94a3b8; font-size:.82rem; margin:8px 0; }
    .divider-row::before,.divider-row::after { content:''; flex:1; height:1px; background:#e2e8f0; }
</style>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-waveform-lines me-2 text-info"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" id="audioForm">

                    @* POI *@
                    <div class="mb-4">
                        <label asp-for="POIId" class="form-label fw-medium">Thuộc địa điểm (POI) <span class="text-danger">*</span></label>
                        <select asp-for="POIId" class="form-select" asp-items="@ViewBag.PoiList" required>
                            <option value="">-- Chọn Địa điểm cần gắn âm thanh --</option>
                        </select>
                    </div>

                    <div class="translate-box mb-3">
                        <div class="box-header">
                            <span class="fw-semibold text-secondary" style="font-size:.85rem">📤 Văn Bản Gốc</span>
                            <span id="detectedLang">Đang nhận diện...</span>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="speakSource()" title="Đọc thử văn bản gốc">🔊 Nghe thử</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="stopSpeech()" title="Dừng">⏹</button>
                            </div>
                        </div>
                        <textarea id="srcText" asp-for="SourceText" class="form-control" rows="4"
                                  placeholder="Gõ nội dung thuyết minh. Hệ thống sẽ tự dịch sang toàn bộ ngôn ngữ đã cấu hình..."
                                  oninput="handleSourceInput(this.value)"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bản dịch theo ngôn ngữ hiện có</label>
                        <div id="translatedPanels" class="row g-3">
                            @foreach (var lang in languages)
                            {
                                <div class="col-md-6">
                                    <div class="translate-box h-100">
                                        <div class="box-header">
                                            <span class="fw-semibold text-secondary">@lang.Name (@lang.Code)</span>
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-info" onclick="speakTarget('@lang.Code')" title="Nghe thử">🔊</button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="stopSpeech()" title="Dừng">⏹</button>
                                            </div>
                                        </div>
                                        <textarea id="dst-@lang.Code" name="Scripts[@lang.Code]" class="form-control" rows="4"
                                                  placeholder="Nội dung @lang.Name"></textarea>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="javascript:history.back()" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-info text-white px-4">
                            <i class="fa-solid fa-cloud-arrow-up me-1"></i> Lưu thuyết minh
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/cms-tts.js" asp-append-version="true"></script>
    <script>
        let synth = window.speechSynthesis;
        let currentUtterance = null;
        const languages = @Html.Raw(JsonSerializer.Serialize(languages));

        const langMap = Object.fromEntries(languages.map(l => [l.Code, l.Locale]));
        const langNames = Object.fromEntries(languages.map(l => [l.Code, `${l.Name} (${l.Code})`]));

        let translateTimer = null;
        let activeController = null;
        let requestVersion = 0;

        function detectLang(text) {
            if (!text.trim()) return 'vi';
            if (/[\u4e00-\u9fff]/.test(text)) return 'zh';
            if (/[\u3040-\u30ff]/.test(text)) return 'ja';
            if (/[\uac00-\ud7af]/.test(text)) return 'ko';
            if (/[àáâãèéêìíòóôõùúýăđơưạảấầẩẫậắằẳẵặẹẻẽếềểễệỉịọỏốồổỗộớờởỡợụủứừửữựỳỵỷỹ]/.test(text)) return 'vi';
            return 'en';
        }

        async function translateInto(targetCode, text, signal) {
            try {
                console.log(`[Translate] Calling API: target=${targetCode}, text="${text.substring(0, 30)}..."`);

                const url = `/api/translate?text=${encodeURIComponent(text)}&target=${targetCode}&source=auto`;
                const response = await fetch(url, { signal });

                console.log(`[Translate] Response status: ${response.status}, Content-Type: ${response.headers.get('content-type')}`);

                if (!response.ok) {
                    console.error(`[Translate] HTTP error: ${response.status}`);
                    return text;
                }

                const contentType = response.headers.get('content-type') || '';
                if (!contentType.includes('application/json')) {
                    const htmlPreview = await response.text();
                    console.error(`[Translate] Not JSON! Content-Type: ${contentType}`);
                    console.error(`[Translate] Response preview: ${htmlPreview.substring(0, 200)}`);
                    return text;
                }

                const data = await response.json();
                console.log('[Translate] Response data:', data);

                if (data && Array.isArray(data) && data[0] && Array.isArray(data[0]) && data[0].length > 0) {
                    const result = data[0].map(x => x[0]).join('');
                    console.log(`[Translate] Translated to ${targetCode}: "${result.substring(0, 30)}..."`);
                    return result;
                }

                console.warn('[Translate] Unexpected format:', data);
                return text;
            } catch (err) {
                if (err && err.name === 'AbortError') {
                    return null;
                }

                console.error('[Translate] Exception:', err);
                return text;
            }
        }

        function handleSourceInput(text) {
            clearTimeout(translateTimer);

            if (activeController) {
                activeController.abort('new-input');
                activeController = null;
            }

            translateTimer = setTimeout(() => translateAll(text), 350);
        }

        async function translateAll(text) {
            const src = (text || '').trim();

            if (!src) {
                document.getElementById('detectedLang').textContent = 'Đang nhận diện...';
                for (const lang of languages) {
                    const box = document.getElementById(`dst-${lang.Code}`);
                    if (box) box.value = '';
                }
                return;
            }

            const currentVersion = ++requestVersion;
            const detected = detectLang(src);

            document.getElementById('detectedLang').textContent = 'Phát hiện: ' + (langNames[detected] || detected);
            console.log(`[translateAll] Detected: ${detected}, Languages:`, languages.map(l => l.Code));

            activeController = new AbortController();
            const signal = activeController.signal;

            for (const lang of languages) {
                if (currentVersion !== requestVersion) return;

                const box = document.getElementById(`dst-${lang.Code}`);
                if (!box) continue;

                const langCode = (lang.Code || '').toLowerCase();
                const detectedCode = (detected || '').toLowerCase();

                if (langCode === detectedCode) {
                    console.log(`[translateAll] Skip ${lang.Code} (same as detected)`);
                    box.value = src;
                    continue;
                }

                console.log(`[translateAll] Translating to ${lang.Code}...`);

                try {
                    const translated = await translateInto(lang.Code, src, signal);

                    if (currentVersion !== requestVersion) return;
                    if (translated === null) continue;

                    box.value = translated;
                    console.log(`[translateAll] ${lang.Code} = "${translated.substring(0, 30)}..."`);
                } catch (err) {
                    if (err && err.name === 'AbortError') {
                        return;
                    }

                    console.error(`[translateAll] Error for ${lang.Code}:`, err);
                    box.value = src;
                }
            }
        }

        /* ===== SPEAK ===== */
        function speakSource() {
            const text = document.getElementById('srcText').value;
            if (!text) return;
            speak(text, 'vi-VN');
        }

        function speakTarget(langCode) {
            const text = document.getElementById(`dst-${langCode}`)?.value || '';
            if (!text) return;
            speak(text, langMap[langCode] || 'en-US');
        }

        function speak(text, lang) {
            stopSpeech();
            currentUtterance = new SpeechSynthesisUtterance(text);
            currentUtterance.lang = lang;
            currentUtterance.pitch = 1.08;
            currentUtterance.rate = 0.95;
            currentUtterance.voice = pickFemaleVoice(lang);
            synth.speak(currentUtterance);
        }

        function stopSpeech() {
            try {
                if (synth && typeof synth.cancel === 'function') {
                    synth.cancel();
                    console.log('[Speech] Stopped');
                }
            } catch (e) {
                console.error('[Speech] Error stopping:', e);
            }
        }

        function pickFemaleVoice(lang) {
            const l = (lang || '').toLowerCase();
            if (l.startsWith('vi')) {
                const vn = typeof cmsPickVietnameseFemaleVoice === 'function' ? cmsPickVietnameseFemaleVoice() : null;
                if (vn) return vn;
            }
            return typeof cmsPickTtsVoiceForLocale === 'function'
                ? cmsPickTtsVoiceForLocale(lang, lang.substring(0, 2))
                : null;
        }

        cmsWarmUpSpeechVoices();

        const poiIdsWithAudio = @Html.Raw(ViewBag.PoiIdsWithAudioJson ?? "[]");
        document.getElementById('audioForm').addEventListener('submit', function (e) {
            const sel = document.querySelector('select[name="POIId"]');
            if (!sel) return true;

            const id = parseInt(sel.value, 10);
            if (!id || !Array.isArray(poiIdsWithAudio) || poiIdsWithAudio.length === 0) return true;
            if (!poiIdsWithAudio.includes(id)) return true;

            if (!confirm('Địa điểm này đã có thuyết minh (nhiều ngôn ngữ). Lưu sẽ ghi đè toàn bộ. Bạn có muốn tiếp tục?')) {
                e.preventDefault();
                return false;
            }

            return true;
        });
    </script>
}

