@model TourApp.CMS.Models.Audio

@{
    ViewData["Title"] = "Tải lên Thuyết minh (Audio)";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-cloud-arrow-up me-2 text-info"></i> @ViewData["Title"]</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label asp-for="POIId" class="form-label fw-medium">Thuộc địa điểm (POI) <span class="text-danger">*</span></label>
                        <select asp-for="POIId" class="form-select" asp-items="@ViewBag.PoiList" required>
                            <option value="">-- Chọn Địa điểm cần gắn âm thanh --</option>
                        </select>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Language" class="form-label fw-medium">Ngôn ngữ <span class="text-danger">*</span></label>
                            <select asp-for="Language" class="form-select" required>
                                <option value="vi" selected>Tiếng Việt (vi)</option>
                                <option value="en">Tiếng Anh (en)</option>
                                <option value="fr">Tiếng Pháp (fr)</option>
                                <option value="ko">Tiếng Hàn (ko)</option>
                                <option value="ja">Tiếng Nhật (ja)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Duration" class="form-label fw-medium">Thời lượng (giây)</label>
                            <input asp-for="Duration" type="number" class="form-control" placeholder="120" value="0" />
                            <small class="text-muted">Mang tính chất tham khảo cho UI Mobile.</small>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium text-info">File âm thanh (.mp3, .wav) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="file" name="uploadAudio" class="form-control border-info" accept="audio/*" required />
                        </div>
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState["uploadAudio"] != null)
                        {
                            <div class="text-danger small mt-1">@ViewData.ModelState["uploadAudio"]?.Errors.FirstOrDefault()?.ErrorMessage</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label asp-for="ScriptText" class="form-label fw-medium">Kịch bản chữ (Subtitle - Không bắt buộc)</label>
                        <textarea asp-for="ScriptText" class="form-control" rows="3" placeholder="Xin chào các bạn, chào mừng đến với..."></textarea>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                            <label class="form-check-label" asp-for="IsActive">Kích hoạt trình phát</label>
                        </div>
                    </div>
                    
                    <hr />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="javascript:history.back()" class="btn btn-light border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-info text-white"><i class="fa-solid fa-save me-1"></i> Tải lên server</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
