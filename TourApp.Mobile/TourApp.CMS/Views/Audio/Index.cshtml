@model IEnumerable<TourApp.CMS.Models.Audio>

@{
    ViewData["Title"] = "Quản lý Thuyết minh (Audio)";
    var poisDict = ViewBag.POIs as Dictionary<int, string> ?? new Dictionary<int, string>();
    var currentPoiId = ViewBag.CurrentPoiId as int?;
    var languageColumns = ViewBag.LanguageColumns as List<TourApp.CMS.Models.LanguageOption> ?? new List<TourApp.CMS.Models.LanguageOption>();
    var grouped = (Model ?? Enumerable.Empty<TourApp.CMS.Models.Audio>())
        .GroupBy(x => x.POIId)
        .OrderBy(g => g.Key)
        .ToList();
    var rowNo = 0;
}

<div class="card border-0 mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            <i class="fa-solid fa-headphones me-2 text-info"></i> Danh sách Audio
            @if(currentPoiId.HasValue && poisDict.ContainsKey(currentPoiId.Value))
            {
                <span class="text-muted fs-6 ms-2">/ Điểm: @poisDict[currentPoiId.Value]</span>
            }
        </h5>
        <div>
            @if(currentPoiId.HasValue)
            {
                <a asp-action="Index" asp-controller="POI" class="btn btn-outline-secondary me-2">
                    <i class="fa-solid fa-arrow-left"></i> Về danh sách POI
                </a>
            }
            <a asp-action="Create" asp-route-poiId="@currentPoiId" class="btn btn-info text-white d-inline-flex align-items-center">
                <i class="fa-solid fa-cloud-arrow-up me-2"></i> Thêm Audio mới
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:48px">#</th>
                        <th>ID</th>
                        <th>Địa điểm (POI)</th>
                        @foreach (var lang in languageColumns)
                        {
                            <th>@lang.Name</th>
                        }
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (grouped.Any())
                    {
                        foreach (var poiGroup in grouped)
                        {
                            rowNo++;
                            var poiAudios = poiGroup.ToList();
                            <tr>
                                <td class="text-center text-muted">@rowNo</td>
                                <td><span class="badge bg-secondary">#@poiGroup.Key</span></td>
                                <td class="fw-medium">
                                    @(poisDict.ContainsKey(poiGroup.Key) ? poisDict[poiGroup.Key] : $"POI ID: {poiGroup.Key}")
                                </td>
                                @foreach (var lang in languageColumns)
                                {
                                    var audio = poiAudios.FirstOrDefault(a => a.Language.Equals(lang.Code, StringComparison.OrdinalIgnoreCase));
                                    <td>
                                        @if (audio != null)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-info mb-2"
                                                    data-text="@audio.ScriptText"
                                                    data-locale="@lang.Locale"
                                                    onclick="speakScriptFromButton(this)">
                                                🔊 Nghe thử
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">--</span>
                                        }
                                    </td>
                                }
                                <td class="text-end">
                                    <a asp-action="EditByPoi" asp-route-poiId="@poiGroup.Key" class="btn btn-sm btn-outline-primary">
                                        <i class="fa-solid fa-pen"></i> Sửa
                                    </a>
                                    <a asp-action="DeleteByPoi" asp-route-poiId="@poiGroup.Key" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Xóa toàn bộ thuyết minh của địa điểm này?');">
                                        <i class="fa-solid fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(4 + languageColumns.Count)" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-music fs-1 mb-3 text-light"></i><br />
                                Chưa có dữ liệu thuyết minh
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
const synth = window.speechSynthesis;

function pickFemaleVoice(lang) {
    const voices = synth.getVoices();
    if (!voices || voices.length === 0) return null;
    const femaleHints = ['female', 'woman', 'zira', 'hanh', 'linh', 'mai', 'nu'];
    return voices.find(v => v.lang?.toLowerCase().startsWith(lang.slice(0, 2).toLowerCase()) && femaleHints.some(k => v.name.toLowerCase().includes(k)))
        || voices.find(v => v.lang?.toLowerCase().startsWith(lang.slice(0, 2).toLowerCase()))
        || null;
}

function speakScriptFromButton(btn) {
    const text = btn.getAttribute('data-text') || '';
    const locale = btn.getAttribute('data-locale') || 'en-US';
    if (!text) return;
    synth.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = locale;
    utter.pitch = 1.08;
    utter.rate = 0.95;
    utter.voice = pickFemaleVoice(utter.lang);
    synth.speak(utter);
}
</script>
}
