@model IEnumerable<TourApp.CMS.Models.Audio>

@{
    ViewData["Title"] = "Quản lý Thuyết minh (Audio)";
    var poisDict = ViewBag.POIs as Dictionary<int, string> ?? new Dictionary<int, string>();
    var catalogMap = ViewBag.PoiCatalogMap as Dictionary<int, int> ?? new Dictionary<int, int>();
    var currentPoiId = ViewBag.CurrentPoiId as int?;
    var languageColumns = ViewBag.LanguageColumns as List<TourApp.CMS.Models.LanguageOption> ?? new List<TourApp.CMS.Models.LanguageOption>();
    var grouped = (Model ?? Enumerable.Empty<TourApp.CMS.Models.Audio>())
        .GroupBy(x => x.POIId)
        .OrderBy(g => catalogMap.TryGetValue(g.Key, out var n) ? n : g.Key)
        .ToList();
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var rowNo = (currentPage - 1) * 10;
    var cmsRole = Context.Session.GetString("Role") ?? "";
    var isAudioAdmin = cmsRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="card border-0 mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            <i class="fa-solid fa-headphones me-2 text-info"></i> Danh sách Audio
            @if(currentPoiId.HasValue && poisDict.ContainsKey(currentPoiId.Value))
            {
                <span class="text-muted fs-6 ms-2">/ Điểm: @poisDict[currentPoiId.Value]</span>
            }
        </h5>
        <div>
            @if(currentPoiId.HasValue)
            {
                <a asp-action="Index" asp-controller="POI" class="btn btn-outline-secondary me-2">
                    <i class="fa-solid fa-arrow-left"></i> Về danh sách POI
                </a>
            }
            @if (!isAudioAdmin)
            {
            <a asp-action="Create" asp-route-poiId="@currentPoiId" class="btn btn-info text-white d-inline-flex align-items-center">
                <i class="fa-solid fa-cloud-arrow-up me-2"></i> Thêm Audio mới
            </a>
            }
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:48px">#</th>
                        <th>ID</th>
                        <th>Địa điểm (POI)</th>
                        @foreach (var lang in languageColumns)
                        {
                            <th>@lang.Name</th>
                        }
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (grouped.Any())
                    {
                        foreach (var poiGroup in grouped)
                        {
                            rowNo++;
                            var poiAudios = poiGroup.ToList();
                            var aNum = catalogMap.TryGetValue(poiGroup.Key, out var cn) ? cn : poiGroup.Key;
                            <tr>
                                <td class="text-center text-muted">@rowNo</td>
                                <td><span class="badge bg-secondary">#A@(aNum)</span></td>
                                <td class="fw-medium">
                                    @(poisDict.ContainsKey(poiGroup.Key) ? poisDict[poiGroup.Key] : $"POI ID: {poiGroup.Key}")
                                </td>
                                @foreach (var lang in languageColumns)
                                {
                                    var audio = poiAudios.FirstOrDefault(a => a.Language.Equals(lang.Code, StringComparison.OrdinalIgnoreCase));
                                    <td>
                                        @if (audio != null)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-info mb-2"
                                                    data-text="@audio.ScriptText"
                                                    data-locale="@lang.Locale"
                                                    data-lang-code="@lang.Code"
                                                    onclick="speakScriptFromButton(this)">
                                                🔊 Nghe thử
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">--</span>
                                        }
                                    </td>
                                }
                                <td class="text-end">
                                    <a asp-action="EditByPoi" asp-route-poiId="@poiGroup.Key" class="btn btn-sm btn-outline-primary">
                                        <i class="fa-solid fa-pen"></i> Sửa
                                    </a>
                                    <a asp-action="DeleteByPoi" asp-route-poiId="@poiGroup.Key" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Xóa toàn bộ thuyết minh của địa điểm này?');">
                                        <i class="fa-solid fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(4 + languageColumns.Count)" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-music fs-1 mb-3 text-light"></i><br />
                                Chưa có dữ liệu thuyết minh
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (totalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-center flex-wrap gap-1">
            @for (var p = 1; p <= totalPages; p++)
            {
                <a class="btn btn-sm @(p == currentPage ? "btn-primary" : "btn-outline-secondary")" asp-action="Index" asp-route-page="@p" asp-route-poiId="@currentPoiId">@p</a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
const synth = window.speechSynthesis;

function pickVoiceForLocale(locale, langCode) {
    const voices = synth.getVoices();
    if (!voices || voices.length === 0) return null;
    const loc = (locale || 'en-US').toLowerCase();
    const shortLang = (langCode || loc.slice(0, 2)).toLowerCase();
    const sameLang = voices.filter(v => (v.lang || '').toLowerCase().startsWith(shortLang));
    if (shortLang === 'vi') {
        const preferFemale = (v) => {
            const n = (v.name || '').toLowerCase();
            return /female|nữ|hoai|my|lan|mai|linh|minh|google.*vi|microsoft.*vi/i.test(n) && !/^microsoft.*nam\b/i.test(n);
        };
        return sameLang.find(preferFemale)
            || sameLang.find(v => !/(male|nam nghiêm|nam minh)\b/i.test(v.name))
            || sameLang[0]
            || null;
    }
    const femaleHints = ['female', 'woman', 'zira'];
    return sameLang.find(v => femaleHints.some(k => v.name.toLowerCase().includes(k)))
        || sameLang[0]
        || null;
}

function speakScriptFromButton(btn) {
    const text = btn.getAttribute('data-text') || '';
    let locale = btn.getAttribute('data-locale') || 'en-US';
    const langCode = btn.getAttribute('data-lang-code') || '';
    if (!text) return;
    if (langCode === 'vi') locale = 'vi-VN';
    synth.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = locale;
    utter.pitch = langCode === 'vi' ? 1.05 : 1.08;
    utter.rate = langCode === 'vi' ? 0.92 : 0.95;
    const v = pickVoiceForLocale(locale, langCode);
    if (v) utter.voice = v;
    synth.speak(utter);
}

if (typeof speechSynthesis !== 'undefined' && speechSynthesis.onvoiceschanged !== undefined) {
    speechSynthesis.onvoiceschanged = function () { /* warm-up voice list */ speechSynthesis.getVoices(); };
}
</script>
}
