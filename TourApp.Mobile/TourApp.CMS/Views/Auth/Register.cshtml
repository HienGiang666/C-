@model TourApp.CMS.Models.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TourApp Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary-color: #3498db;
            --sidebar-bg: #2c3e50;
        }

        body {
            background: linear-gradient(135deg, var(--sidebar-bg) 0%, var(--primary-color) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px 0;
        }

        .register-container {
            width: 100%;
            max-width: 500px;
        }

        .register-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        .register-header {
            background: linear-gradient(135deg, var(--sidebar-bg) 0%, var(--primary-color) 100%);
            color: white;
            padding: 30px 20px;
            text-align: center;
        }

        .register-header i {
            font-size: 40px;
            margin-bottom: 10px;
            display: block;
        }

        .register-header h1 {
            font-size: 24px;
            font-weight: bold;
            margin: 0;
            margin-bottom: 5px;
        }

        .register-body {
            padding: 40px;
            background: white;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-label {
            font-weight: 600;
            color: var(--sidebar-bg);
            margin-bottom: 6px;
            display: block;
            font-size: 14px;
        }

        .form-control {
            border: 2px solid #ecf0f1;
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
        }

        .btn-register {
            width: 100%;
            padding: 11px;
            background: linear-gradient(135deg, var(--sidebar-bg) 0%, var(--primary-color) 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(52, 152, 219, 0.4);
            color: white;
        }

        .register-footer {
            text-align: center;
            padding: 15px;
            background: #f8f9fa;
            border-top: 1px solid #ecf0f1;
        }

        .register-footer p {
            margin: 0;
            color: #7f8c8d;
            font-size: 13px;
        }

        .register-footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
        }

        .register-footer a:hover {
            text-decoration: underline;
        }

        .alert {
            border-radius: 8px;
            border: none;
            margin-bottom: 15px;
            font-size: 13px;
        }

        .error-message {
            color: #e74c3c;
            font-size: 12px;
            margin-top: 3px;
            display: block;
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="register-header">
                <i class="fas fa-user-plus"></i>
                <h1>Tạo tài khoản mới</h1>
            </div>

            <div class="register-body">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form asp-action="Register" method="post">
                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">
                            <i class="fas fa-user"></i> Họ và tên
                        </label>
                        <input asp-for="FullName" class="form-control" 
                               placeholder="Nhập họ tên đầy đủ" required />
                        <span asp-validation-for="FullName" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">
                            <i class="fas fa-envelope"></i> Email
                        </label>
                        <input asp-for="Email" type="email" class="form-control" 
                               placeholder="Nhập email" required />
                        <span asp-validation-for="Email" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Username" class="form-label">
                            <i class="fas fa-at"></i> Tên đăng nhập
                        </label>
                        <input asp-for="Username" class="form-control" 
                               placeholder="Nhập tên đăng nhập" required />
                        <span asp-validation-for="Username" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="form-label">
                            <i class="fas fa-lock"></i> Mật khẩu
                        </label>
                        <input asp-for="Password" type="password" class="form-control" 
                               placeholder="Nhập mật khẩu (tối thiểu 6 ký tự)" required />
                        <span asp-validation-for="Password" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">
                            <i class="fas fa-lock"></i> Xác nhận mật khẩu
                        </label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" 
                               placeholder="Nhập lại mật khẩu" required />
                        <span asp-validation-for="ConfirmPassword" class="error-message"></span>
                    </div>

                    <button type="submit" class="btn btn-register">
                        <i class="fas fa-user-check"></i> Đăng ký
                    </button>
                </form>
            </div>

            <div class="register-footer">
                <p>
                    Đã có tài khoản? <a asp-action="Login">Đăng nhập tại đây</a>
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
