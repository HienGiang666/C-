@model TourApp.CMS.Models.AdminUser

@{
    ViewData["Title"] = "Hồ sơ Quản trị viên";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="row g-4">
            <!-- Avatar Card -->
            <div class="col-md-4">
                <div class="card border-0 text-center">
                    <div class="card-body py-5">
                        <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=4f46e5&color=fff&size=120&bold=true" class="rounded-circle shadow mb-3" width="120" height="120" />
                        <h4 class="fw-bold mb-1">@Model.FullName</h4>
                        <p class="text-muted mb-2">@@@Model.Username</p>
                        @if(Model.Role == "Admin") {
                            <span class="badge bg-danger px-3 py-2"><i class="fa-solid fa-shield-halved me-1"></i> Admin</span>
                        } else {
                            <span class="badge bg-info px-3 py-2"><i class="fa-solid fa-id-badge me-1"></i> @Model.Role</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Info Card -->
            <div class="col-md-8">
                <div class="card border-0">
                    <div class="card-header bg-white">
                        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-address-card text-primary me-2"></i> Thông tin tài khoản</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row mb-3 pb-3 border-bottom">
                            <div class="col-sm-4 text-muted">Email:</div>
                            <div class="col-sm-8"><i class="fa-regular fa-envelope me-2 text-muted"></i> @Model.Email</div>
                        </div>
                        <div class="row mb-3 pb-3 border-bottom">
                            <div class="col-sm-4 text-muted">Tên đăng nhập:</div>
                            <div class="col-sm-8"><code>@Model.Username</code></div>
                        </div>
                        <div class="row mb-3 pb-3 border-bottom">
                            <div class="col-sm-4 text-muted">Trạng thái:</div>
                            <div class="col-sm-8">
                                @if(Model.IsActive) {
                                    <span class="badge bg-success bg-opacity-10 text-success"><i class="fa-solid fa-check-circle me-1"></i> Đang hoạt động</span>
                                } else {
                                    <span class="badge bg-danger bg-opacity-10 text-danger"><i class="fa-solid fa-ban me-1"></i> Đã khóa</span>
                                }
                            </div>
                        </div>
                        <div class="row mb-3 pb-3 border-bottom">
                            <div class="col-sm-4 text-muted">Ngày tạo:</div>
                            <div class="col-sm-8"><i class="fa-regular fa-calendar-days me-2 text-primary"></i> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 text-muted">Đăng nhập lần cuối:</div>
                            <div class="col-sm-8">
                                @if(Model.LastLogin.HasValue) {
                                    <i class="fa-regular fa-clock me-2 text-success"></i> @Model.LastLogin.Value.ToString("dd/MM/yyyy HH:mm")
                                } else {
                                    <span class="text-muted">Chưa ghi nhận</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-3 text-end">
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger"><i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất</a>
                </div>
            </div>
        </div>
    </div>
</div>
