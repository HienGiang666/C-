@model TourApp.CMS.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - TourApp Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.25);
            overflow: hidden;
            width: 100%;
            max-width: 440px;
        }
        .login-header {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            padding: 2.5rem 2rem;
            text-align: center;
            color: white;
        }
        .login-header h2 { margin: 0; font-weight: 700; }
        .login-header p { margin: 0.5rem 0 0; opacity: 0.85; }
        .login-body { padding: 2rem; }
        .form-control:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.15);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <i class="fa-solid fa-earth-americas fs-1 mb-3"></i>
            <h2>TourApp Admin</h2>
            <p>Đăng nhập vào hệ thống quản trị</p>
        </div>
        <div class="login-body">
            @if (TempData["success"] != null)
            {
                <div class="alert alert-success border-0 rounded-3 py-2">
                    <i class="fa-solid fa-circle-check me-1"></i> @TempData["success"]
                </div>
            }

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-medium">Tài khoản</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fa-regular fa-user text-muted"></i></span>
                        <input asp-for="Username" class="form-control border-start-0 ps-0" placeholder="Nhập tên đăng nhập..." autofocus required />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-medium">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="Nhập mật khẩu..." required />
                    </div>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted">Ghi nhớ phiên đăng nhập</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-3" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);border:none">
                    <i class="fa-solid fa-arrow-right-to-bracket me-2"></i> Đăng nhập
                </button>

                <div class="text-center">
                    <span class="text-muted">Chưa có tài khoản?</span>
                    <a asp-action="Register" class="text-decoration-none fw-medium"> Đăng ký ngay</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
