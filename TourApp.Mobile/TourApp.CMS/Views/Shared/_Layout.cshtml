<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TourApp Admin</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Custom Admin Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-dark text-white shadow-sm" id="sidebar-wrapper" style="position: sticky; top: 0; height: 100vh; overflow-y: auto;">
            <div class="sidebar-heading text-center py-4 fs-4 fw-bold border-bottom border-secondary text-uppercase tracking-wider">
                <i class="fa-solid fa-earth-americas me-2 text-primary"></i>Tour Admin
            </div>
            <div class="list-group list-group-flush mt-3 px-2">
                <a asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-gauge me-3 fs-5 width-20"></i> Dashboard
                </a>
                <a asp-controller="POI" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-map-location-dot me-3 fs-5 width-20"></i> Quản lý Địa điểm
                </a>
                <a asp-controller="Audio" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-headphones me-3 fs-5 width-20"></i> Thuyết minh (Audio)
                </a>
                <a asp-controller="Tour" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-suitcase-rolling me-3 fs-5 width-20"></i> Quản lý Tour
                </a>
                <a asp-controller="Booking" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-ticket ms-0 me-3 fs-5 width-20"></i> Quản lý Booking
                </a>
                <a asp-controller="User" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-users me-3 fs-5 width-20"></i> Thành viên
                </a>
                <a asp-controller="Activity" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded mb-1 btn-sidebar">
                    <i class="fa-solid fa-clipboard-list me-3 fs-5 width-20"></i> Lịch sử hoạt động
                </a>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100 p-0">
            <!-- Top Navigation -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 shadow-sm mb-4 px-4 sticky-top">
                <div class="d-flex align-items-center">
                    <i class="fa-solid fa-bars fs-4 text-secondary me-3 cursor-pointer" id="menu-toggle"></i>
                    <h5 class="m-0 fw-bold text-dark">@ViewData["Title"]</h5>
                </div>
                
                <div class="ms-auto d-flex align-items-center">
                    <!-- User Profile Dropdown -->
                    @if (Context.Session.GetString("UserId") != null)
                    {
                        <div class="dropdown">
                            <a class="text-decoration-none dropdown-toggle text-dark fw-medium d-flex align-items-center" href="#" role="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="https://ui-avatars.com/api/?name=@(Context.Session.GetString("FullName") ?? "Admin")&background=random&color=fff&rounded=true" width="35" height="35" class="me-2 shadow-sm rounded-circle" />
                                <span>@Context.Session.GetString("FullName")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 rounded-3" aria-labelledby="userDropdown">
                                <li><h6 class="dropdown-header text-uppercase text-muted">@Context.Session.GetString("Role")</h6></li>
                                <li><a class="dropdown-item py-2" asp-controller="Auth" asp-action="Profile"><i class="fa-regular fa-user me-2"></i> Hồ sơ cá nhân</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="Logout"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="fa-solid fa-user me-2"></i> Đăng nhập</a>
                    }
                </div>
            </nav>

            <!-- Main Container -->
            <div class="container-fluid px-4 pb-5 content-area">
                
                @if (TempData["success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> <strong>Thành công!</strong> @TempData["success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                
                @if (TempData["error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> <strong>Lỗi!</strong> @TempData["error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
                
            </div>
            
            <footer class="text-center py-4 text-muted border-top bg-white mt-auto">
                <small>&copy; 2026 TourApp Admin Dashboard. Developed with <i class="fa-solid fa-heart text-danger mx-1"></i> by You.</small>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Toggle Sidebar Script
        $("#menu-toggle").click(function(e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });
        
        // Active Link Script based on URL
        $(document).ready(function() {
            var currentUrl = window.location.pathname;
            $('.list-group-item').each(function() {
                if($(this).attr('href') === currentUrl) {
                    $(this).removeClass('bg-transparent text-white').addClass('active bg-primary text-whitefw-bold shadow-sm');
                }
            });
            if(currentUrl === "/") {
               $('.list-group-item').first().removeClass('bg-transparent text-white').addClass('active bg-primary text-white fw-bold shadow-sm');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
