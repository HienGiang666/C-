<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TourApp.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TourApp.Mobile.Views"
    Title="Tour Quận 4">

    <!-- Shell hosts the authenticated app tabs only -->

    <TabBar>
        <!-- Home Tab -->
        <Tab Title="Home" Icon="ic_home.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="HomePage" />
        </Tab>
        
        <!-- Quán Ăn Tab -->
        <Tab Title="Quán Ăn" Icon="ic_food.png">
            <ShellContent ContentTemplate="{DataTemplate views:POIPage}" Route="POIPage" />
        </Tab>

        <!-- Map Tab -->
        <Tab Title="Map" Icon="ic_map.png">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" Route="MapPage" />
        </Tab>

        <!-- Tour Tab -->
        <Tab Title="Tour" Icon="ic_tour.png">
            <ShellContent ContentTemplate="{DataTemplate views:TourPage}" Route="TourPage" />
        </Tab>

        <!-- Profile Tab -->
        <Tab Title="Tôi" Icon="ic_profile.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>
