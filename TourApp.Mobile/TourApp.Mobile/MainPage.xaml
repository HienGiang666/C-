<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.MainPage"
             BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Header -->
            <VerticalStackLayout Padding="0,10,0,10">
                <Label Text="Xin chào," FontSize="14" TextColor="#64748B" />
                <Label Text="Khám phá Sài Gòn" FontSize="22" FontAttributes="Bold" TextColor="#1E293B" />
            </VerticalStackLayout>

            <!-- Search Bar -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#FFFFFF" Padding="15,0">
                <Entry Placeholder="Tìm kiếm địa điểm, tour..." PlaceholderColor="#94A3B8" TextColor="#333" />
            </Border>

            <!-- Featured Tours - TEXT ONLY (no network images to avoid ANR) -->
            <Label Text="Tour Nổi Bật" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="0,10,0,0"/>

            <Border BackgroundColor="#4F46E5" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                <VerticalStackLayout>
                    <Label Text="🍽️ Phố Ẩm Thực Vĩnh Khánh" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Trải nghiệm ăn đêm Quận 4" FontSize="13" TextColor="#C7D2FE" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#0EA5E9" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                <VerticalStackLayout>
                    <Label Text="🏛️ Trung tâm Di Tích Lịch Sử" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Chợ Bến Thành, Nhà thờ Đức Bà" FontSize="13" TextColor="#BAE6FD" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Categories -->
            <Label Text="Khám phá theo danh mục" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="0,10,0,0"/>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Grid.Column="0" BackgroundColor="#E0E7FF" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15,12">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="🍲" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Ẩm thực" FontSize="12" TextColor="#4338CA" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15,12">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="🏛" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Di tích" FontSize="12" TextColor="#B45309" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" BackgroundColor="#D1FAE5" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15,12">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="🎨" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Văn hoá" FontSize="12" TextColor="#047857" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Go to Map -->
            <Button Text="Đến Bản Đồ Tour  🗺"
                    BackgroundColor="#4F46E5"
                    TextColor="White"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Margin="0,20,0,20"
                    Clicked="OnGoToMapClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>