<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.PaymentPage"
             Title="{Binding [PaymentTitle], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0F7F4" Offset="0.0"/>
            <GradientStop Color="#FFF8F0" Offset="0.5"/>
            <GradientStop Color="#EEF2F7" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <!-- Header -->
            <Label Text="{Binding [PaymentHeader], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#1A1D26"
                   HorizontalOptions="Center"/>

            <Label Text="{Binding [PaymentSubtitle], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   FontSize="14"
                   TextColor="#6B7588"
                   HorizontalOptions="Center"/>

            <!-- Booking Summary -->
            <Border StrokeThickness="0" BackgroundColor="White" Padding="18" StrokeShape="RoundRectangle 14">
                <Border.Shadow>
                    <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding [BookingInfoTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#A0A8B8"/>
                    <Label x:Name="TourNameLabel" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <Label Text="{Binding [BookingCodeLabel], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#6B7588"/>
                        <Label x:Name="BookingCodeLabel" Grid.Column="1" FontSize="13" FontAttributes="Bold" TextColor="#1A1D26"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding [NumberOfPeopleLabel], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#6B7588"/>
                        <Label x:Name="ParticipantsLabel" Grid.Column="1" FontSize="13" TextColor="#1A1D26"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <Label Text="{Binding [TotalPaymentLabel], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="15" FontAttributes="Bold" TextColor="#1A1D26"/>
                        <Label x:Name="TotalPriceLabel" Grid.Column="1" FontSize="18" FontAttributes="Bold" TextColor="#00B14F"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- QR Code Display -->
            <Border StrokeThickness="0" BackgroundColor="White" Padding="24" StrokeShape="RoundRectangle 14"
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#000" Offset="0,4" Radius="12" Opacity="0.1"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="{Binding [QRCodeTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center"/>

                    <!-- QR Image -->
                    <Image x:Name="QrCodeImage" WidthRequest="200" HeightRequest="200" Aspect="AspectFit"/>

                    <Label Text="{Binding [QRCodeInstruction], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="12"
                           TextColor="#A0A8B8"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Timer -->
            <Label x:Name="TimerLabel"
                   Text="{Binding [QRCodeExpiry], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   FontSize="13"
                   TextColor="#FF6B35"
                   HorizontalOptions="Center"/>

            <!-- Payment Methods -->
            <Border StrokeThickness="0" BackgroundColor="White" Padding="16" StrokeShape="RoundRectangle 14">
                <Border.Shadow>
                    <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding [PaymentMethods], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="15" FontAttributes="Bold" TextColor="#1A1D26"/>

                    <Button x:Name="VnPayButton"
                            Text="{Binding [PayWithVNPay], Source={x:Static services:LocalizationResourceManager.Instance}}"
                            BackgroundColor="#0055A4"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnVnPayClicked"/>

                    <Button x:Name="MomoButton"
                            Text="{Binding [PayWithMomo], Source={x:Static services:LocalizationResourceManager.Instance}}"
                            BackgroundColor="#D82D8B"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnMomoClicked"/>

                    <Button x:Name="PayPalButton"
                            Text="{Binding [PayWithPayPal], Source={x:Static services:LocalizationResourceManager.Instance}}"
                            BackgroundColor="#003087"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnPayPalClicked"/>

                </VerticalStackLayout>
            </Border>

            <!-- Cancel Button -->
            <Button Text="{Binding [CancelPayment], Source={x:Static services:LocalizationResourceManager.Instance}}"
                    BackgroundColor="Transparent"
                    TextColor="#6B7588"
                    BorderColor="#E4E7ED"
                    BorderWidth="1"
                    CornerRadius="12"
                    HeightRequest="48"
                    Clicked="OnCancelClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
