<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TourApp.Mobile.Models"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.TourDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <!-- Page layout: scrollable content + sticky bottom bar -->
    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ===== HERO IMAGE WITH GRADIENT OVERLAY ===== -->
                <Grid HeightRequest="320">
                    <Image x:Name="TourImage"
                           Aspect="AspectFill"
                           HeightRequest="320" />

                    <!-- Dark gradient overlay for title readability -->
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.0" />
                                <GradientStop Color="#00000020" Offset="0.5" />
                                <GradientStop Color="#000000AA" Offset="1.0" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Back button -->
                    <Button Text="{x:Static helpers:IconFont.ArrowLeft}"
                            FontFamily="MaterialIcons"
                            FontSize="24"
                            TextColor="White"
                            BackgroundColor="#00000099"
                            CornerRadius="22"
                            WidthRequest="44"
                            HeightRequest="44"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="16,16,0,0"
                            Padding="0"
                            Clicked="OnBackClicked" />

                    <!-- Tour title on image -->
                    <VerticalStackLayout VerticalOptions="End"
                                         Padding="20,0,20,20"
                                         Spacing="6">
                        <Label x:Name="TourNameLabel"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               LineBreakMode="WordWrap"
                               MaxLines="2" />
                    </VerticalStackLayout>
                </Grid>

                <!-- ===== PRICE & INFO HIGHLIGHT ===== -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="16">
                    <!-- Price -->
                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{x:Static helpers:IconFont.CashMultiple}"
                               FontFamily="MaterialIcons"
                               FontSize="22"
                               TextColor="#00B14F"
                               VerticalOptions="Center" />
                        <Label x:Name="PriceLabel"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#00B14F"
                               VerticalOptions="Center" />
                        <Label x:Name="PerPersonLabel"
                               Text="{Binding [PerPerson], Source={x:Static services:LocalizationResourceManager.Instance}}"
                               FontSize="14"
                               TextColor="#9AA0A6"
                               VerticalOptions="End"
                               Margin="0,0,0,4" />
                    </HorizontalStackLayout>

                    <!-- Duration & Max People row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <!-- Duration -->
                        <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                            <Border WidthRequest="36"
                                    HeightRequest="36"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF3E0"
                                    StrokeShape="RoundRectangle 10">
                                <Label Text="{x:Static helpers:IconFont.ClockOutline}"
                                       FontFamily="MaterialIcons"
                                       FontSize="18"
                                       TextColor="#FF6B00"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                                <Label Text="{Binding [Duration], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                       FontSize="11"
                                       TextColor="#9AA0A6" />
                                <Label x:Name="DurationLabel"
                                       FontSize="14"
                                       TextColor="#1A1D26"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!-- Max People -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <Border WidthRequest="36"
                                    HeightRequest="36"
                                    StrokeThickness="0"
                                    BackgroundColor="#E8F0FE"
                                    StrokeShape="RoundRectangle 10">
                                <Label Text="{x:Static helpers:IconFont.AccountGroup}"
                                       FontFamily="MaterialIcons"
                                       FontSize="18"
                                       TextColor="#007AFF"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                                <Label Text="{Binding [MaxPeopleLabel], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                       FontSize="11"
                                       TextColor="#9AA0A6" />
                                <Label x:Name="ParticipantsLabel"
                                       FontSize="14"
                                       TextColor="#1A1D26"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Grid>
                </VerticalStackLayout>

                <!-- ===== DIVIDER ===== -->
                <BoxView HeightRequest="1" BackgroundColor="#F0F2F5" Margin="20,16,20,0" />

                <!-- ===== DESCRIPTION ===== -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="12">
                    <Label Text="{Binding [Introduction], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1A1D26" />
                    <Label x:Name="TourDescriptionLabel"
                           FontSize="15"
                           TextColor="#4A5568"
                           LineBreakMode="WordWrap"
                           LineHeight="1.6" />
                </VerticalStackLayout>

                <!-- ===== DIVIDER ===== -->
                <BoxView HeightRequest="1" BackgroundColor="#F0F2F5" Margin="20,24,20,0" />

                <!-- ===== DESTINATIONS (TIMELINE STYLE) ===== -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="12">
                    <Label Text="{Binding [Destinations], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1A1D26" />

                    <CollectionView x:Name="StopsCollectionView">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TourPOI">
                                <Grid ColumnDefinitions="48,*" Padding="0,0,0,16">
                                    <!-- Timeline dot + line -->
                                    <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                        <Ellipse Grid.Row="0"
                                                 WidthRequest="28"
                                                 HeightRequest="28"
                                                 Fill="#00B14F"
                                                 VerticalOptions="Start"
                                                 HorizontalOptions="Center" />
                                        <Label Text="{Binding OrderIndex}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Start"
                                               Margin="0,6,0,0" />
                                        <!-- Connector line -->
                                        <BoxView Grid.Row="1"
                                                 WidthRequest="2"
                                                 BackgroundColor="#E2E8F0"
                                                 VerticalOptions="Fill"
                                                 HorizontalOptions="Center"
                                                 Margin="0,4,0,0" />
                                    </Grid>

                                    <!-- Stop info card -->
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="#F8FAFC"
                                            Padding="14"
                                            StrokeShape="RoundRectangle 12"
                                            VerticalOptions="Start">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding POI.Name}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#1A1D26" />
                                            <Label Text="{Binding POI.Address}"
                                                   FontSize="13"
                                                   TextColor="#6B7588"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ===== DIVIDER ===== -->
                <BoxView HeightRequest="1" BackgroundColor="#F0F2F5" Margin="20,8,20,0" />

                <!-- ===== DOWNLOAD AUDIO (DE-EMPHASIZED) ===== -->
                <HorizontalStackLayout Padding="20,16,20,0"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="{x:Static helpers:IconFont.Download}"
                           FontFamily="MaterialIcons"
                           FontSize="18"
                           TextColor="#9AA0A6" />
                    <Label Text="{Binding [DownloadOfflineAudio], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="14"
                           TextColor="#9AA0A6"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDownloadAudioClicked" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Spacer to ensure scrollable content clears bottom bar -->
                <BoxView HeightRequest="100" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== STICKY BOTTOM BAR ===== -->
        <Border Grid.Row="1"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="20,12,20,20">
            <Border.Shadow>
                <Shadow Brush="#000" Offset="0,-4" Radius="16" Opacity="0.08" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="{Binding [Route], Source={x:Static services:LocalizationResourceManager.Instance}}"
                        BackgroundColor="White"
                        TextColor="#00B14F"
                        BorderColor="#00B14F"
                        BorderWidth="1.5"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="12"
                        HeightRequest="50"
                        Clicked="OnViewMapClicked" />
                <Button Grid.Column="1"
                        Text="{Binding [BookTour], Source={x:Static services:LocalizationResourceManager.Instance}}"
                        BackgroundColor="#00B14F"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="12"
                        HeightRequest="50"
                        Clicked="OnBookTourClicked" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
