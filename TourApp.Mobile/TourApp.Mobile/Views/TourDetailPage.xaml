<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TourApp.Mobile.Models"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.TourDetailPage"
             Title="{Binding [TourDetailTitle], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0F7F4" Offset="0.0"/>
            <GradientStop Color="#FFF8F0" Offset="0.5"/>
            <GradientStop Color="#EEF2F7" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Header Image -->
            <Image x:Name="TourImage" HeightRequest="260" Aspect="AspectFill" Source="media__1775454533773.jpg" />

            <VerticalStackLayout Padding="20" Spacing="16" Margin="0,-24,0,0" BackgroundColor="Transparent">
                <!-- Tour Title Card -->
                <Border StrokeThickness="0" BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#000" Offset="0,2" Radius="10" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="TourNameLabel" Text="{Binding [TourName], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="22" FontAttributes="Bold" TextColor="#1A1D26"/>
                        
                        <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                            <HorizontalStackLayout Grid.Column="0" Spacing="6">
                                <Border WidthRequest="28" HeightRequest="28" StrokeThickness="0" BackgroundColor="#E6F9EE" StrokeShape="RoundRectangle 8">
                                    <Label Text="{x:Static helpers:IconFont.CashMultiple}" FontFamily="MaterialIcons" FontSize="14" TextColor="#00B14F" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label x:Name="PriceLabel" Text="0 đ" FontSize="14" TextColor="#00B14F" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                <Border WidthRequest="28" HeightRequest="28" StrokeThickness="0" BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 8">
                                    <Label Text="{x:Static helpers:IconFont.ClockOutline}" FontFamily="MaterialIcons" FontSize="14" TextColor="#FF6B00" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label x:Name="DurationLabel" Text="" FontSize="14" TextColor="#6B7588" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="2" Spacing="6">
                                <Border WidthRequest="28" HeightRequest="28" StrokeThickness="0" BackgroundColor="#E8F0FE" StrokeShape="RoundRectangle 8">
                                    <Label Text="{x:Static helpers:IconFont.AccountGroup}" FontFamily="MaterialIcons" FontSize="14" TextColor="#007AFF" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label x:Name="ParticipantsLabel" Text="" FontSize="14" TextColor="#6B7588" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Tour Description -->
                <VerticalStackLayout Spacing="8" Padding="4,0">
                    <Label Text="{Binding [Introduction], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26" Margin="0,4,0,0"/>
                    <Label x:Name="TourDescriptionLabel" Text="" FontSize="14" TextColor="#6B7588" LineBreakMode="WordWrap" LineHeight="1.5"/>
                </VerticalStackLayout>

                <!-- Stops (POIs) -->
                <VerticalStackLayout Spacing="8" Padding="4,0">
                    <Label Text="{Binding [Destinations], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26" Margin="0,4,0,2"/>
                    <CollectionView x:Name="StopsCollectionView">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TourPOI">
                                <Border StrokeThickness="0" BackgroundColor="White" Padding="14" Margin="0,3" StrokeShape="RoundRectangle 12">
                                    <Border.Shadow>
                                        <Shadow Brush="#000" Offset="0,1" Radius="6" Opacity="0.05"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="40,*" ColumnSpacing="12">
                                        <Border Grid.Column="0" WidthRequest="34" HeightRequest="34" StrokeThickness="0" BackgroundColor="#00B14F" StrokeShape="RoundRectangle 17" VerticalOptions="Center" HorizontalOptions="Start">
                                            <Label Text="{Binding OrderIndex}" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding POI.Name}" FontSize="14" FontAttributes="Bold" TextColor="#1A1D26"/>
                                            <Label Text="{Binding POI.Address}" FontSize="12" TextColor="#6B7588" LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Download Offline Audio -->
                <Button x:Name="DownloadAudioButton" Text="{Binding [DownloadOfflineAudio], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#F0F2F5" TextColor="#1A1D26" CornerRadius="12" HeightRequest="48" Margin="0,4,0,0" Clicked="OnDownloadAudioClicked" />

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,24">
                    <Button Grid.Column="0" Text="{Binding [ViewTour], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="Transparent" TextColor="#00B14F" BorderColor="#00B14F" BorderWidth="1.5" CornerRadius="12" HeightRequest="48" Clicked="OnViewMapClicked"/>
                    <Button Grid.Column="1" Text="{Binding [BookTour], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" Clicked="OnBookTourClicked"/>
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
