<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.ChangePasswordPage"
             Title="{Binding [ChangePassword], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#F5F7FA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Border WidthRequest="60" HeightRequest="60" StrokeThickness="0" BackgroundColor="#FFF3E0" HorizontalOptions="Center" StrokeShape="RoundRectangle 18" Margin="0,20,0,10">
                <Label Text="{x:Static helpers:IconFont.Lock}" FontFamily="MaterialIcons" FontSize="28" TextColor="#FF6B00" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Text="{Binding [ChangePassword], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center" Margin="0,0,0,16"/>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [CurrentPassword], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="CurrentPasswordEntry" Placeholder="{Binding [CurrentPasswordPlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" IsPassword="True" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [NewPassword], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="NewPasswordEntry" Placeholder="{Binding [NewPasswordPlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" IsPassword="True" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [ConfirmNewPassword], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="ConfirmPasswordEntry" Placeholder="{Binding [ConfirmPasswordPlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" IsPassword="True" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <Button x:Name="SaveButton" Text="{Binding [ChangePasswordButton], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,8,0,0" Clicked="OnChangePasswordClicked"/>

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#00B14F" HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
