<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.ChangePasswordPage"
             Title="Đổi mật khẩu"
             BackgroundColor="#F5F6F8">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Icon -->
            <Label Text="🔒" FontSize="50" HorizontalOptions="Center" Margin="0,20,0,10"/>
            <Label Text="Đổi mật khẩu" FontSize="22" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <!-- Current Password -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Mật khẩu hiện tại" FontSize="14" FontAttributes="Bold" TextColor="#444"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="12,0">
                    <Entry x:Name="CurrentPasswordEntry" Placeholder="Nhập mật khẩu hiện tại" TextColor="Black" BackgroundColor="Transparent" IsPassword="True" FontSize="15"/>
                </Border>
            </VerticalStackLayout>

            <!-- New Password -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Mật khẩu mới" FontSize="14" FontAttributes="Bold" TextColor="#444"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="12,0">
                    <Entry x:Name="NewPasswordEntry" Placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" TextColor="Black" BackgroundColor="Transparent" IsPassword="True" FontSize="15"/>
                </Border>
            </VerticalStackLayout>

            <!-- Confirm New Password -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Xác nhận mật khẩu mới" FontSize="14" FontAttributes="Bold" TextColor="#444"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="12,0">
                    <Entry x:Name="ConfirmPasswordEntry" Placeholder="Nhập lại mật khẩu mới" TextColor="Black" BackgroundColor="Transparent" IsPassword="True" FontSize="15"/>
                </Border>
            </VerticalStackLayout>

            <!-- Save Button -->
            <Button x:Name="SaveButton" Text="Đổi mật khẩu" BackgroundColor="#FF3D00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,10,0,0" Clicked="OnChangePasswordClicked"/>

            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#FF3D00" HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
