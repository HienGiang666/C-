<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.ProfilePage"
             BackgroundColor="#F5F7FA"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Clean White Header with avatar -->
            <VerticalStackLayout BackgroundColor="White" Padding="24,52,24,28">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Border WidthRequest="88" HeightRequest="88" Stroke="#00B14F" StrokeThickness="3" Padding="0" StrokeShape="RoundRectangle 44" HorizontalOptions="Center">
                        <Image Source="media__1775454538289.png" Aspect="AspectFill"/>
                    </Border>
                    <Label x:Name="UserNameLabel" FontSize="22" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center" Margin="0,8,0,0"/>
                    <Label x:Name="UserEmailLabel" FontSize="13" TextColor="#A0A8B8" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Edit Profile Button (ẩn khi là khách) -->
                <Border x:Name="EditProfileButton" StrokeThickness="1" Stroke="#E4E7ED" BackgroundColor="#F8F9FC" Padding="18,10" HorizontalOptions="Center" Margin="0,14,0,0" StrokeShape="RoundRectangle 12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="{x:Static helpers:IconFont.Pencil}" FontFamily="MaterialIcons" FontSize="16" TextColor="#00B14F" VerticalOptions="Center"/>
                        <Label Text="Chỉnh sửa hồ sơ" FontSize="14" TextColor="#1A1D26" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnEditProfileTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Padding="20,16,20,40" Spacing="14">
                <!-- Stats Card -->
                <Border x:Name="StatsFrame" StrokeThickness="0" BackgroundColor="White" Padding="20,18" IsVisible="False" StrokeShape="RoundRectangle 14">
                    <Border.Shadow>
                        <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,1,*,1,*">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="8" FontSize="22" FontAttributes="Bold" TextColor="#00B14F" HorizontalOptions="Center"/>
                            <Label Text="Tour đã đi" FontSize="11" TextColor="#6B7588"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" Color="#E4E7ED" WidthRequest="1" VerticalOptions="Fill" Margin="0,4"/>

                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="24" FontSize="22" FontAttributes="Bold" TextColor="#00B14F" HorizontalOptions="Center"/>
                            <Label Text="Quán đã thử" FontSize="11" TextColor="#6B7588"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="3" Color="#E4E7ED" WidthRequest="1" VerticalOptions="Fill" Margin="0,4"/>

                        <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Label Text="12" FontSize="22" FontAttributes="Bold" TextColor="#00B14F" HorizontalOptions="Center"/>
                            <Label Text="Yêu thích" FontSize="11" TextColor="#6B7588"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Menu List -->
                <Border StrokeThickness="0" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 14">
                    <Border.Shadow>
                        <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <!-- Ngôn ngữ -->
                        <Grid ColumnDefinitions="46,*,Auto,Auto" Padding="16,14" HeightRequest="58">
                            <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#E6F9EE" StrokeShape="RoundRectangle 10">
                                <Label Text="{x:Static helpers:IconFont.Translate}" FontFamily="MaterialIcons" FontSize="18" TextColor="#00B14F" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="{Binding [SelectLanguage], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#1A1D26" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label x:Name="LanguageLabel" Grid.Column="2" Text="Tiếng Việt" FontSize="12" TextColor="#A0A8B8" VerticalOptions="Center" Margin="0,0,6,0"/>
                            <Label Grid.Column="3" Text="{x:Static helpers:IconFont.ChevronRight}" FontFamily="MaterialIcons" FontSize="20" TextColor="#CDD2DB" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F2F5" Margin="16,0"/>

                        <!-- Lịch sử Tour (ẩn khi là khách) -->
                        <Grid x:Name="HistoryRow" ColumnDefinitions="46,*,Auto" Padding="16,14" HeightRequest="58">
                            <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#E8F0FE" StrokeShape="RoundRectangle 10">
                                <Label Text="{x:Static helpers:IconFont.ClockOutline}" FontFamily="MaterialIcons" FontSize="18" TextColor="#007AFF" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="{Binding [MyTours], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#1A1D26" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="{x:Static helpers:IconFont.ChevronRight}" FontFamily="MaterialIcons" FontSize="20" TextColor="#CDD2DB" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHistoryTapped"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView x:Name="HistoryDivider" HeightRequest="1" Color="#F0F2F5" Margin="16,0"/>

                        <!-- Đổi mật khẩu (ẩn khi là khách) -->
                        <Grid x:Name="ChangePasswordRow" ColumnDefinitions="46,*,Auto" Padding="16,14" HeightRequest="58">
                            <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 10">
                                <Label Text="{x:Static helpers:IconFont.Lock}" FontFamily="MaterialIcons" FontSize="18" TextColor="#FF6B00" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="{Binding [ChangePassword], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#1A1D26" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="{x:Static helpers:IconFont.ChevronRight}" FontFamily="MaterialIcons" FontSize="20" TextColor="#CDD2DB" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangePasswordTapped"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Logout Button (chỉ hiện khi đăng nhập thường) -->
                <Button x:Name="LogoutButton" Text="{Binding [Logout], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#FFEBEE" TextColor="#FF3B30" FontAttributes="Bold" FontSize="14" CornerRadius="12" HeightRequest="48" Clicked="OnLogoutClicked"/>

                <!-- Login + Register Buttons (chỉ hiện khi là khách) -->
                <VerticalStackLayout x:Name="GuestButtonsLayout" IsVisible="False" Spacing="10">
                    <Button Text="Đăng nhập" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="14" CornerRadius="12" HeightRequest="48" Clicked="OnLoginClicked"/>
                    <Button Text="Đăng ký" BackgroundColor="White" TextColor="#00B14F" BorderColor="#00B14F" BorderWidth="1.5" FontAttributes="Bold" FontSize="14" CornerRadius="12" HeightRequest="48" Clicked="OnRegisterClicked"/>
                </VerticalStackLayout>

                <Label Text="Version 1.0.0" FontSize="11" TextColor="#CDD2DB" HorizontalOptions="Center" Margin="0,4,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangeIpTapped" NumberOfTapsRequired="3"/>
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
