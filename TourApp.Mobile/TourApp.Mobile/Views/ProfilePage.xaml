<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.ProfilePage"
             BackgroundColor="#F5F6F8"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid>
            <!-- Orange Curved Header -->
            <BoxView Color="#FF3D00" HeightRequest="250" VerticalOptions="Start" CornerRadius="0,0,40,40" Margin="0,-20,0,0"/>

            <VerticalStackLayout Padding="20,40,20,40">
                <!-- User Profile Info -->
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="0,20,0,30">
                    <Border WidthRequest="100" HeightRequest="100" Stroke="White" StrokeThickness="2" Padding="0" StrokeShape="RoundRectangle 50" HorizontalOptions="Center">
                        <Image Source="media__1775454538289.png" Aspect="AspectFill"/>
                    </Border>
                    <Label x:Name="UserNameLabel" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
                    <Label x:Name="UserEmailLabel" FontSize="14" TextColor="#FFDED0" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Stats Card (Hidden) -->
                <Border x:Name="StatsFrame" StrokeThickness="0" BackgroundColor="White" Padding="20" Margin="0,0,0,20" IsVisible="False" StrokeShape="RoundRectangle 20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.12"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,1,*,1,*">
                        <!-- Tours -->
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="8" FontSize="22" TextColor="#FF3D00" HorizontalOptions="Center"/>
                            <Label Text="Tour đã đi" FontSize="11" TextColor="#888"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" Color="#EEEEEE" WidthRequest="1" VerticalOptions="Fill"/>

                        <!-- Quán -->
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="24" FontSize="22" TextColor="#FF3D00" HorizontalOptions="Center"/>
                            <Label Text="Quán đã thử" FontSize="11" TextColor="#888"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="3" Color="#EEEEEE" WidthRequest="1" VerticalOptions="Fill"/>

                        <!-- Yêu thích -->
                        <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="12" FontSize="22" TextColor="#FF3D00" HorizontalOptions="Center"/>
                            <Label Text="Yêu thích" FontSize="11" TextColor="#888"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Menu List -->
                <Border StrokeThickness="0" BackgroundColor="White" Padding="10,0" Margin="0,0,0,30" StrokeShape="RoundRectangle 20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.12"/>
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <!-- Ngôn ngữ -->
                        <Grid ColumnDefinitions="40,*,Auto,Auto" Padding="15" HeightRequest="60">
                            <Label Grid.Column="0" Text="🌐" FontSize="20" VerticalOptions="Center" TextColor="#FF3D00"/>
                            <Label Grid.Column="1" Text="{Binding [SelectLanguage], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="16" TextColor="Black" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label x:Name="LanguageLabel" Grid.Column="2" Text="Tiếng Việt" FontSize="14" TextColor="#888" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Label Grid.Column="3" Text=">" FontSize="18" TextColor="#CCC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                        <!-- Lịch sử -->
                        <Grid ColumnDefinitions="40,*,Auto" Padding="15" HeightRequest="60">
                            <Label Grid.Column="0" Text="🕒" FontSize="20" VerticalOptions="Center" TextColor="#FF3D00"/>
                            <Label Grid.Column="1" Text="{Binding [MyTours], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="16" TextColor="Black" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text=">" FontSize="18" TextColor="#CCC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHistoryTapped"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                        <!-- Chỉnh IP -->
                        <Grid ColumnDefinitions="40,*,Auto" Padding="15" HeightRequest="60">
                            <Label Grid.Column="0" Text="📡" FontSize="20" VerticalOptions="Center" TextColor="#FF3D00"/>
                            <Label Grid.Column="1" Text="{Binding [Settings], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="16" TextColor="Black" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text=">" FontSize="18" TextColor="#CCC" VerticalOptions="Center"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangeIpTapped"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Logout Button -->
                <Button Text="{Binding [Logout], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#FFF0F0" TextColor="#FF3B30" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,0,0,20" Clicked="OnLogoutClicked"/>

                <Label Text="Version 1.0.0" FontSize="12" TextColor="#BBB" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
