<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#FFFFFF">

    <ScrollView>
        <VerticalStackLayout Padding="30, 60, 30, 30" Spacing="15">
            <!-- Back Button -->
            <ImageButton Source="dotnet_bot.png" 
                         HeightRequest="30" WidthRequest="30"
                         HorizontalOptions="Start"
                         BackgroundColor="Transparent"
                         Clicked="OnBackClicked"
                         Margin="0,0,0,20"/>

            <Label Text="Tạo Tài Khoản Mới" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#1E293B"/>
            <Label Text="Bắt đầu khám phá Sài Gòn cùng chúng tôi." 
                   FontSize="14" 
                   TextColor="#64748B" 
                   Margin="0,0,0,20"/>

            <!-- Name Input -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F8FAFC" Padding="15,0">
                <Entry x:Name="NameEntry" Placeholder="Họ và tên" TextColor="#333" PlaceholderColor="#94A3B8"/>
            </Border>

            <!-- Email Input -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F8FAFC" Padding="15,0">
                <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" TextColor="#333" PlaceholderColor="#94A3B8"/>
            </Border>

            <!-- Password Input -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F8FAFC" Padding="15,0">
                <Entry x:Name="PasswordEntry" Placeholder="Mật khẩu" IsPassword="True" TextColor="#333" PlaceholderColor="#94A3B8"/>
            </Border>

            <!-- Confirm Password Input -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F8FAFC" Padding="15,0">
                <Entry x:Name="ConfirmPasswordEntry" Placeholder="Xác nhận mật khẩu" IsPassword="True" TextColor="#333" PlaceholderColor="#94A3B8"/>
            </Border>

            <!-- Register Button -->
            <Button Text="Đăng Ký" 
                    BackgroundColor="#4F46E5" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="12" 
                    HeightRequest="50" 
                    Margin="0,20,0,0"
                    Clicked="OnRegisterClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
