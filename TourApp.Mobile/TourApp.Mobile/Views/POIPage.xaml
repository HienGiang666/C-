<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.POIPage"
             BackgroundColor="#F5F6F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Header Content -->
        <VerticalStackLayout Grid.Row="0">
            <Grid>
                <!-- Orange Header -->
                <BoxView Color="#FF3D00" HeightRequest="150" VerticalOptions="Start" />
                
                <VerticalStackLayout Padding="20,40,20,20">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                            <Label Text="🍲" FontSize="24" />
                            <Label Text="Quán Ăn" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- QR Code Scanner button -->
                        <Frame Grid.Column="2" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="White" Padding="0" HasShadow="False">
                            <Label Text="📷" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQRScanClicked"/>
                            </Frame.GestureRecognizers>
                        </Frame>
                    </Grid>

                    <!-- Search Bar -->
                    <Frame BackgroundColor="White" CornerRadius="25" HasShadow="False" Padding="15,0" Margin="0,20,0,0" HeightRequest="50" BorderColor="Transparent">
                        <Grid ColumnDefinitions="30,*">
                            <Label Grid.Column="0" Text="🔍" FontSize="18" TextColor="#888" VerticalOptions="Center"/>
                            <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="Tìm quán ăn..." TextColor="Black" BackgroundColor="Transparent" Completed="OnSearchCompleted"/>
                        </Grid>
                    </Frame>
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,40" Spacing="25" BackgroundColor="#F5F6F8">
                <CollectionView x:Name="PoiCollectionView" SelectionMode="Single" SelectionChanged="OnPoiSelected">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="15" VerticalItemSpacing="15" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="20" Padding="0" IsClippedToBounds="True" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                                <Grid RowDefinitions="120,Auto">
                                    <Image Grid.Row="0" Source="media__1775454533773.jpg" Aspect="AspectFill"/>
                                    <VerticalStackLayout Grid.Row="1" Padding="15">
                                        <Label Text="{Binding PoiName}" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
                                        <Label Text="{Binding Rating, StringFormat='⭐ {0:F1}'}" FontSize="12" TextColor="#FF5B00" Margin="0,5,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
