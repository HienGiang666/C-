<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:TourApp.Mobile.Views"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:converters="clr-namespace:TourApp.Mobile.Converters"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             xmlns:models="clr-namespace:TourApp.Mobile.Models"
             x:Class="TourApp.Mobile.Views.HomePage"
             x:DataType="views:HomePage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:UrlToImageSourceConverter x:Key="UrlToImageConverter" />
    </ContentPage.Resources>

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0F7F4" Offset="0.0"/>
            <GradientStop Color="#F5F0EB" Offset="0.5"/>
            <GradientStop Color="#EEF2F7" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Offline Banner -->
            <Border x:Name="OfflineBanner" IsVisible="False"
                    BackgroundColor="#FEF3C7" StrokeThickness="0"
                    Padding="14,8" HorizontalOptions="Fill">
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{x:Static helpers:IconFont.WifiOff}" FontFamily="MaterialIcons"
                           FontSize="16" TextColor="#92400E" VerticalOptions="Center"/>
                    <Label x:Name="OfflineBannerText"
                           Text="{Binding [OfflineBanner], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="13" TextColor="#92400E" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Green Gradient Header -->
            <Grid Padding="20,48,20,22">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00B14F" Offset="0.0"/>
                        <GradientStop Color="#00C853" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,18">
                    <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="#FFFFFF30" StrokeShape="RoundRectangle 22">
                            <Label Text="{x:Static helpers:IconFont.Account}" FontFamily="MaterialIcons" FontSize="22" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="1">
                            <Label x:Name="WelcomeLabel" FontSize="12" TextColor="#FFFFFFBB"/>
                            <Label x:Name="UserNameLabel" FontSize="17" FontAttributes="Bold" TextColor="White"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Border Grid.Column="2" WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="#FFFFFF30" StrokeShape="RoundRectangle 22">
                        <Label Text="{x:Static helpers:IconFont.QrcodeScan}" FontFamily="MaterialIcons" FontSize="22" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnQRScanClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Search Bar with Dropdown -->
                <Grid Grid.Row="1">
                    <Border Stroke="Transparent" StrokeThickness="0" BackgroundColor="White" Padding="14,0" HeightRequest="48" StrokeShape="RoundRectangle 24">
                        <Border.Shadow>
                            <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.08"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="30,*">
                            <Label Grid.Column="0" Text="{x:Static helpers:IconFont.Magnify}" FontFamily="MaterialIcons" FontSize="20" TextColor="#A0A8B8" VerticalOptions="Center"/>
                            <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="{Binding [SearchPlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" PlaceholderColor="#A0A8B8" FontSize="14" BackgroundColor="Transparent" 
                                   TextChanged="OnSearchTextChanged"
                                   Completed="OnSearchCompleted"/>
                        </Grid>
                    </Border>

                    <!-- Search Autocomplete Dropdown -->
                    <Border x:Name="SearchDropdown" IsVisible="False" Margin="0,52,0,0"
                            VerticalOptions="Start" HorizontalOptions="Fill"
                            BackgroundColor="White" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.12, Radius=10}"
                            MaximumHeightRequest="260">
                        <CollectionView x:Name="SearchResultsView" SelectionMode="Single"
                                        SelectionChanged="OnSearchResultSelected">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:POI">
                                    <Grid Padding="14,10" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Label Grid.Column="0" Text="{x:Static helpers:IconFont.MapMarker}"
                                               FontFamily="MaterialIcons" FontSize="18"
                                               TextColor="#00B14F" VerticalOptions="Center"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"
                                                   TextColor="#1A1D26" LineBreakMode="TailTruncation" MaxLines="1"/>
                                            <Label Text="{Binding Address}" FontSize="11"
                                                   TextColor="#94A3B8" LineBreakMode="TailTruncation" MaxLines="1"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </Grid>
            </Grid>

            <!-- Decorative curve -->
            <BoxView HeightRequest="18" Margin="0,-18,0,0">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00C853" Offset="0.0"/>
                        <GradientStop Color="Transparent" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- Main Content -->
            <VerticalStackLayout Padding="20,10,20,40" Spacing="24">
                
                <!-- Category Chips - horizontal scroll -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding [Categories], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26"/>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="White" Padding="0,14" StrokeShape="RoundRectangle 14">
                            <Border.Shadow>
                                <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNuongTapped"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Border WidthRequest="42" HeightRequest="42" StrokeThickness="0" BackgroundColor="#FFF2E8" StrokeShape="RoundRectangle 12" HorizontalOptions="Center">
                                    <Label Text="{x:Static helpers:IconFont.Fire}" FontFamily="MaterialIcons" FontSize="22" TextColor="#FF6B00" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding [CategoryNuong], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold" TextColor="#4A5568" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="White" Padding="0,14" StrokeShape="RoundRectangle 14">
                            <Border.Shadow>
                                <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLauTapped"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Border WidthRequest="42" HeightRequest="42" StrokeThickness="0" BackgroundColor="#FFE8E8" StrokeShape="RoundRectangle 12" HorizontalOptions="Center">
                                    <Label Text="{x:Static helpers:IconFont.FoodForkDrink}" FontFamily="MaterialIcons" FontSize="22" TextColor="#FF3B30" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding [CategoryLau], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold" TextColor="#4A5568" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="White" Padding="0,14" StrokeShape="RoundRectangle 14">
                            <Border.Shadow>
                                <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOcTapped"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Border WidthRequest="42" HeightRequest="42" StrokeThickness="0" BackgroundColor="#E8F0FE" StrokeShape="RoundRectangle 12" HorizontalOptions="Center">
                                    <Label Text="{x:Static helpers:IconFont.Food}" FontFamily="MaterialIcons" FontSize="22" TextColor="#007AFF" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding [CategoryOc], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold" TextColor="#4A5568" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="3" StrokeThickness="0" BackgroundColor="White" Padding="0,14" StrokeShape="RoundRectangle 14">
                            <Border.Shadow>
                                <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAnVatTapped"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Border WidthRequest="42" HeightRequest="42" StrokeThickness="0" BackgroundColor="#E6F9EE" StrokeShape="RoundRectangle 12" HorizontalOptions="Center">
                                    <Label Text="{x:Static helpers:IconFont.StorefrontOutline}" FontFamily="MaterialIcons" FontSize="22" TextColor="#00B14F" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding [CategoryAnVat], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="11" FontAttributes="Bold" TextColor="#4A5568" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Suggested Tours -->
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="{x:Static helpers:IconFont.Fire}" FontFamily="MaterialIcons" FontSize="20" TextColor="#FF6B00" VerticalOptions="Center"/>
                            <Label Text="{Binding [SuggestedTours], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26"/>
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" Text="{Binding [SeeMore], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#00B14F" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnXemThemTourTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <CollectionView x:Name="TourCollectionView" HeightRequest="260" ItemsLayout="HorizontalList" SelectionMode="Single" SelectionChanged="OnTourSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="views:MockItem">
                                <Border WidthRequest="260" StrokeThickness="0" Padding="0" Margin="0,0,12,0" BackgroundColor="White" StrokeShape="RoundRectangle 16">
                                    <Border.Shadow>
                                        <Shadow Brush="#000" Offset="0,4" Radius="12" Opacity="0.08"/>
                                    </Border.Shadow>
                                    <Grid RowDefinitions="140,Auto">
                                        <!-- Placeholder bg khi không có ảnh -->
                                        <BoxView Grid.Row="0" Color="#E6F9EE"/>
                                        <Image Grid.Row="0" Source="{Binding ImageUrl, Converter={StaticResource UrlToImageConverter}}" Aspect="AspectFill"/>
                                        <!-- Gradient overlay bottom -->
                                        <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="50">
                                            <BoxView.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0.0"/>
                                                    <GradientStop Color="#40000000" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </BoxView.Background>
                                        </BoxView>
                                        <VerticalStackLayout Grid.Row="1" Padding="16,12" Spacing="4">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="#1A1D26"/>
                                            <Label Text="{Binding Summary}" FontSize="13" TextColor="#00B14F" FontAttributes="Bold" LineBreakMode="TailTruncation" MaxLines="1"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Top Places -->
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="{x:Static helpers:IconFont.Star}" FontFamily="MaterialIcons" FontSize="20" TextColor="#FFB800" VerticalOptions="Center"/>
                            <Label Text="{Binding [TopPlaces], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26"/>
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" Text="{Binding [SeeMore], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#00B14F" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnXemThemPoiTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <CollectionView x:Name="PoiCollectionView" HeightRequest="220" ItemsLayout="HorizontalList" SelectionMode="Single" SelectionChanged="OnPoiSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="views:MockItem">
                                <Border WidthRequest="180" StrokeThickness="0" Padding="0" Margin="0,0,12,6" BackgroundColor="White" StrokeShape="RoundRectangle 16">
                                    <Border.Shadow>
                                        <Shadow Brush="#000" Offset="0,4" Radius="12" Opacity="0.08"/>
                                    </Border.Shadow>
                                    <Grid RowDefinitions="130,Auto">
                                        <BoxView Grid.Row="0" Color="#FFF2E8"/>
                                        <Image Grid.Row="0" Source="{Binding ImageUrl, Converter={StaticResource UrlToImageConverter}}" Aspect="AspectFill"/>
                                        <!-- Rating badge -->
                                        <Border Grid.Row="0" VerticalOptions="Start" HorizontalOptions="End" Margin="8" Padding="6,3" BackgroundColor="#FFFFFFDD" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                            <Label Text="{Binding Summary}" FontSize="11" FontAttributes="Bold" TextColor="#FF6B00"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Row="1" Padding="12,10" Spacing="2">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="13" TextColor="#1A1D26" LineBreakMode="TailTruncation" MaxLines="2"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
