<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:TourApp.Mobile.Views"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.HomePage"
             x:DataType="views:HomePage"
             BackgroundColor="#F5F6F8"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid RowDefinitions="Auto,*">

            <!-- Header Content (Gradient Orange) -->
            <VerticalStackLayout Grid.Row="0">
                <Grid>
                    <!-- Simulated Gradient Background Area -->
                    <BoxView Color="#FF3D00" HeightRequest="150" VerticalOptions="Start" />
                    
                    <VerticalStackLayout Padding="20,40,20,20">
                        <!-- Top Bar -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                <Label Text="🗺️" FontSize="24" />
                                <Label x:Name="UserNameLabel" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <!-- QR Code Scanner button -->
                            <Border Grid.Column="2" WidthRequest="40" HeightRequest="40" StrokeThickness="0" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20">
                                <Label Text="📷" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQRScanClicked"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>

                        <!-- Search Bar -->
                        <Border StrokeThickness="0" BackgroundColor="White" Padding="15,0" Margin="0,20,0,0" HeightRequest="50" StrokeShape="RoundRectangle 25">
                            <Grid ColumnDefinitions="30,*">
                                <Label Grid.Column="0" Text="🔍" FontSize="18" TextColor="#888" VerticalOptions="Center"/>
                                <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="{Binding [SearchPlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="Black" BackgroundColor="Transparent" Completed="OnSearchCompleted"/>
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSearchBarTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>

            <!-- Main Scrollable Area -->
            <VerticalStackLayout Grid.Row="1" Padding="20,10,20,40" Spacing="25" BackgroundColor="#F5F6F8">
                
                <!-- Category Grid -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="#FFF0E5" Padding="5,15" StrokeShape="RoundRectangle 15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNuongTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🔥" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [CategoryNuong], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#444"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#FCE4E4" Padding="5,15" StrokeShape="RoundRectangle 15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLauTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🍲" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [CategoryLau], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#444"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="#E6F0FF" Padding="5,15" StrokeShape="RoundRectangle 15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOcTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🐚" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [CategoryOc], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#444"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="3" StrokeThickness="0" BackgroundColor="#E6FCEF" Padding="5,15" StrokeShape="RoundRectangle 15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAnVatTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🍢" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding [CategoryAnVat], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#444"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Lộ Trình Gợi Ý -->
                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding [SuggestedTours], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="#16182B"/>
                        <Label Grid.Column="1" Text="{Binding [SeeMore], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#FF5B00" FontSize="14" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnXemThemTourTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <CollectionView x:Name="TourCollectionView" HeightRequest="250" SelectionMode="Single" SelectionChanged="OnTourSelected">
                        <!-- Mock setup for item layout -->
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="views:MockItem">
                                <Border StrokeThickness="0" Padding="0" Margin="0,0,0,15" BackgroundColor="White" StrokeShape="RoundRectangle 20">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.12"/>
                                    </Border.Shadow>
                                    <Grid RowDefinitions="120,Auto">
                                        <Image Grid.Row="0" Source="media__1775454533773.jpg" Aspect="AspectFill"/>
                                        <VerticalStackLayout Grid.Row="1" Padding="15">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                                            <Label Text="{Binding Summary}" FontSize="12" TextColor="#888" Margin="0,5,0,0"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Top Nổi Bật -->
                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding [TopPlaces], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="#16182B"/>
                        <Label Grid.Column="1" Text="{Binding [SeeMore], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#FF5B00" FontSize="14" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnXemThemPoiTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <CollectionView x:Name="PoiCollectionView" HeightRequest="200" ItemsLayout="HorizontalList" SelectionMode="Single" SelectionChanged="OnPoiSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="views:MockItem">
                                <Border WidthRequest="200" StrokeThickness="0" Padding="0" Margin="0,0,15,5" BackgroundColor="White" StrokeShape="RoundRectangle 20">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.12"/>
                                    </Border.Shadow>
                                    <Grid RowDefinitions="120,Auto">
                                        <Image Grid.Row="0" Source="media__1775454545663.jpg" Aspect="AspectFill"/>
                                        <VerticalStackLayout Grid.Row="1" Padding="15">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                                            <Label Text="{Binding Summary}" FontSize="12" TextColor="#FF5B00" Margin="0,5,0,0"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
