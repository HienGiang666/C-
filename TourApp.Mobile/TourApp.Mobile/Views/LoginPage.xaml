<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#FFFFFF">

    <ScrollView>
        <VerticalStackLayout Padding="30, 80, 30, 30" Spacing="20">
            <!-- Header Image or Icon -->
            <Image Source="dotnet_bot.png" 
                   HeightRequest="120" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,30" />

            <!-- Title -->
            <Label Text="Chào mừng trở lại!" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#1E293B" 
                   HorizontalTextAlignment="Center" />
            <Label Text="Đăng nhập để tiếp tục hành trình" 
                   FontSize="14" 
                   TextColor="#64748B" 
                   HorizontalTextAlignment="Center" 
                   Margin="0,0,0,20"/>

            <!-- Email Input -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F8FAFC" Padding="15,0">
                <Entry x:Name="EmailEntry" 
                       Placeholder="Email của bạn" 
                       Keyboard="Email" 
                       TextColor="#333333" 
                       PlaceholderColor="#94A3B8" 
                       ClearButtonVisibility="WhileEditing"/>
            </Border>

            <!-- Password Input -->
            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F8FAFC" Padding="15,0">
                <Entry x:Name="PasswordEntry" 
                       Placeholder="Mật khẩu" 
                       IsPassword="True" 
                       TextColor="#333333" 
                       PlaceholderColor="#94A3B8" 
                       ClearButtonVisibility="WhileEditing"/>
            </Border>

            <!-- Login Button -->
            <Button Text="Đăng Nhập" 
                    BackgroundColor="#4F46E5" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="12" 
                    HeightRequest="50" 
                    Margin="0,20,0,0"
                    Clicked="OnLoginClicked"/>

            <!-- Register Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,15,0,0">
                <Label Text="Chưa có tài khoản?" TextColor="#64748B" VerticalOptions="Center"/>
                <Label Text="Đăng ký ngay" 
                       TextColor="#4F46E5" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
