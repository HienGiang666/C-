<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.QRScannerPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,40,20,20" BackgroundColor="#80000000">
            <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeThickness="0"
                   BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20">
                <Label Text="←" FontSize="20" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
            </Border>
            
            <Label Grid.Column="1" Text="{Binding [QRScannerTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" 
                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            
            <!-- Flash toggle -->
            <Border Grid.Column="2" WidthRequest="40" HeightRequest="40" StrokeThickness="0"
                   BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20">
                <Label Text="⚡" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFlashTapped"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- Camera View -->
        <Grid Grid.Row="1">
            <!-- ZXing Camera Barcode Reader -->
            <zxing:CameraBarcodeReaderView
                x:Name="cameraBarcodeReader"
                CameraLocation="Rear"
                BarcodesDetected="OnBarcodesDetected"
                IsDetecting="True"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"/>
            
            <!-- Scanner overlay frame -->
            <Border BackgroundColor="Transparent" Stroke="#FF3D00" StrokeThickness="3"
                   StrokeShape="RoundRectangle 20" Padding="0"
                   WidthRequest="250" HeightRequest="250"
                   HorizontalOptions="Center" VerticalOptions="Center">
                <Grid>
                    <!-- Corner markers -->
                    <BoxView Color="#FF3D00" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="Start" VerticalOptions="Start" Margin="10"/>
                    <BoxView Color="#FF3D00" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="Start" VerticalOptions="Start" Margin="10"/>
                    
                    <BoxView Color="#FF3D00" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="End" VerticalOptions="Start" Margin="10"/>
                    <BoxView Color="#FF3D00" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="End" VerticalOptions="Start" Margin="10"/>
                    
                    <BoxView Color="#FF3D00" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="Start" VerticalOptions="End" Margin="10"/>
                    <BoxView Color="#FF3D00" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="Start" VerticalOptions="End" Margin="10"/>
                    
                    <BoxView Color="#FF3D00" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="End" VerticalOptions="End" Margin="10"/>
                    <BoxView Color="#FF3D00" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="End" VerticalOptions="End" Margin="10"/>
                    
                    <!-- Scanning line animation -->
                    <BoxView x:Name="ScanLine" Color="#FF3D00" HeightRequest="2" 
                             HorizontalOptions="Fill" VerticalOptions="Start" Margin="20,0"/>

                </Grid>
            </Border>

            <!-- Emulator Mock Buttons -->
            <VerticalStackLayout x:Name="EmulatorUI" IsVisible="True" VerticalOptions="Center" HorizontalOptions="Center" Spacing="20" BackgroundColor="#AA000000" Padding="20">
                <Label Text="(Test Mode)" TextColor="White" HorizontalOptions="Center"/>
                <Button Text="{Binding [MockScan1], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#FF3D00" TextColor="White" Clicked="OnMockScan1Clicked"/>
                <Button Text="{Binding [MockScan2], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#FF3D00" TextColor="White" Clicked="OnMockScan2Clicked"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Bottom instruction -->
        <VerticalStackLayout Grid.Row="2" Padding="20,30" BackgroundColor="#80000000" Spacing="10">
            <Label Text="{Binding [ScanQRInstruction], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="White" 
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Label Text="{Binding [QRHelpText], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" 
                   TextColor="#AAAAAA" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
