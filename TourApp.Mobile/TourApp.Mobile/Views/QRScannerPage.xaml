<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.QRScannerPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,40,20,20" BackgroundColor="#80000000">
            <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeThickness="0"
                   BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20">
                <Label Text="{x:Static helpers:IconFont.ArrowLeft}" FontFamily="MaterialIcons" FontSize="20" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
            </Border>
            
            <Label Grid.Column="1" Text="{Binding [QRScannerTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" 
                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            
            <!-- Flash toggle - hidden on Windows -->
            <Border x:Name="FlashButton" Grid.Column="2" WidthRequest="40" HeightRequest="40" StrokeThickness="0"
                   BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20">
                <Label Text="{x:Static helpers:IconFont.Flash}" FontFamily="MaterialIcons" FontSize="20" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFlashTapped"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- Camera View -->
        <Grid Grid.Row="1" x:Name="CameraGrid">
            <!-- Camera view - only visible on mobile platforms -->
            <Grid x:Name="CameraContainer" IsVisible="False"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <!-- Camera view will be added dynamically on supported platforms -->
            </Grid>

            <!-- Scanner overlay frame - InputTransparent so camera works underneath -->
            <Border BackgroundColor="Transparent" Stroke="#00B14F" StrokeThickness="3"
                   StrokeShape="RoundRectangle 24" Padding="0"
                   WidthRequest="260" HeightRequest="260"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   InputTransparent="True">
                <Grid>
                    <!-- Corner markers -->
                    <BoxView Color="#00B14F" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="Start" VerticalOptions="Start" Margin="10"/>
                    <BoxView Color="#00B14F" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="Start" VerticalOptions="Start" Margin="10"/>
                    
                    <BoxView Color="#00B14F" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="End" VerticalOptions="Start" Margin="10"/>
                    <BoxView Color="#00B14F" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="End" VerticalOptions="Start" Margin="10"/>
                    
                    <BoxView Color="#00B14F" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="Start" VerticalOptions="End" Margin="10"/>
                    <BoxView Color="#00B14F" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="Start" VerticalOptions="End" Margin="10"/>
                    
                    <BoxView Color="#00B14F" WidthRequest="40" HeightRequest="4" 
                             HorizontalOptions="End" VerticalOptions="End" Margin="10"/>
                    <BoxView Color="#00B14F" WidthRequest="4" HeightRequest="40" 
                             HorizontalOptions="End" VerticalOptions="End" Margin="10"/>
                    
                    <!-- Scanning line animation -->
                    <BoxView x:Name="ScanLine" Color="#00B14F" HeightRequest="2" 
                             HorizontalOptions="Fill" VerticalOptions="Start" Margin="20,0"/>

                </Grid>
            </Border>

        </Grid>

        <!-- Bottom instruction -->
        <VerticalStackLayout Grid.Row="2" Padding="20,30" BackgroundColor="#80000000" Spacing="10">
            <Label Text="{Binding [ScanQRInstruction], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="White" 
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Label Text="{Binding [QRHelpText], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" 
                   TextColor="#AAAAAA" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
