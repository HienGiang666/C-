<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:TourApp.Mobile.Views"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.BookingPage"
             x:DataType="views:BookingPage"
             Title="{Binding [BookTourTitle], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0F7F4" Offset="0.0"/>
            <GradientStop Color="#FFF8F0" Offset="0.5"/>
            <GradientStop Color="#EEF2F7" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <!-- Tour Summary -->
            <Border StrokeThickness="0" BackgroundColor="White" Padding="18" StrokeShape="RoundRectangle 14">
                <Border.Shadow>
                    <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding [SelectedTour], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="#A0A8B8"/>
                    <Label x:Name="TourNameLabel" Text="{Binding [TourName], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="17" FontAttributes="Bold" TextColor="#1A1D26"/>
                    <HorizontalStackLayout Spacing="5" Margin="0,4,0,0">
                        <Label Text="{Binding [PricePerPerson], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#6B7588"/>
                        <Label x:Name="PriceLabel" Text="0 đ" FontSize="14" FontAttributes="Bold" TextColor="#00B14F"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding [BookingInfo], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="16" FontAttributes="Bold" TextColor="#1A1D26"/>

            <VerticalStackLayout>
                <Label Text="{Binding [DepartureDate], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="12,0">
                    <DatePicker x:Name="TourDatePicker" MinimumDate="{Binding MinimumDate}" TextColor="Black" BackgroundColor="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="{Binding [NumberOfPeople], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Grid ColumnDefinitions="*,50,*">
                    <Button Grid.Column="0" Text="-" BackgroundColor="#F0F2F5" TextColor="#1A1D26" FontAttributes="Bold" CornerRadius="12" Clicked="OnDecreaseParticipantsClicked"/>
                    <Label x:Name="ParticipantsLabel" Grid.Column="1" Text="1" FontSize="18" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Button Grid.Column="2" Text="+" BackgroundColor="#F0F2F5" TextColor="#1A1D26" FontAttributes="Bold" CornerRadius="12" Clicked="OnIncreaseParticipantsClicked"/>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="{Binding [NotesOptional], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="100" StrokeShape="RoundRectangle 12" Padding="0">
                    <Editor x:Name="NotesEditor" Placeholder="{Binding [SpecialRequests], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="Black" BackgroundColor="Transparent" Margin="10,5" IsTextPredictionEnabled="False"/>
                </Border>
            </VerticalStackLayout>

            <!-- Summary -->
            <Border StrokeThickness="0" BackgroundColor="#E6F9EE" Padding="18" StrokeShape="RoundRectangle 12" Margin="0,4,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding [TotalPayment], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" FontAttributes="Bold" TextColor="#1A1D26" VerticalOptions="Center"/>
                    <Label x:Name="TotalPriceLabel" Grid.Column="1" Text="0 đ" FontSize="17" FontAttributes="Bold" TextColor="#00B14F"/>
                </Grid>
            </Border>

            <Button x:Name="ConfirmBookingButton" Text="{Binding [ConfirmBooking], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,4,0,24" Clicked="OnConfirmBookingClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
