<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.EditProfilePage"
             Title="Chỉnh sửa hồ sơ"
             BackgroundColor="#F5F7FA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,10,0,10">
                <Border WidthRequest="88" HeightRequest="88" Stroke="#00B14F" StrokeThickness="3" Padding="0" StrokeShape="RoundRectangle 44" HorizontalOptions="Center">
                    <Image Source="media__1775454538289.png" Aspect="AspectFill"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Họ và tên" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="FullNameEntry" Placeholder="Nhập họ và tên" TextColor="#1A1D26" BackgroundColor="Transparent" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Email" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="EmailEntry" Placeholder="Nhập email" TextColor="#1A1D26" BackgroundColor="Transparent" Keyboard="Email" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Số điện thoại" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="PhoneEntry" Placeholder="Nhập số điện thoại" TextColor="#1A1D26" BackgroundColor="Transparent" Keyboard="Telephone" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Địa chỉ" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="AddressEntry" Placeholder="Nhập địa chỉ" TextColor="#1A1D26" BackgroundColor="Transparent" FontSize="14"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Ngày sinh" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <DatePicker x:Name="DateOfBirthPicker" TextColor="Black" BackgroundColor="Transparent" MaximumDate="{Binding Today}" Format="dd/MM/yyyy"/>
                </Border>
            </VerticalStackLayout>

            <Button x:Name="SaveButton" Text="Lưu thay đổi" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,8,0,0" Clicked="OnSaveClicked"/>

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#00B14F" HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
