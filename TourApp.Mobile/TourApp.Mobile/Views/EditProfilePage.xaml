<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.EditProfilePage"
             Title="{Binding [EditProfileTitle], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F3F0FF" Offset="0.0"/>
            <GradientStop Color="#F5F0EB" Offset="0.5"/>
            <GradientStop Color="#EEF2F7" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,10,0,10">
                <Border WidthRequest="88" HeightRequest="88" Stroke="#00B14F" StrokeThickness="3" Padding="0" StrokeShape="RoundRectangle 44" HorizontalOptions="Center">
                    <Image Source="media__1775454538289.png" Aspect="AspectFill"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [FullName], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="FullNameEntry" Placeholder="{Binding [EnterFullName], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" FontSize="14" IsTextPredictionEnabled="False"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [Email], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="EmailEntry" Placeholder="{Binding [EnterEmail], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" Keyboard="Email" FontSize="14" IsTextPredictionEnabled="False"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [Phone], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="PhoneEntry" Placeholder="{Binding [EnterPhone], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" Keyboard="Telephone" FontSize="14" IsTextPredictionEnabled="False"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [Address], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <Entry x:Name="AddressEntry" Placeholder="{Binding [EnterAddress], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" BackgroundColor="Transparent" FontSize="14" IsTextPredictionEnabled="False"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding [DateOfBirth], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" HeightRequest="50" StrokeShape="RoundRectangle 12" Padding="14,0">
                    <DatePicker x:Name="DateOfBirthPicker" TextColor="Black" BackgroundColor="Transparent" MaximumDate="{Binding Today}" Format="dd/MM/yyyy"/>
                </Border>
            </VerticalStackLayout>

            <Button x:Name="SaveButton" Text="{Binding [SaveChanges], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,8,0,0" Clicked="OnSaveClicked"/>

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#00B14F" HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
