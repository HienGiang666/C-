<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TourApp.Mobile.Models"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.UserBookingsPage"
             Title="{Binding [MyTours], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="*">
        <RefreshView x:Name="BookingsRefreshView" Grid.Row="0" Refreshing="OnRefreshing">
            <CollectionView x:Name="BookingsCollectionView" Margin="20,10,20,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                        <Label Text="{x:Static helpers:IconFont.CalendarBlank}" FontFamily="MaterialIcons" FontSize="50" TextColor="#CDD2DB" HorizontalOptions="Center"/>
                        <Label Text="{Binding [NoBookings], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#A0A8B8" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Booking">
                        <Border StrokeThickness="0" BackgroundColor="White" Padding="16" Margin="0,0,0,10" StrokeShape="RoundRectangle 14">
                            <Border.Shadow>
                                <Shadow Brush="#000" Offset="0,2" Radius="8" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Notes}" FontSize="15" FontAttributes="Bold" TextColor="#1A1D26"/>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [TourDate], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#6B7588" FontSize="12"/>
                                    <Label Grid.Column="1" Text="{Binding TourDate, StringFormat='{0:dd/MM/yyyy}'}" TextColor="#1A1D26" FontSize="12" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [Participants], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#6B7588" FontSize="12"/>
                                    <Label Grid.Column="1" Text="{Binding NumberOfParticipants}" TextColor="#1A1D26" FontSize="12" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [TotalPrice], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#6B7588" FontSize="12"/>
                                    <Label Grid.Column="1" Text="{Binding TotalPrice, StringFormat='{0:N0} đ'}" TextColor="#00B14F" FontSize="12" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [Status], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#6B7588" FontSize="12"/>
                                    <Label Grid.Column="1" Text="{Binding Status}" TextColor="#007AFF" FontSize="12" FontAttributes="Bold"/>
                                </Grid>
                                <HorizontalStackLayout Spacing="2" Margin="0,4,0,0">
                                    <Label Text="{Binding [BookingDate], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#A0A8B8" FontSize="11"/>
                                    <Label Text="{Binding BookingDate, StringFormat=': {0:dd/MM/yyyy HH:mm}'}" TextColor="#A0A8B8" FontSize="11"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
