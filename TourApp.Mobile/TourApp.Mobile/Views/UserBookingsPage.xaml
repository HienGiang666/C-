<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TourApp.Mobile.Models"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.UserBookingsPage"
             Title="{Binding [MyTours], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#F5F6F8">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#FF3D00" StrokeThickness="0" Padding="20" Margin="0,0,0,10">
            <Label Text="{Binding [MyTours], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
        </Border>

        <RefreshView x:Name="BookingsRefreshView" Grid.Row="1" Refreshing="OnRefreshing">
            <CollectionView x:Name="BookingsCollectionView" Margin="20,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                        <Label Text="📭" FontSize="50" HorizontalOptions="Center"/>
                        <Label Text="{Binding [NoBookings], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="16" TextColor="#888" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Booking">
                        <Border StrokeThickness="0" BackgroundColor="White" Padding="15" Margin="0,0,0,15" StrokeShape="RoundRectangle 15">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Notes}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [TourDate], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding TourDate, StringFormat='{0:dd/MM/yyyy}'}" TextColor="Black" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [Participants], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding NumberOfParticipants}" TextColor="Black" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [TotalPrice], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding TotalPrice, StringFormat='{0:N0} đ'}" TextColor="#FF3D00" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="{Binding [Status], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding Status}" TextColor="#2196F3" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <HorizontalStackLayout Spacing="2" Margin="0,10,0,0">
                                    <Label Text="{Binding [BookingDate], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#AAA" FontSize="12"/>
                                    <Label Text="{Binding BookingDate, StringFormat=': {0:dd/MM/yyyy HH:mm}'}" TextColor="#AAA" FontSize="12"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
