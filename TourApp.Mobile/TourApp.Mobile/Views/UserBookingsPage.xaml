<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TourApp.Mobile.Models"
             x:Class="TourApp.Mobile.Views.UserBookingsPage"
             Title="Lịch sử Đặt Tour"
             BackgroundColor="#F5F6F8">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#FF3D00" StrokeThickness="0" Padding="20" Margin="0,0,0,10">
            <Label Text="Danh sách Tour đã đặt" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
        </Border>

        <RefreshView x:Name="BookingsRefreshView" Grid.Row="1" Refreshing="OnRefreshing">
            <CollectionView x:Name="BookingsCollectionView" Margin="20,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                        <Label Text="📭" FontSize="50" HorizontalOptions="Center"/>
                        <Label Text="Bạn chưa đặt tour nào." FontSize="16" TextColor="#888" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Booking">
                        <Border StrokeThickness="0" BackgroundColor="White" Padding="15" Margin="0,0,0,15" StrokeShape="RoundRectangle 15">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Notes}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="Ngày đi: " TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding TourDate, StringFormat='{0:dd/MM/yyyy}'}" TextColor="Black" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="Số người: " TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding NumberOfParticipants}" TextColor="Black" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="Tổng tiền: " TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding TotalPrice, StringFormat='{0:N0} đ'}" TextColor="#FF3D00" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="Trạng thái: " TextColor="#888" FontSize="14"/>
                                    <Label Grid.Column="1" Text="{Binding Status}" TextColor="#2196F3" FontSize="14" FontAttributes="Bold"/>
                                </Grid>
                                <Label Text="{Binding BookingDate, StringFormat='Đặt ngày: {0:dd/MM/yyyy HH:mm}'}" TextColor="#AAA" FontSize="12" Margin="0,10,0,0"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
