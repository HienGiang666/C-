<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.MapPage"
             Title="🗺 Tour Vĩnh Khánh"
             BackgroundColor="White">

    <Grid>
        <!-- Full Screen Map -->
        <WebView x:Name="MapWebView" HorizontalOptions="Fill" VerticalOptions="Fill" Navigating="OnMapWebViewNavigating" />

        <!-- Top Search Bar Floating -->
        <Border Padding="10,5" Margin="15,15,15,0" VerticalOptions="Start" HorizontalOptions="Fill"
                BackgroundColor="White" StrokeShape="RoundRectangle 25" StrokeThickness="0"
                Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.12, Radius=10}">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="🔍" FontSize="18" VerticalOptions="Center" Margin="5,0"/>
                <Entry x:Name="SearchEntry"
                       Placeholder="Tìm quán ăn, điểm tham quan..."
                       PlaceholderColor="#94A3B8"
                       TextColor="#333"
                       HorizontalOptions="FillAndExpand"
                       BackgroundColor="Transparent"
                       ReturnType="Search"
                       Completed="OnSearchCompleted"/>
                <Button Text="Tìm" BackgroundColor="#4F46E5" TextColor="White" CornerRadius="16"
                        HeightRequest="36" Padding="12,0" FontSize="13" Clicked="OnSearchClicked"/>
            </HorizontalStackLayout>
        </Border>

        <!-- Re-center GPS button -->
        <Border WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24"
                BackgroundColor="White" StrokeThickness="0" HorizontalOptions="End"
                VerticalOptions="Start" Margin="0,80,15,0"
                Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.15, Radius=8}">
            <Button Text="📍" BackgroundColor="Transparent" FontSize="20" Padding="0"
                    Clicked="OnRecenterClicked"/>
        </Border>

        <!-- Bottom Sheet Overlay -->
        <ContentView x:Name="BottomSheetView" IsVisible="False" VerticalOptions="End">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 24, 24, 0, 0" StrokeThickness="0"
                    Shadow="{Shadow Brush=Black, Offset='0,-5', Opacity=0.15, Radius=15}">
                <VerticalStackLayout Padding="0,0,0,30">
                    <!-- Handle Pill -->
                    <BoxView Color="#CBD5E1" HeightRequest="5" WidthRequest="40" CornerRadius="2.5"
                             HorizontalOptions="Center" Margin="0,12,0,12"/>

                    <!-- Cover Image -->
                    <Border StrokeShape="RoundRectangle 12" Margin="20,0,20,12" StrokeThickness="0" BackgroundColor="#F1F5F9">
                        <Image x:Name="PoiImage" HeightRequest="150" Aspect="AspectFill" />
                    </Border>

                    <VerticalStackLayout Padding="20,0">
                        <!-- Name + Fav Button -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="PoiNameLabel" Grid.Column="0" Text="Tên quán"
                                   FontSize="22" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Button x:Name="FavBtn" Grid.Column="1" Text="🤍" FontSize="20"
                                    BackgroundColor="Transparent" Padding="0" WidthRequest="40"
                                    Clicked="OnFavoriteClicked"/>
                        </Grid>

                        <!-- Rating row -->
                        <HorizontalStackLayout Spacing="6" Margin="0,4,0,8">
                            <Label x:Name="PoiRatingLabel" Text="⭐ 4.8" FontSize="14"
                                   FontAttributes="Bold" TextColor="#F59E0B"/>
                            <Label x:Name="PoiDistanceLabel" Text="• Đang xác định..."
                                   FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="PoiDescLabel" Text="" FontSize="14" LineHeight="1.4"
                               TextColor="#475569" MaxLines="3" LineBreakMode="TailTruncation" Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="🔊 Nghe" BackgroundColor="#4F46E5"
                                    TextColor="White" CornerRadius="12" FontAttributes="Bold"
                                    Clicked="OnPlayAudioClicked"/>
                            <Button Grid.Column="1" Text="🗺️ Đường đi" BackgroundColor="#E0E7FF"
                                    TextColor="#4F46E5" CornerRadius="12" FontAttributes="Bold"
                                    Clicked="OnDirectionsClicked"/>
                            <Button Grid.Column="2" Text="❌ Đóng" BackgroundColor="#F1F5F9"
                                    TextColor="#64748B" CornerRadius="12"
                                    Clicked="OnCloseSheetClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </ContentView>
    </Grid>
</ContentPage>