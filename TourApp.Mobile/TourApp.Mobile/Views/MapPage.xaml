<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.MapPage"
             Title="Tour Vĩnh Khánh"
             BackgroundColor="White">

    <Grid>
        <!-- Full Screen Map -->
        <WebView x:Name="MapWebView" HorizontalOptions="Fill" VerticalOptions="Fill" Navigating="OnMapWebViewNavigating" />

        <!-- Top Search Bar Floating -->
        <Border Padding="10,5" Margin="15,15,15,0" VerticalOptions="Start" HorizontalOptions="Fill"
                BackgroundColor="White" StrokeShape="RoundRectangle 25" StrokeThickness="0"
                Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.12, Radius=10}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                <Label Grid.Column="0" Text="{x:Static helpers:IconFont.Magnify}" FontFamily="MaterialIcons" FontSize="20" TextColor="#A0A8B8" VerticalOptions="Center" Margin="5,0"/>
                <Entry Grid.Column="1" x:Name="SearchEntry"
                       Placeholder="{Binding [SearchMap], Source={x:Static services:LocalizationResourceManager.Instance}}"
                       PlaceholderColor="#94A3B8"
                       TextColor="#1B1D2A"
                       HorizontalOptions="Fill"
                       BackgroundColor="Transparent"
                       ReturnType="Search"
                       Completed="OnSearchCompleted"/>
                <Button Grid.Column="2" Text="{Binding [Search], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" CornerRadius="16"
                        HeightRequest="36" Padding="12,0" FontSize="13" Clicked="OnSearchClicked"/>
            </Grid>
        </Border>

        <!-- Re-center GPS button -->
        <Border WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24"
                BackgroundColor="White" StrokeThickness="0" HorizontalOptions="End"
                VerticalOptions="Start" Margin="0,80,15,0"
                Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.15, Radius=8}">
            <Label Text="{x:Static helpers:IconFont.CrosshairsGps}" FontFamily="MaterialIcons" FontSize="22" TextColor="#00B14F" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRecenterClicked"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- QR Scanner button -->
        <Border WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24"
                BackgroundColor="#00B14F" StrokeThickness="0" HorizontalOptions="End"
                VerticalOptions="Start" Margin="0,200,15,0"
                Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.2, Radius=8}">
            <Label Text="{x:Static helpers:IconFont.QrcodeScan}" FontFamily="MaterialIcons" FontSize="22" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnQRScanClicked"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- Mock Location toggle button -->
        <Border x:Name="MockToggleBtn" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24"
                BackgroundColor="White" StrokeThickness="0" HorizontalOptions="End"
                VerticalOptions="Start" Margin="0,260,15,0"
                Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.15, Radius=8}">
            <Label x:Name="MockToggleIcon" Text="{x:Static helpers:IconFont.MapMarker}" FontFamily="MaterialIcons" FontSize="22" TextColor="#4A5568" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMockToggleClicked"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- Mock mode banner -->
        <Border x:Name="MockBanner" IsVisible="False" BackgroundColor="#FF6B00" StrokeThickness="0" 
                StrokeShape="RoundRectangle 12" Padding="12,6" HorizontalOptions="Center" 
                VerticalOptions="Start" Margin="0,70,0,0">
            <Label Text="{Binding [MockModeBanner], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" TextColor="White" FontAttributes="Bold"/>
        </Border>

        <ContentView x:Name="BottomSheetView" IsVisible="False" VerticalOptions="End">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 24, 24, 0, 0" StrokeThickness="0"
                    Shadow="{Shadow Brush=Black, Offset='0,-5', Opacity=0.15, Radius=15}">
                <VerticalStackLayout Padding="0,0,0,30">
                    <!-- Handle Pill -->
                    <BoxView Color="#CBD5E1" HeightRequest="5" WidthRequest="40" CornerRadius="2.5"
                             HorizontalOptions="Center" Margin="0,12,0,12"/>

                    <!-- Cover Image -->
                    <Border StrokeShape="RoundRectangle 12" Margin="20,0,20,12" StrokeThickness="0" BackgroundColor="#F1F5F9">
                        <Image x:Name="PoiImage" HeightRequest="150" Aspect="AspectFill" />
                    </Border>

                    <VerticalStackLayout Padding="20,0">
                        <!-- Name + Fav Button -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="PoiNameLabel" Grid.Column="0" Text="{Binding [PoiNamePlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="22" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Button x:Name="FavBtn" Grid.Column="1" Text="{x:Static helpers:IconFont.HeartOutline}" FontFamily="MaterialIcons" BackgroundColor="Transparent" TextColor="#4A5568" FontSize="20" Padding="0" WidthRequest="40"
                                    Clicked="OnFavoriteClicked"/>
                        </Grid>

                        <!-- Rating row -->
                        <HorizontalStackLayout Spacing="6" Margin="0,4,0,8">
                            <Label x:Name="PoiRatingLabel" Text="{x:Static helpers:IconFont.Star}" FontFamily="MaterialIcons" FontSize="14"
                                   FontAttributes="Bold" TextColor="#F59E0B"/>
                            <Label x:Name="PoiDistanceLabel" Text="{Binding [Locating], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="PoiDescLabel" Text="" FontSize="14" LineHeight="1.4"
                               TextColor="#475569" MaxLines="3" LineBreakMode="TailTruncation" Margin="0,0,0,20"/>

                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="{Binding [ListenAudio], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F"
                                    TextColor="White" CornerRadius="12" FontAttributes="Bold"
                                    Clicked="OnPlayAudioClicked"/>
                            <Button Grid.Column="1" Text="{Binding [Directions], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#E6F9EE"
                                    TextColor="#00B14F" CornerRadius="12" FontAttributes="Bold"
                                    Clicked="OnDirectionsClicked"/>
                            <Button Grid.Column="2" Text="{Binding [Close], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#F1F5F9"
                                    TextColor="#64748B" CornerRadius="12"
                                    Clicked="OnCloseSheetClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </ContentView>
        
        <!-- Floating Audio Player -->
        <ContentView x:Name="FloatingAudioPlayer" IsVisible="False" VerticalOptions="End" Margin="15,0,15,20">
            <Border BackgroundColor="#1E293B" StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="15,10">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.3" Radius="10"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                    <Label Text="{x:Static helpers:IconFont.MusicNote}" FontFamily="MaterialIcons" FontSize="20" TextColor="#00B14F" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label x:Name="AudioTitleLabel" Text="{Binding [NowPlaying], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="White" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                        <Label x:Name="AudioQueueCountLabel" Text="" TextColor="#94A3B8" FontSize="11" IsVisible="False"/>
                    </VerticalStackLayout>
                    <Button x:Name="AudioPlayPauseBtn" Grid.Column="2" Text="{x:Static helpers:IconFont.Pause}" FontFamily="MaterialIcons" BackgroundColor="Transparent" TextColor="White" FontSize="22" Padding="0" Clicked="OnToggleAudioClicked"/>
                    <Button Grid.Column="3" Text="{x:Static helpers:IconFont.SkipNext}" FontFamily="MaterialIcons" BackgroundColor="Transparent" TextColor="White" FontSize="22" Padding="0" Clicked="OnSkipAudioClicked"/>
                    <Button Grid.Column="4" Text="{x:Static helpers:IconFont.Close}" FontFamily="MaterialIcons" BackgroundColor="Transparent" TextColor="#94A3B8" FontSize="20" Padding="0" Clicked="OnStopAudioClicked"/>
                </Grid>
            </Border>
        </ContentView>
    </Grid>

</ContentPage>