<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.Auth.VerificationPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Padding="24,48,24,40" Spacing="0">
        <Border WidthRequest="38" HeightRequest="38" StrokeThickness="0" BackgroundColor="#F0F2F5" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
            <Label Text="{x:Static helpers:IconFont.ArrowLeft}" FontFamily="MaterialIcons" FontSize="20" TextColor="#1A1D26" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped" />
            </Border.GestureRecognizers>
        </Border>
        
        <Label Text="{Binding [VerificationTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="24" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center" Margin="0,20,0,4"/>
        <Label Text="{Binding [VerificationSubtitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" TextColor="#A0A8B8" HorizontalOptions="Center"/>
        <Label Text="example@gmail.com" FontSize="14" TextColor="#00B14F" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,4,0,28"/>

        <VerticalStackLayout Spacing="20">
            <Grid ColumnDefinitions="*,*">
                <Label Grid.Column="0" Text="{Binding [VerificationCode], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588"/>
                <Label x:Name="ResendLabel" Grid.Column="1" FontSize="12" TextColor="#A0A8B8" HorizontalTextAlignment="End"/>
            </Grid>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Border WidthRequest="56" HeightRequest="56" Stroke="#00B14F" StrokeThickness="2" Padding="0" BackgroundColor="White" StrokeShape="RoundRectangle 12">
                    <Entry Text="1" FontSize="24" TextColor="#1A1D26" HorizontalTextAlignment="Center" VerticalOptions="Center" IsTextPredictionEnabled="False"/>
                </Border>
                <Border WidthRequest="56" HeightRequest="56" Stroke="#E4E7ED" StrokeThickness="1" Padding="0" BackgroundColor="#F8F9FC" StrokeShape="RoundRectangle 12">
                    <Entry FontSize="24" TextColor="#1A1D26" HorizontalTextAlignment="Center" VerticalOptions="Center" IsTextPredictionEnabled="False"/>
                </Border>
                <Border WidthRequest="56" HeightRequest="56" Stroke="#E4E7ED" StrokeThickness="1" Padding="0" BackgroundColor="#F8F9FC" StrokeShape="RoundRectangle 12">
                    <Entry FontSize="24" TextColor="#1A1D26" HorizontalTextAlignment="Center" VerticalOptions="Center" IsTextPredictionEnabled="False"/>
                </Border>
                <Border WidthRequest="56" HeightRequest="56" Stroke="#E4E7ED" StrokeThickness="1" Padding="0" BackgroundColor="#F8F9FC" StrokeShape="RoundRectangle 12">
                    <Entry FontSize="24" TextColor="#1A1D26" HorizontalTextAlignment="Center" VerticalOptions="Center" IsTextPredictionEnabled="False"/>
                </Border>
            </HorizontalStackLayout>

            <Button Text="{Binding [Verify], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,8,0,0" Clicked="OnVerifyClicked"/>
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentPage>
