<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.VerificationPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Back Button & Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="20,40,20,20">
            <!-- Back button -->
            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="White" Padding="0" HasShadow="False" HorizontalOptions="Start">
                <Label Text="&lt;" FontSize="18" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Frame.GestureRecognizers>
            </Frame>
            
            <Label Text="Verification" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label Text="We have sent a code to your email" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
            <Label Text="example@gmail.com" FontSize="14" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="30" HasShadow="True" Margin="0" Padding="30,40,30,20">
            <VerticalStackLayout Spacing="20">
                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0" Text="CODE" FontSize="12" FontAttributes="Bold" TextColor="#444"/>
                    <Label Grid.Column="1" Text="Resend in 49sec" FontSize="12" TextColor="#777" HorizontalTextAlignment="End"/>
                </Grid>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Frame WidthRequest="60" HeightRequest="60" CornerRadius="15" BorderColor="Black" Padding="0" HasShadow="False" BackgroundColor="White">
                        <Entry Text="1" FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Frame WidthRequest="60" HeightRequest="60" CornerRadius="15" BorderColor="#E0E0E0" Padding="0" HasShadow="False" BackgroundColor="#F9F9F9">
                        <Entry FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Frame WidthRequest="60" HeightRequest="60" CornerRadius="15" BorderColor="#E0E0E0" Padding="0" HasShadow="False" BackgroundColor="#F9F9F9">
                        <Entry FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Frame WidthRequest="60" HeightRequest="60" CornerRadius="15" BorderColor="#E0E0E0" Padding="0" HasShadow="False" BackgroundColor="#F9F9F9">
                        <Entry FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Frame>
                </HorizontalStackLayout>

                <!-- Verify Button -->
                <Button Text="VERIFY" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,30,0,0" Clicked="OnVerifyClicked"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
