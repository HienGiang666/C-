<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.VerificationPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Back Button & Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="20,40,20,20">
            <!-- Back button -->
            <Border WidthRequest="40" HeightRequest="40" StrokeThickness="0" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20" HorizontalOptions="Start">
                <Label Text="&lt;" FontSize="18" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
            </Border>
            
            <Label Text="Xác nhận" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label Text="Chúng tôi đã gửi mã đến email của bạn" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
            <Label Text="example@gmail.com" FontSize="14" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White" Padding="30,40,30,20" Margin="0" StrokeShape="RoundRectangle 30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="20">
                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0" Text="MÃ XÁC NHẬN" FontSize="12" FontAttributes="Bold" TextColor="#444"/>
                    <Label Grid.Column="1" Text="Gửi lại sau 49s" FontSize="12" TextColor="#777" HorizontalTextAlignment="End"/>
                </Grid>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border WidthRequest="60" HeightRequest="60" Stroke="Black" StrokeThickness="1" Padding="0" BackgroundColor="White" StrokeShape="RoundRectangle 15">
                        <Entry Text="1" FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border WidthRequest="60" HeightRequest="60" Stroke="#E0E0E0" StrokeThickness="1" Padding="0" BackgroundColor="#F9F9F9" StrokeShape="RoundRectangle 15">
                        <Entry FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border WidthRequest="60" HeightRequest="60" Stroke="#E0E0E0" StrokeThickness="1" Padding="0" BackgroundColor="#F9F9F9" StrokeShape="RoundRectangle 15">
                        <Entry FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border WidthRequest="60" HeightRequest="60" Stroke="#E0E0E0" StrokeThickness="1" Padding="0" BackgroundColor="#F9F9F9" StrokeShape="RoundRectangle 15">
                        <Entry FontSize="24" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>

                <!-- Verify Button -->
                <Button Text="XÁC NHẬN" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,30,0,0" Clicked="OnVerifyClicked"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
