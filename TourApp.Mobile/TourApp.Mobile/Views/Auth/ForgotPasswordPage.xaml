<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.ForgotPasswordPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Back Button & Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="20,40,20,20">
            <!-- Back button -->
            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="White" Padding="0" HasShadow="False" HorizontalOptions="Start">
                <Label Text="&lt;" FontSize="18" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Frame.GestureRecognizers>
            </Frame>
            
            <Label Text="Forgot Password" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label Text="Please sign in to your existing account" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="30" HasShadow="True" Margin="0" Padding="30,40,30,20">
            <VerticalStackLayout Spacing="20">
                <!-- Email -->
                <VerticalStackLayout>
                    <Label Text="EMAIL" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Frame BorderColor="#E0E0E0" CornerRadius="10" Padding="15,0" HasShadow="False" BackgroundColor="#F9F9F9" HeightRequest="50">
                        <Entry Placeholder="example@gmail.com" TextColor="Black" PlaceholderColor="#B0B0B0" Keyboard="Email" VerticalOptions="Center"/>
                    </Frame>
                </VerticalStackLayout>

                <!-- Send Code Button -->
                <Button Text="SEND CODE" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,20,0,0" Clicked="OnSendCodeClicked"/>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
