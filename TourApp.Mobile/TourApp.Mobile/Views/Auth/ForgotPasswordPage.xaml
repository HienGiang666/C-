<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             x:Class="TourApp.Mobile.Views.Auth.ForgotPasswordPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Padding="24,48,24,40" Spacing="0">
        <Border WidthRequest="38" HeightRequest="38" StrokeThickness="0" BackgroundColor="#F0F2F5" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
            <Label Text="{x:Static helpers:IconFont.ArrowLeft}" FontFamily="MaterialIcons" FontSize="20" TextColor="#1A1D26" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped" />
            </Border.GestureRecognizers>
        </Border>
        
        <Label Text="Quên mật khẩu?" FontSize="24" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center" Margin="0,20,0,4"/>
        <Label Text="Nhập email để nhận mã xác nhận" FontSize="13" TextColor="#A0A8B8" HorizontalOptions="Center" Margin="0,0,0,32"/>

        <VerticalStackLayout Spacing="18">
            <VerticalStackLayout>
                <Label Text="Email" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" Padding="14,0" HeightRequest="50" StrokeShape="RoundRectangle 12">
                    <Entry x:Name="EmailEntry" Placeholder="Nhập email của bạn" TextColor="#1A1D26" PlaceholderColor="#A0A8B8" FontSize="14" Keyboard="Email" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>
            <Button Text="GỬI MÃ XÁC NHẬN" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,8,0,0" Clicked="OnSendCodeClicked"/>
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentPage>
