<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.SignUpPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Back Button & Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="20,40,20,20">
            <!-- Back button -->
            <Border WidthRequest="40" HeightRequest="40" StrokeThickness="0" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20" HorizontalOptions="Start">
                <Label Text="&lt;" FontSize="18" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
            </Border>
            
            <Label Text="Sign Up" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label Text="Please sign up to get started" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White" Padding="30,40,30,20" Margin="0" StrokeShape="RoundRectangle 30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <ScrollView>
                <VerticalStackLayout Spacing="20">
                    <!-- Name -->
                    <VerticalStackLayout>
                        <Label Text="NAME" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                        <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                            <Entry x:Name="FullNameEntry" Placeholder="John doe" TextColor="Black" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Username -->
                    <VerticalStackLayout>
                        <Label Text="USERNAME" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                        <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                            <Entry x:Name="UsernameEntry" Placeholder="Enter username" TextColor="Black" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout>
                        <Label Text="EMAIL" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                        <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                            <Entry x:Name="EmailEntry" Placeholder="example@gmail.com" TextColor="Black" PlaceholderColor="#B0B0B0" Keyboard="Email" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout>
                        <Label Text="PASSWORD" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                        <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                            <Grid ColumnDefinitions="*,30">
                                <Entry x:Name="PasswordEntry" Grid.Column="0" Placeholder="••••••••" TextColor="Black" IsPassword="True" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                                <Label x:Name="ShowPasswordLabel" Grid.Column="1" Text="👁" TextColor="#888" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnShowPasswordTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Re-type Password -->
                    <VerticalStackLayout>
                        <Label Text="RE-TYPE PASSWORD" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                        <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                            <Grid ColumnDefinitions="*,30">
                                <Entry x:Name="ConfirmPasswordEntry" Grid.Column="0" Placeholder="••••••••" TextColor="Black" IsPassword="True" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                                <Label x:Name="ShowConfirmPasswordLabel" Grid.Column="1" Text="👁" TextColor="#888" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnShowConfirmPasswordTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Sign Up Button -->
                    <Button x:Name="SignUpButton" Text="SIGN UP" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,10,0,50" Clicked="OnSignUpClicked"/>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>
