<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.ResetPasswordPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Back Button & Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="20,40,20,20">
            <!-- Back button -->
            <Border WidthRequest="40" HeightRequest="40" StrokeThickness="0" BackgroundColor="White" Padding="0" StrokeShape="RoundRectangle 20" HorizontalOptions="Start">
                <Label Text="&lt;" FontSize="18" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Border.GestureRecognizers>
            </Border>
            
            <Label Text="Đặt lại mật khẩu" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
            <Label Text="Nhập mã và mật khẩu mới" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White" Padding="30,40,30,20" Margin="0" StrokeShape="RoundRectangle 30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="20">
                <!-- Reset Code -->
                <VerticalStackLayout>
                    <Label Text="MÃ XÁC NHẬN" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Entry x:Name="CodeEntry" Placeholder="Nhập mã xác nhận" TextColor="Black" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- New Password -->
                <VerticalStackLayout>
                    <Label Text="MẬT KHẨU MỚI" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Entry x:Name="NewPasswordEntry" Placeholder="Nhập mật khẩu mới" TextColor="Black" PlaceholderColor="#B0B0B0" IsPassword="True" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Confirm New Password -->
                <VerticalStackLayout>
                    <Label Text="XÁC NHẬN MẬT KHẨU MỚI" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Nhập lại mật khẩu mới" TextColor="Black" PlaceholderColor="#B0B0B0" IsPassword="True" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Reset Button -->
                <Button x:Name="ResetButton" Text="ĐẶT LẠI MẬT KHẨU" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,20,0,0" Clicked="OnResetClicked"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
