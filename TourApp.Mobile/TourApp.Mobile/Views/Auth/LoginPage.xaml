<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.LoginPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="0,50,0,30" HorizontalOptions="Center">
            <Label Text="Đăng nhập" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            <Label Text="Vui lòng đăng nhập để tiếp tục" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White" Padding="30,40,30,20" Margin="0" StrokeShape="RoundRectangle 30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="20">
                <!-- Username -->
                <VerticalStackLayout>
                    <Label Text="TÀI KHOẢN" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Entry x:Name="UsernameEntry" Placeholder="Nhập tài khoản" TextColor="Black" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout>
                    <Label Text="MẬT KHẨU" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*,30">
                            <Entry x:Name="PasswordEntry" Grid.Column="0" Placeholder="Nhập mật khẩu" TextColor="Black" IsPassword="True" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                            <Label x:Name="ShowPasswordLabel" Grid.Column="1" Text="👁" TextColor="#888" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnShowPasswordTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Remember me -->
                <HorizontalStackLayout Margin="0,-10,0,0" Spacing="-5">
                    <CheckBox Color="#FF5B00" Scale="0.8"/>
                    <Label Text="Ghi nhớ" TextColor="#555" VerticalOptions="Center" FontSize="13"/>
                </HorizontalStackLayout>

                <!-- Login Button -->
                <Button x:Name="LoginButton" Text="ĐĂNG NHẬP" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,10,0,0" Clicked="OnLoginClicked"/>

                <!-- Sign up text -->
                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
                    <Label Text="Chưa có tài khoản? " TextColor="#555" FontSize="13"/>
                    <Label Text="ĐĂNG KÝ NGAY" TextColor="#FF5B00" FontSize="13" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSignUpTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Guest login button -->
                <Button x:Name="GuestLoginButton" Text="ĐĂNG NHẬP KHÁCH" BackgroundColor="Transparent" TextColor="#666" FontAttributes="Bold" CornerRadius="15" HeightRequest="50" Margin="0,5,0,0" BorderColor="#999" BorderWidth="1" Clicked="OnGuestLoginClicked"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
