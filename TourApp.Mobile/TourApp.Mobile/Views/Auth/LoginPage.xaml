<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:TourApp.Mobile.Helpers"
             xmlns:services="clr-namespace:TourApp.Mobile.Services"
             x:Class="TourApp.Mobile.Views.Auth.LoginPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="28,60,28,0" Spacing="0">
                
                <!-- Logo -->
                <Border WidthRequest="72" HeightRequest="72" StrokeThickness="0" HorizontalOptions="Center" BackgroundColor="#E6F9EE" StrokeShape="RoundRectangle 22">
                    <Label Text="{x:Static helpers:IconFont.Map}" FontFamily="MaterialIcons" FontSize="34" TextColor="#00B14F" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                
                <Label Text="TourApp" FontSize="28" FontAttributes="Bold" TextColor="#1A1D26" HorizontalOptions="Center" Margin="0,16,0,4"/>
                <Label Text="{Binding [AppSlogan], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="14" TextColor="#A0A8B8" HorizontalOptions="Center" Margin="0,0,0,36"/>

                <!-- Form -->
                <VerticalStackLayout Spacing="18">
                    <!-- Username -->
                    <VerticalStackLayout>
                        <Label Text="{Binding [Username], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                        <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" Padding="14,0" HeightRequest="50" StrokeShape="RoundRectangle 12">
                            <Entry x:Name="UsernameEntry" Placeholder="{Binding [UsernamePlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" PlaceholderColor="#A0A8B8" FontSize="14" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout>
                        <Label Text="{Binding [Password], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" FontAttributes="Bold" TextColor="#6B7588" Margin="0,0,0,8"/>
                        <Border Stroke="#E4E7ED" StrokeThickness="1" BackgroundColor="#F8F9FC" Padding="14,0" HeightRequest="50" StrokeShape="RoundRectangle 12">
                            <Grid ColumnDefinitions="*,36">
                                <Entry x:Name="PasswordEntry" Grid.Column="0" Placeholder="{Binding [PasswordPlaceholder], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#1A1D26" IsPassword="True" PlaceholderColor="#A0A8B8" FontSize="14" VerticalOptions="Center"/>
                                <Label x:Name="ShowPasswordLabel" Grid.Column="1" Text="{x:Static helpers:IconFont.EyeOff}" FontFamily="MaterialIcons" TextColor="#A0A8B8" VerticalOptions="Center" HorizontalOptions="Center" FontSize="20">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnShowPasswordTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Remember me -->
                    <HorizontalStackLayout Margin="0,-6,0,0" Spacing="8">
                        <CheckBox Color="#00B14F" Scale="0.8"/>
                        <Label Text="{Binding [RememberLogin], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#6B7588" VerticalOptions="Center" FontSize="13"/>
                    </HorizontalStackLayout>

                    <!-- Login Button -->
                    <Button x:Name="LoginButton" Text="{Binding [LoginButton], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="#00B14F" TextColor="White" FontAttributes="Bold" FontSize="15" CornerRadius="12" HeightRequest="50" Margin="0,4,0,0" Clicked="OnLoginClicked"/>

                    <!-- Sign up -->
                    <HorizontalStackLayout HorizontalOptions="Center" Margin="0,4,0,0">
                        <Label Text="{Binding [NoAccount], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#6B7588" FontSize="13"/>
                        <Label Text="{Binding [SignUpNow], Source={x:Static services:LocalizationResourceManager.Instance}}" TextColor="#00B14F" FontSize="13" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSignUpTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Guest login -->
        <VerticalStackLayout Grid.Row="1" Padding="28,0,28,36">
            <Button x:Name="GuestLoginButton" Text="{Binding [ContinueAsGuest], Source={x:Static services:LocalizationResourceManager.Instance}}" BackgroundColor="Transparent" TextColor="#6B7588" FontAttributes="Bold" FontSize="14" CornerRadius="12" HeightRequest="48" BorderColor="#E4E7ED" BorderWidth="1" Clicked="OnGuestLoginClicked"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
