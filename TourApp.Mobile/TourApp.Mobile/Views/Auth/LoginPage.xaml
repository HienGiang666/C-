<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourApp.Mobile.Views.Auth.LoginPage"
             BackgroundColor="#16182B"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Header text -->
        <VerticalStackLayout Grid.Row="0" Margin="0,50,0,30" HorizontalOptions="Center">
            <Label Text="Log In" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            <Label Text="Please sign in to your existing account" FontSize="14" TextColor="#A0A0B0" HorizontalOptions="Center" Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- White card form -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White" Padding="30,40,30,20" Margin="0" StrokeShape="RoundRectangle 30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="20">
                <!-- Username -->
                <VerticalStackLayout>
                    <Label Text="USERNAME" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Entry x:Name="UsernameEntry" Placeholder="Enter username" TextColor="Black" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout>
                    <Label Text="PASSWORD" FontSize="12" FontAttributes="Bold" TextColor="#444" Margin="0,0,0,5"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#F9F9F9" Padding="15,0" HeightRequest="50" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*,30">
                            <Entry x:Name="PasswordEntry" Grid.Column="0" Placeholder="••••••••" TextColor="Black" IsPassword="True" PlaceholderColor="#B0B0B0" VerticalOptions="Center"/>
                            <Label x:Name="ShowPasswordLabel" Grid.Column="1" Text="👁" TextColor="#888" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnShowPasswordTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Remember / Forgot -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-10,0,0">
                    <CheckBox Grid.Column="0" Color="#FF5B00" Scale="0.8"/>
                    <Label Grid.Column="1" Text="Remember me" TextColor="#555" VerticalOptions="Center" FontSize="13" Margin="-5,0,0,0"/>
                    <Label Grid.Column="2" Text="Forgot Password" TextColor="#FF5B00" VerticalOptions="Center" FontSize="13">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnForgotPasswordTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- Login Button -->
                <Button x:Name="LoginButton" Text="LOG IN" BackgroundColor="#FF5B00" TextColor="White" FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,10,0,0" Clicked="OnLoginClicked"/>

                <!-- Sign up text -->
                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
                    <Label Text="Don't have an account? " TextColor="#555" FontSize="13"/>
                    <Label Text="SIGN UP" TextColor="#FF5B00" FontSize="13" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSignUpTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <!-- Social login mock -->
                <Label Text="Or" TextColor="#999" HorizontalOptions="Center" FontSize="13" Margin="0,15,0,5"/>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                    <Button Text="f" WidthRequest="50" HeightRequest="50" CornerRadius="25" BackgroundColor="#1877F2" TextColor="White" FontAttributes="Bold" Padding="0"/>
                    <Button Text="t" WidthRequest="50" HeightRequest="50" CornerRadius="25" BackgroundColor="#1DA1F2" TextColor="White" FontAttributes="Bold" Padding="0"/>
                    <Button Text="a" WidthRequest="50" HeightRequest="50" CornerRadius="25" BackgroundColor="#000000" TextColor="White" FontAttributes="Bold" Padding="0"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
