<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══ Fresh Green Palette (Grab-inspired) ═══ -->

    <!-- Primary Green -->
    <Color x:Key="Primary">#00B14F</Color>
    <Color x:Key="PrimaryDark">#009740</Color>
    <Color x:Key="PrimaryLight">#E6F9EE</Color>
    <Color x:Key="PrimaryDarkText">#1A1D26</Color>
    <Color x:Key="Secondary">#E6F9EE</Color>
    <Color x:Key="SecondaryDarkText">#00873A</Color>
    <Color x:Key="Tertiary">#007A33</Color>

    <!-- Accent - Warm Orange for CTA highlights -->
    <Color x:Key="Accent">#FF6B00</Color>
    <Color x:Key="AccentLight">#FFF3E8</Color>
    <Color x:Key="AccentGreen">#00B14F</Color>
    <Color x:Key="AccentRed">#FF3B30</Color>
    <Color x:Key="AccentBlue">#007AFF</Color>
    <Color x:Key="AccentTeal">#00BFA5</Color>

    <!-- Background -->
    <Color x:Key="Background">#F5F7FA</Color>
    <Color x:Key="BackgroundDark">#0F1118</Color>
    <Color x:Key="BackgroundWarm">#FFF8F3</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#1A1D26</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardDarkBackground">#1E2130</Color>
    <Color x:Key="CardElevated">#FFFFFF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1A1D26</Color>
    <Color x:Key="TextSecondary">#6B7588</Color>
    <Color x:Key="TextTertiary">#A0A8B8</Color>
    <Color x:Key="TextInverse">#FFFFFF</Color>
    <Color x:Key="TextLink">#00B14F</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Legacy compat -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#00B14F</Color>
    <Color x:Key="MidnightBlue">#1A1D26</Color>
    <Color x:Key="OffBlack">#1A1D26</Color>

    <!-- Grays (Neutral Slate) -->
    <Color x:Key="Gray50">#F8F9FC</Color>
    <Color x:Key="Gray100">#F0F2F5</Color>
    <Color x:Key="Gray200">#E4E7ED</Color>
    <Color x:Key="Gray300">#CDD2DB</Color>
    <Color x:Key="Gray400">#A0A8B8</Color>
    <Color x:Key="Gray500">#6B7588</Color>
    <Color x:Key="Gray600">#4A5568</Color>
    <Color x:Key="Gray900">#1A1D26</Color>
    <Color x:Key="Gray950">#0F1118</Color>

    <!-- Category Colors -->
    <Color x:Key="CatNuong">#FFF2E8</Color>
    <Color x:Key="CatLau">#FFE8E8</Color>
    <Color x:Key="CatOc">#E8F0FE</Color>
    <Color x:Key="CatAnVat">#E6F9EE</Color>

    <!-- Status Colors -->
    <Color x:Key="StatusSuccess">#E6F9EE</Color>
    <Color x:Key="StatusWarning">#FFF3E0</Color>
    <Color x:Key="StatusError">#FFEBEE</Color>
    <Color x:Key="StatusInfo">#E3F2FD</Color>

    <!-- Solid Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>

    <!-- Gradient Brushes (subtle, not heavy) -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00B14F" Offset="0.0"/>
        <GradientStop Color="#00C853" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00B14F" Offset="0.0"/>
        <GradientStop Color="#00C853" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0.0"/>
        <GradientStop Color="#F5F7FA" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarmGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E6F9EE" Offset="0.0"/>
        <GradientStop Color="#D0F0DC" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>